{% extends 'base.html.twig' %}

{% block title %}Accueil - {{ parent() }}{% endblock %}

{% block body %}
<div class="container mt-5">
    <div class="row">
        <div class="col-12 text-center">
            <h1 class="display-4 text-success">Bienvenue sur Agrigo</h1>
            <p class="lead">Votre plateforme de gestion agricole</p>
        </div>
    </div>
    <div class="row mt-5">
        <div class="col-md-4">
            <div class="card h-100">
                <div class="card-body text-center">
                    <i class="fas fa-seedling fa-3x text-success mb-3"></i>
                    <h5 class="card-title">Gestion des Cultures</h5>
                    <p class="card-text">Suivez vos cultures et leur évolution.</p>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card h-100">
                <div class="card-body text-center">
                    <i class="fas fa-map-marked-alt fa-3x text-success mb-3"></i>
                    <h5 class="card-title">Parcelles</h5>
                    <p class="card-text">Gérez vos parcelles agricoles.</p>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card h-100">
                <div class="card-body text-center">
                    <i class="fas fa-chart-line fa-3x text-success mb-3"></i>
                    <h5 class="card-title">Suivi des Récoltes</h5>
                    <p class="card-text">Analysez vos performances.</p>
                </div>
            </div>
        </div>
    </div>
    {% if app.user %}
        <div class="row mt-5">
            <div class="col-12 text-center">
                <a href="{{ path('app_profile') }}" class="btn btn-primary btn-lg">
                    <i class="fas fa-user"></i> Mon Profil
                </a>
                {% if is_granted('ROLE_ADMIN') %}
                    <a href="{{ path('app_admin_users') }}" class="btn btn-secondary btn-lg ms-3">
                        <i class="fas fa-users-cog"></i> Gestion Utilisateurs
                    </a>
                {% endif %}
            </div>
        </div>
    {% else %}
        <div class="row mt-5">
            <div class="col-12 text-center">
                <a href="{{ path('app_login') }}" class="btn btn-primary btn-lg">
                    <i class="fas fa-sign-in-alt"></i> Se connecter
                </a>
                <a href="{{ path('app_register') }}" class="btn btn-success btn-lg ms-3">
                    <i class="fas fa-user-plus"></i> S'inscrire
                </a>
            </div>
        </div>
    {% endif %}
</div>
{% endblock %}