{% extends 'base.html.twig' %}

{% block title %}Mes Tâches{% endblock %}

{% block content %}
<div class="container mt-5">
    <div class="row mb-4">
        <div class="col-md-8">
            <h1>Mes Tâches</h1>
        </div>
        <div class="col-md-4 text-end">
            <a href="#" class="btn btn-primary">Ajouter une tâche</a>
        </div>
    </div>

    {% if tasks is empty %}
        <div class="alert alert-info">
            Aucune tâche trouvée.
        </div>
    {% else %}
        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead class="table-dark">
                    <tr>
                        <th>ID</th>
                        <th>Titre</th>
                        <th>Description</th>
                        <th>Type</th>
                        <th>Statut</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    {% for task in tasks %}
                        <tr>
                            <td>{{ task.idTache }}</td>
                            <td>{{ task.titreTache }}</td>
                            <td>{{ task.descriptionTache }}</td>
                            <td>{{ task.typeTache }}</td>
                            <td>
                                {% if task.statusTache == 'complétée' %}
                                    <span class="badge bg-success">Complétée</span>
                                {% elseif task.statusTache == 'en cours' %}
                                    <span class="badge bg-warning">En cours</span>
                                {% else %}
                                    <span class="badge bg-secondary">{{ task.statusTache }}</span>
                                {% endif %}
                            </td>
                            <td>
                                <a href="#" class="btn btn-sm btn-info">Voir</a>
                                <a href="#" class="btn btn-sm btn-warning">Éditer</a>
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    {% endif %}
</div>
{% endblock %}
