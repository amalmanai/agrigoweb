{% extends 'base.html.twig' %}

{% block title %}Mot de passe oublié - Agrigo{% endblock %}

{% block body %}
<div class="row justify-content-center align-items-center" style="min-height: 80vh;">
    <div class="col-md-6 col-lg-5">
        <div class="card border-0 shadow-lg p-4 animate__animated animate__zoomIn" style="border-radius: 20px; background: rgba(255, 255, 255, 0.9); backdrop-filter: blur(10px);">
            <div class="text-center mb-4">
                <img src="{{ asset('images/logo.png') }}" alt="Agrigo Logo" height="120" class="mb-3">
                <h2 class="fw-bold text-dark">Propulsez votre Agriculture</h2>
                <p class="text-muted">Entrez votre email pour recevoir votre code OTP de vérification.</p>
            </div>

            <form method="post">
                <div class="mb-4">
                    <label class="form-label text-dark fw-semibold">Adresse Email</label>
                    <div class="input-group">
                        <span class="input-group-text bg-white border-end-0"><i class="fas fa-envelope text-muted"></i></span>
                        <input type="email" name="email" class="form-control border-start-0 ps-0" placeholder="exemple@agri.tn" required autofocus>
                    </div>
                </div>

                <button class="btn btn-success btn-lg w-100 shadow-sm transition-all mb-3" type="submit" style="border-radius: 12px;">
                    Envoyer le code <i class="fas fa-paper-plane ms-2"></i>
                </button>
            </form>

            <div class="text-center mt-3">
                <a href="{{ path('app_login') }}" class="text-decoration-none text-muted small">
                    <i class="fas fa-arrow-left me-1"></i> Retour à la connexion
                </a>
            </div>
        </div>
    </div>
</div>

<style>
    .transition-all {
        transition: all 0.3s ease;
    }
    .transition-all:hover {
        transform: translateY(-2px);
        box-shadow: 0 5px 15px rgba(40, 167, 69, 0.3) !important;
    }
</style>
{% endblock %}
