{% extends 'base.html.twig' %}

{% block title %}Inscription - {{ parent() }}{% endblock %}

{% block body %}
<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow">
                <div class="card-header bg-success text-white">
                    <h2 class="mb-0"><i class="fas fa-user-plus"></i> Créer un compte</h2>
                </div>
                <div class="card-body">
                    {% if registrationForm.vars.errors | length > 0 %}
                        <div class="alert alert-danger alert-dismissible fade show" role="alert">
                            <h4 class="alert-heading"><i class="fas fa-exclamation-triangle"></i> Erreurs de validation</h4>
                            {% for error in registrationForm.vars.errors %}
                                <div class="mb-2">{{ error.message }}</div>
                            {% endfor %}
                            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                        </div>
                    {% endif %}

                    {{ form_start(registrationForm, {'attr': {'novalidate': 'novalidate'}}) }}
                        <div class="row">
                            <div class="col-md-6">
                                <div class="form-group mb-3">
                                    {{ form_label(registrationForm.nomUser) }}
                                    {{ form_widget(registrationForm.nomUser, {
                                        attr: {class: 'form-control ' ~ (registrationForm.nomUser.vars.errors | length > 0 ? 'is-invalid' : '')}
                                    }) }}
                                    {% if registrationForm.nomUser.vars.errors | length > 0 %}
                                        <div class="invalid-feedback d-block">
                                            {% for error in registrationForm.nomUser.vars.errors %}
                                                <i class="fas fa-times-circle"></i> {{ error.message }}
                                            {% endfor %}
                                        </div>
                                    {% endif %}
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-group mb-3">
                                    {{ form_label(registrationForm.prenomUser) }}
                                    {{ form_widget(registrationForm.prenomUser, {
                                        attr: {class: 'form-control ' ~ (registrationForm.prenomUser.vars.errors | length > 0 ? 'is-invalid' : '')}
                                    }) }}
                                    {% if registrationForm.prenomUser.vars.errors | length > 0 %}
                                        <div class="invalid-feedback d-block">
                                            {% for error in registrationForm.prenomUser.vars.errors %}
                                                <i class="fas fa-times-circle"></i> {{ error.message }}
                                            {% endfor %}
                                        </div>
                                    {% endif %}
                                </div>
                            </div>
                        </div>

                        <div class="form-group mb-3">
                            {{ form_label(registrationForm.emailUser) }}
                            {{ form_widget(registrationForm.emailUser, {
                                attr: {class: 'form-control ' ~ (registrationForm.emailUser.vars.errors | length > 0 ? 'is-invalid' : '')}
                            }) }}
                            {% if registrationForm.emailUser.vars.errors | length > 0 %}
                                <div class="invalid-feedback d-block">
                                    {% for error in registrationForm.emailUser.vars.errors %}
                                        <i class="fas fa-times-circle"></i> {{ error.message }}
                                    {% endfor %}
                                </div>
                            {% endif %}
                        </div>

                        <div class="row">
                            <div class="col-md-6">
                                <div class="form-group mb-3">
                                    {{ form_label(registrationForm.numUser) }}
                                    {{ form_widget(registrationForm.numUser, {
                                        attr: {class: 'form-control ' ~ (registrationForm.numUser.vars.errors | length > 0 ? 'is-invalid' : '')}
                                    }) }}
                                    {% if registrationForm.numUser.vars.errors | length > 0 %}
                                        <div class="invalid-feedback d-block">
                                            {% for error in registrationForm.numUser.vars.errors %}
                                                <i class="fas fa-times-circle"></i> {{ error.message }}
                                            {% endfor %}
                                        </div>
                                    {% endif %}
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-group mb-3">
                                    {{ form_label(registrationForm.adresseUser) }}
                                    {{ form_widget(registrationForm.adresseUser, {
                                        attr: {class: 'form-control ' ~ (registrationForm.adresseUser.vars.errors | length > 0 ? 'is-invalid' : '')}
                                    }) }}
                                    {% if registrationForm.adresseUser.vars.errors | length > 0 %}
                                        <div class="invalid-feedback d-block">
                                            {% for error in registrationForm.adresseUser.vars.errors %}
                                                <i class="fas fa-times-circle"></i> {{ error.message }}
                                            {% endfor %}
                                        </div>
                                    {% endif %}
                                </div>
                            </div>
                        </div>

                        <div class="form-group mb-3">
                            {{ form_label(registrationForm.password) }}
                            {{ form_widget(registrationForm.password, {
                                attr: {class: 'form-control ' ~ (registrationForm.password.vars.errors | length > 0 ? 'is-invalid' : '')}
                            }) }}
                            {% if registrationForm.password.vars.errors | length > 0 %}
                                <div class="invalid-feedback d-block">
                                    {% for error in registrationForm.password.vars.errors %}
                                        <i class="fas fa-times-circle"></i> {{ error.message }}
                                    {% endfor %}
                                </div>
                            {% endif %}
                        </div>

                        <div class="mt-4">
                            <button type="submit" class="btn btn-success btn-block w-100">
                                <i class="fas fa-user-plus"></i> S'inscrire
                            </button>
                        </div>

                        <p class="text-center mt-3">
                            Déjà un compte ? <a href="{{ path('app_login') }}" class="btn btn-link">Se connecter</a>
                        </p>
                    {{ form_end(registrationForm) }}
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .invalid-feedback {
        color: #dc3545;
        font-size: 0.875em;
        margin-top: 0.25rem;
        display: block !important;
    }
    .form-control.is-invalid {
        border-color: #dc3545;
    }
</style>
{% endblock %}