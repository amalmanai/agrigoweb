<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}AgriGo Admin{% endblock %}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <style>
        :root {
            --admin-bg: #f2f6fc;
            --admin-sidebar: #1f2a40;
            --admin-sidebar-2: #273551;
            --admin-accent: #0d6efd;
            --admin-text: #1e2a3a;
            --admin-muted: #77829a;
            --admin-card: #ffffff;
        }

        body {
            font-family: 'Nunito', sans-serif;
            background: var(--admin-bg);
            color: var(--admin-text);
            min-height: 100vh;
            margin: 0;
        }

        .admin-layout {
            display: flex;
            min-height: 100vh;
        }

        .admin-sidebar {
            width: 260px;
            background: linear-gradient(180deg, var(--admin-sidebar) 0%, var(--admin-sidebar-2) 100%);
            color: #dbe4ff;
            position: sticky;
            top: 0;
            height: 100vh;
            padding: 1rem 0.85rem;
            box-shadow: 8px 0 20px rgba(13, 20, 35, 0.16);
        }

        .admin-brand {
            display: flex;
            align-items: center;
            gap: 0.65rem;
            color: #f3f7ff;
            text-decoration: none;
            font-weight: 800;
            font-size: 1.1rem;
            padding: 0.65rem 0.75rem 1rem;
            border-bottom: 1px solid rgba(255, 255, 255, 0.12);
            margin-bottom: 1rem;
        }

        .admin-brand i {
            font-size: 1.25rem;
            color: #8ec5ff;
        }

        .admin-nav {
            display: flex;
            flex-direction: column;
            gap: 0.25rem;
        }

        .admin-nav a {
            color: #d5def3;
            text-decoration: none;
            border-radius: 8px;
            padding: 0.62rem 0.78rem;
            font-weight: 700;
            font-size: 0.92rem;
            letter-spacing: 0.1px;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        .admin-nav a:hover,
        .admin-nav a.active {
            background: rgba(255, 255, 255, 0.12);
            color: #ffffff;
        }

        .admin-main {
            flex: 1;
            min-width: 0;
            display: flex;
            flex-direction: column;
        }

        .admin-topbar {
            height: 64px;
            background: #ffffff;
            border-bottom: 1px solid #dfe6f3;
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0 1.15rem;
        }

        .topbar-title {
            font-weight: 800;
            font-size: 1rem;
            color: #324154;
        }

        .topbar-badge {
            background: #e7f0ff;
            color: #205bbb;
            font-weight: 700;
            border-radius: 999px;
            padding: 0.3rem 0.7rem;
            font-size: 0.78rem;
        }

        .admin-content {
            padding: 1rem;
        }

        .admin-stats {
            display: grid;
            grid-template-columns: repeat(4, minmax(0, 1fr));
            gap: 0.85rem;
            margin-bottom: 0.95rem;
        }

        .stat-box {
            background: var(--admin-card);
            border-left: 4px solid var(--admin-accent);
            border-radius: 10px;
            box-shadow: 0 4px 14px rgba(40, 51, 72, 0.09);
            padding: 0.78rem 0.82rem;
        }

        .stat-box.alt-warn {
            border-left-color: #f0ad4e;
        }

        .stat-box.alt-ok {
            border-left-color: #1cc88a;
        }

        .stat-box.alt-danger {
            border-left-color: #e74a3b;
        }

        .stat-label {
            font-size: 0.72rem;
            text-transform: uppercase;
            letter-spacing: 0.8px;
            color: #6e7b94;
            font-weight: 800;
            margin-bottom: 0.18rem;
        }

        .stat-value {
            font-size: 1.2rem;
            font-weight: 800;
            color: #2f3f56;
            line-height: 1;
        }

        .back-shell {
            background: #ffffff;
            border: 1px solid #e1e7f1;
            border-radius: 12px;
            box-shadow: 0 10px 22px rgba(25, 41, 72, 0.08);
            padding: 1rem;
        }

        .back-shell .table {
            --bs-table-striped-bg: #f7f9fd;
        }

        .back-shell .table thead th {
            background: #f0f4fb;
            color: #445671;
            border-bottom-color: #d8e1ef;
        }

        .back-shell .btn-primary {
            box-shadow: 0 5px 14px rgba(38, 97, 189, 0.24);
        }

        @media (max-width: 1080px) {
            .admin-stats {
                grid-template-columns: repeat(2, minmax(0, 1fr));
            }
        }

        @media (max-width: 900px) {
            .admin-layout {
                flex-direction: column;
            }

            .admin-sidebar {
                width: 100%;
                height: auto;
                position: relative;
                box-shadow: none;
            }

            .admin-nav {
                flex-direction: row;
                flex-wrap: wrap;
            }

            .admin-nav a {
                flex: 1 1 170px;
            }
        }

        @media (max-width: 640px) {
            .admin-stats {
                grid-template-columns: 1fr;
            }

            .admin-topbar {
                padding: 0 0.8rem;
            }
        }
    </style>
    {% block stylesheets %}{% endblock %}
</head>
<body>
<div class="admin-layout">
    <aside class="admin-sidebar">
        <a class="admin-brand" href="{{ path('admin_culture_index') }}">
            <i class="bi bi-grid-1x2-fill"></i>
            <span>AgriGo Admin</span>
        </a>
        <nav class="admin-nav">
            <a href="{{ path('app_home') }}"><i class="bi bi-house-door"></i> Dashboard</a>
            <a href="{{ path('admin_culture_index') }}"><i class="bi bi-flower1"></i> Cultures</a>
            <a href="{{ path('admin_parcelle_index') }}"><i class="bi bi-map"></i> Parcelles</a>
            <a href="{{ path('admin_historique_culture_index') }}"><i class="bi bi-clock-history"></i> Historiques</a>
            <a href="{{ path('admin_systeme_irrigation_index') }}"><i class="bi bi-droplet-half"></i> Irrigation</a>
            <a href="{{ path('admin_historique_irrigation_index') }}"><i class="bi bi-calendar-check"></i> Hist. irrigation</a>
            {% if 'ROLE_ADMIN' in app.user.roles %}
                <a href="{{ path('app_admin_users') }}"><i class="bi bi-people"></i> Manage Users</a>
            {% endif %}
            <a href="{{ path('app_logout') }}"><i class="bi bi-box-arrow-right"></i> Logout</a>
        </nav>
    </aside>

    <div class="admin-main">
        <header class="admin-topbar">
            <div class="topbar-title">Dashboard</div>
            <span class="topbar-badge">AgriGo Symphony</span>
        </header>

        <main class="admin-content">
            <section class="admin-stats">
                <article class="stat-box">
                    <div class="stat-label">Cultures</div>
                    <div class="stat-value">Live</div>
                </article>
                <article class="stat-box alt-warn">
                    <div class="stat-label">Parcelles</div>
                    <div class="stat-value">Mapping</div>
                </article>
                <article class="stat-box alt-ok">
                    <div class="stat-label">Historiques</div>
                    <div class="stat-value">Tracking</div>
                </article>
                <article class="stat-box alt-danger">
                    <div class="stat-label">Utilisateurs</div>
                    <div class="stat-value">Gestion</div>
                </article>
            </section>

            {% for label, messages in app.flashes %}
                {% for message in messages %}
                    <div class="alert alert-{{ label == 'danger' ? 'danger' : 'success' }}" role="alert">{{ message }}</div>
                {% endfor %}
            {% endfor %}

            <section class="back-shell">
                {% block content %}{% endblock %}
            </section>
        </main>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
{% block javascripts %}{% endblock %}
</body>
</html>
