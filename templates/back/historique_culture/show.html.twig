{% extends 'back/base.html.twig' %}

{% block title %}Historique Culture - Detail{% endblock %}

{% block content %}
<h1 class="h3 mb-3">Detail historique #{{ historique.id }}</h1>

<div class="card">
    <div class="card-body">
        <dl class="row mb-0">
            <dt class="col-sm-4">Parcelle</dt>
            <dd class="col-sm-8">{{ historique.parcelle ? historique.parcelle.nomParcelle : 'Aucune' }}</dd>

            <dt class="col-sm-4">Ancienne culture</dt>
            <dd class="col-sm-8">{{ historique.ancienneCulture ?? '-' }}</dd>

            <dt class="col-sm-4">Date recolte effective</dt>
            <dd class="col-sm-8">{{ historique.dateRecolteEffective ? historique.dateRecolteEffective|date('Y-m-d') : '-' }}</dd>

            <dt class="col-sm-4">Rendement final</dt>
            <dd class="col-sm-8">{{ historique.rendementFinal is not null ? historique.rendementFinal : '-' }}</dd>
        </dl>
    </div>
</div>

<div class="mt-3">
    <a class="btn btn-secondary" href="{{ path('admin_historique_culture_index') }}">Retour liste</a>
</div>
{% endblock %}


