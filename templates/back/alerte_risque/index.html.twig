{% extends 'back/base.html.twig' %}

{% block title %}Alertes Risques - Admin{% endblock %}

{% block content %}
<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h3 m-0">Administration alertes risques</h1>
    <a href="{{ path('admin_alerte_risque_new') }}" class="btn btn-primary">Ajouter une alerte</a>
</div>

{% include '_partials/list_filter.html.twig' with {
    routeName: 'admin_alerte_risque_index',
    resetRoute: 'admin_alerte_risque_index',
    search: search,
    sort: sort,
    direction: direction,
    sortOptions: sortOptions
} %}

<div class="table-responsive">
    <table class="table table-bordered table-hover align-middle">
        <thead class="table-light">
        <tr>
            <th>ID</th>
            <th>Type</th>
            <th>Description</th>
            <th>Date</th>
            <th>Culture</th>
            <th>Actions</th>
        </tr>
        </thead>
        <tbody>
        {% for alerte in alertes %}
            <tr>
                <td>{{ alerte.id }}</td>
                <td>{{ alerte.typeAlerte ?? '-' }}</td>
                <td>{{ alerte.description ?? '-' }}</td>
                <td>{{ alerte.dateAlerte ? alerte.dateAlerte|date('Y-m-d H:i:s') : '-' }}</td>
                <td>{{ alerte.culture ? alerte.culture.nomCulture : 'Aucune' }}</td>
                <td class="d-flex gap-2">
                    <a href="{{ path('admin_alerte_risque_show', {id: alerte.id}) }}" class="btn btn-sm btn-info">Voir</a>
                    <a href="{{ path('admin_alerte_risque_edit', {id: alerte.id}) }}" class="btn btn-sm btn-warning">Modifier</a>
                    <form method="post" action="{{ path('admin_alerte_risque_delete', {id: alerte.id}) }}" onsubmit="return confirm('Confirmer la suppression ?');">
                        <input type="hidden" name="_token" value="{{ csrf_token('delete_alerte_' ~ alerte.id) }}">
                        <button class="btn btn-sm btn-danger" type="submit">Supprimer</button>
                    </form>
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="6" class="text-center text-muted">Aucune alerte enregistree.</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>
</div>
{% endblock %}


