<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" crossorigin=""/>
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" crossorigin=""></script>
<script>
    document.addEventListener('DOMContentLoaded', function() {
        const btnToggleMap = document.getElementById('btn-toggle-map');
        const btnLocateMe = document.getElementById('btn-locate-me');
        const mapContainer = document.getElementById('address-map-container');
        const addressInput = document.getElementById('adresse_user_input');
        const loader = document.getElementById('address-loader');
        
        let map = null;
        let marker = null;

        function setAddressFromLatLng(lat, lng) {
            loader.style.display = 'block';
            
            // Nominatim Reverse Geocoding
            fetch(`https://nominatim.openstreetmap.org/reverse?format=jsonv2&lat=${lat}&lon=${lng}`, {
                headers: {
                    'Accept-Language': 'fr'
                }
            })
            .then(response => response.json())
            .then(data => {
                if (data && data.address) {
                    const addr = data.address;
                    let parts = [];
                    
                    // Build a readable address
                    if (addr.house_number) parts.push(addr.house_number);
                    if (addr.road) parts.push(addr.road);
                    if (addr.suburb) parts.push(addr.suburb);
                    if (addr.city || addr.town || addr.village) parts.push(addr.city || addr.town || addr.village);
                    if (addr.postcode) parts.push(addr.postcode);
                    if (addr.state) parts.push(addr.state);
                    
                    const formatted = parts.length > 0 ? parts.join(', ') : data.display_name;
                    addressInput.value = formatted;
                    
                    // Trigger change event for any listeners
                    addressInput.dispatchEvent(new Event('change'));
                }
            })
            .catch(err => console.error('Geocoding error:', err))
            .finally(() => {
                loader.style.display = 'none';
            });
        }

        function updateMarker(lat, lng) {
            if (!marker) {
                marker = L.marker([lat, lng]).addTo(map);
            } else {
                marker.setLatLng([lat, lng]);
            }
        }

        btnToggleMap.addEventListener('click', function() {
            if (mapContainer.style.display === 'none') {
                mapContainer.style.display = 'block';
                btnLocateMe.style.display = 'inline-block';
                btnToggleMap.innerHTML = '<i class="fas fa-times"></i> Fermer';
                
                if (!map) {
                    // Tunis default
                    map = L.map('address-map').setView([36.8065, 10.1815], 11);
                    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
                        attribution: '&copy; OpenStreetMap'
                    }).addTo(map);

                    map.on('click', function(e) {
                        updateMarker(e.latlng.lat, e.latlng.lng);
                        setAddressFromLatLng(e.latlng.lat, e.latlng.lng);
                    });
                } else {
                    map.invalidateSize();
                }
            } else {
                mapContainer.style.display = 'none';
                btnLocateMe.style.display = 'none';
                btnToggleMap.innerHTML = '<i class="fas fa-map"></i> Carte';
            }
        });

        btnLocateMe.addEventListener('click', function() {
            if (navigator.geolocation) {
                btnLocateMe.disabled = true;
                btnLocateMe.innerHTML = '<i class="fas fa-spinner fa-spin"></i>...';
                
                navigator.geolocation.getCurrentPosition(function(position) {
                    const lat = position.coords.latitude;
                    const lng = position.coords.longitude;
                    
                    map.setView([lat, lng], 15);
                    updateMarker(lat, lng);
                    setAddressFromLatLng(lat, lng);
                    
                    btnLocateMe.disabled = false;
                    btnLocateMe.innerHTML = '<i class="fas fa-location-arrow"></i> Ma position';
                }, function() {
                    alert("Impossible d'obtenir votre position.");
                    btnLocateMe.disabled = false;
                    btnLocateMe.innerHTML = '<i class="fas fa-location-arrow"></i> Ma position';
                });
            }
        });
    });
</script>

<script src="https://cdn.jsdelivr.net/npm/face-api.js@0.22.2/dist/face-api.min.js"></script>
<script>
    const MODEL_URL = 'https://raw.githubusercontent.com/justadudewhohacks/face-api.js/master/weights/';
    let isModelsLoaded = false;
    let videoStream = null;
    let detectionInterval = null;
    const video = document.getElementById('reg-video');
    const canvas = document.getElementById('reg-canvas');
    const overlay = document.getElementById('camera-overlay');
    const statusEl = document.getElementById('face-status');
    const captureBtn = document.getElementById('capture-face-btn');
    const faceInput = document.getElementById('user_faceDescriptor'); // Based on Symfony field naming convention

    async function loadModels() {
        if (isModelsLoaded) return true;
        statusEl.innerText = "Chargement de l'intelligence artificielle...";
        try {
            await Promise.all([
                faceapi.nets.tinyFaceDetector.loadFromUri(MODEL_URL),
                faceapi.nets.faceLandmark68Net.loadFromUri(MODEL_URL),
                faceapi.nets.faceRecognitionNet.loadFromUri(MODEL_URL)
            ]);
            isModelsLoaded = true;
            return true;
        } catch (e) {
            statusEl.innerText = "Erreur de chargement des modèles IA.";
            return false;
        }
    }

    async function toggleCamera() {
        if (!videoStream) {
            if (!(await loadModels())) return;
            try {
                videoStream = await navigator.mediaDevices.getUserMedia({ video: {} });
                video.srcObject = videoStream;
                overlay.style.display = 'none';
                captureBtn.style.display = 'inline-block';
                statusEl.innerText = "🔍 Recherche de visage...";
                
                video.onplay = () => {
                    const displaySize = { width: video.offsetWidth, height: video.offsetHeight };
                    faceapi.matchDimensions(canvas, displaySize);
                    
                    detectionInterval = setInterval(async () => {
                        const detections = await faceapi.detectSingleFace(video, new faceapi.TinyFaceDetectorOptions()).withFaceLandmarks();
                        if (detections) {
                            const resizedDetections = faceapi.resizeResults(detections, displaySize);
                            canvas.getContext('2d').clearRect(0, 0, canvas.width, canvas.height);
                            faceapi.draw.drawDetections(canvas, resizedDetections);
                            statusEl.innerText = "✅ Visage détecté !";
                            statusEl.style.color = "var(--front-olive)";
                        } else {
                            canvas.getContext('2d').clearRect(0, 0, canvas.width, canvas.height);
                            statusEl.innerText = "🔍 Positionnez votre visage au centre";
                            statusEl.style.color = "var(--front-muted)";
                        }
                    }, 500);
                };
            } catch (e) {
                statusEl.innerText = "Accès caméra refusé ou non disponible.";
            }
        }
    }

    captureBtn.onclick = async function() {
        statusEl.innerText = "Analyse en cours...";
        const detections = await faceapi.detectSingleFace(video, new faceapi.TinyFaceDetectorOptions())
            .withFaceLandmarks()
            .withFaceDescriptor();
            
        if (!detections) {
            statusEl.innerText = "❌ Échec : Aucun visage détecté.";
            statusEl.style.color = "red";
            return;
        }

        // Store descriptor in hidden field
        faceInput.value = JSON.stringify(Array.from(detections.descriptor));
        statusEl.innerText = "✨ Signature faciale enregistrée !";
        statusEl.style.color = "var(--front-forest)";
        captureBtn.innerHTML = '<i class="fas fa-check"></i> Visage enregistré';
        captureBtn.disabled = true;
        
        // Stop camera to save resources
        if (videoStream) {
            videoStream.getTracks().forEach(track => track.stop());
            videoStream = null;
        }
        clearInterval(detectionInterval);
        video.style.opacity = '0.5';
    };

    overlay.onclick = toggleCamera;
</script>
{% endblock %}