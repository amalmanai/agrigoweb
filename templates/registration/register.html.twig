                    <div class="alert-modern">
                        <i class="fas fa-exclamation-circle" style="margin-top: 0.2rem;"></i>
                        <div>
                            <strong>Erreurs de validation</strong><br>
                            {% for error in registrationForm.vars.errors %}
                                {{ error.message }}<br>
                            {% endfor %}
                        </div>
                    </div>
                {% endif %}

