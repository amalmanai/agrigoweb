                                        {% for error in registrationForm.nomUser.vars.errors %}
                                            <i class="fas fa-times-circle"></i> {{ error.message }}
                                        {% endfor %}
                                    </div>
                                {% endif %}
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group-modern">
                                {{ form_label(registrationForm.prenomUser, 'Prénom', {'label_attr': {'class': 'd-block'}}) }}
                                <i class="fas fa-user-tag input-icon"></i>
                                {{ form_widget(registrationForm.prenomUser, {
                                    attr: {
                                        class: 'input-modern ' ~ (registrationForm.prenomUser.vars.errors | length > 0 ? 'is-invalid' : ''),
                                        placeholder: 'Votre prénom'
                                    }
                                }) }}
                                {% if registrationForm.prenomUser.vars.errors | length > 0 %}
                                    <div class="invalid-feedback-modern">
                                        {% for error in registrationForm.prenomUser.vars.errors %}
                                            <i class="fas fa-times-circle"></i> {{ error.message }}
                                        {% endfor %}
                                    </div>
                                {% endif %}
