{% extends 'front/base.html.twig' %}

{% block title %}Inscription - Agrigo{% endblock %}

{% block stylesheets %}
<style>
    /* Premium Register Styles */
    .register-container {
        display: flex;
        justify-content: center;
        align-items: center;
        min-height: 80vh;
        padding: 2rem 1rem;
        perspective: 1000px;
    }

    .register-wrapper {
        width: 100%;
        max-width: 600px;
        animation: floatIn 0.8s cubic-bezier(0.2, 0.8, 0.2, 1) forwards;
    }

    .register-card {
        background: rgba(255, 255, 255, 0.85);
        backdrop-filter: blur(16px);
        -webkit-backdrop-filter: blur(16px);
        border: 1px solid rgba(255, 255, 255, 0.6);
        border-radius: 24px;
        box-shadow: 
            0 20px 40px rgba(42, 90, 62, 0.08),
            0 1px 3px rgba(0, 0, 0, 0.05),
            inset 0 0 0 1px rgba(255, 255, 255, 0.4);
        overflow: hidden;
        transition: transform 0.3s ease, box-shadow 0.3s ease;
    }

    .register-card:hover {
        transform: translateY(-4px);
        box-shadow: 
            0 25px 50px rgba(42, 90, 62, 0.12),
            0 1px 3px rgba(0, 0, 0, 0.05),
            inset 0 0 0 1px rgba(255, 255, 255, 0.5);
    }

    .register-header {
        text-align: center;
        padding: 2.5rem 2rem 1rem;
        position: relative;
    }

    .register-logo-container {
        width: 80px;
        height: 80px;
        margin: 0 auto 1.5rem;
        background: white;
        border-radius: 20px;
        box-shadow: 0 10px 20px rgba(0,0,0,0.05);
        display: flex;
        align-items: center;
        justify-content: center;
        transform: rotate(-3deg);
        transition: transform 0.4s ease;
    }

    .register-card:hover .register-logo-container {
        transform: rotate(0deg) scale(1.05);
    }

    .register-logo-container i {
        font-size: 2.5rem;
        color: var(--front-forest);
    }

    .register-title {
        font-family: 'DM Serif Display', serif;
        font-size: 2rem;
        color: var(--front-ink);
        margin-bottom: 0.5rem;
    }

    .register-subtitle {
        color: var(--front-muted);
        font-size: 0.95rem;
    }

    .register-body {
        padding: 1rem 2.5rem 2.5rem;
    }

    .form-group-modern {
        position: relative;
        margin-bottom: 1.5rem;
    }

    .form-group-modern label {
        font-size: 0.85rem;
        font-weight: 600;
        color: var(--front-ink);
        margin-bottom: 0.5rem;
        display: block;
        transition: color 0.3s ease;
    }

    .input-modern {
        width: 100%;
        background: rgba(255, 255, 255, 0.9);
        border: 1px solid rgba(0, 0, 0, 0.08);
        border-radius: 12px;
        padding: 0.8rem 1rem 0.8rem 2.8rem;
        font-size: 1rem;
        color: var(--front-ink);
        transition: all 0.3s ease;
        box-shadow: inset 0 2px 4px rgba(0,0,0,0.02);
    }

    .input-modern.is-invalid {
        border-color: #dc3545;
        box-shadow: inset 0 2px 4px rgba(220, 53, 69, 0.1);
    }

    .input-modern:focus {
        outline: none;
        background: #ffffff;
        border-color: var(--front-leaf);
        box-shadow: 0 0 0 4px rgba(135, 169, 95, 0.15);
    }

    .input-modern.is-invalid:focus {
        border-color: #dc3545;
        box-shadow: 0 0 0 4px rgba(220, 53, 69, 0.15);
    }

    .input-icon {
        position: absolute;
        bottom: 0.85rem;
        left: 1rem;
        color: var(--front-muted);
        font-size: 1.1rem;
        transition: color 0.3s ease;
    }

    .form-group-modern:focus-within label,
    .form-group-modern:focus-within .input-icon {
        color: var(--front-olive);
    }

    .btn-register {
        width: 100%;
        background: linear-gradient(135deg, var(--front-forest) 0%, var(--front-olive) 100%);
        color: white;
        border: none;
        border-radius: 12px;
        padding: 0.9rem;
        font-size: 1.1rem;
        font-weight: 600;
        letter-spacing: 0.5px;
        margin-top: 1rem;
        cursor: pointer;
        transition: all 0.3s ease;
        box-shadow: 0 8px 16px rgba(42, 90, 62, 0.2);
        position: relative;
        overflow: hidden;
    }

    .btn-register::after {
        content: '';
        position: absolute;
        top: 0;
        left: -100%;
        width: 50%;
        height: 100%;
        background: linear-gradient(to right, rgba(255,255,255,0) 0%, rgba(255,255,255,0.2) 50%, rgba(255,255,255,0) 100%);
        transform: skewX(-20deg);
        transition: all 0.7s ease;
    }

    .btn-register:hover {
        transform: translateY(-2px);
        box-shadow: 0 12px 20px rgba(42, 90, 62, 0.3);
    }

    .btn-register:hover::after {
        left: 200%;
    }

    .register-footer {
        display: flex;
        justify-content: center;
        align-items: center;
        margin-top: 1.8rem;
        padding-top: 1.5rem;
        border-top: 1px solid rgba(0, 0, 0, 0.05);
    }

    .register-link {
        color: var(--front-olive);
        text-decoration: none;
        font-weight: 600;
        font-size: 0.9rem;
        transition: all 0.2s ease;
        position: relative;
    }

    .register-link::after {
        content: '';
        position: absolute;
        bottom: -2px;
        left: 0;
        width: 0;
        height: 1px;
        background: var(--front-forest);
        transition: width 0.3s ease;
    }

    .register-link:hover {
        color: var(--front-forest);
    }

    .register-link:hover::after {
        width: 100%;
    }

    .invalid-feedback-modern {
        color: #dc3545;
        font-size: 0.8rem;
        margin-top: 0.3rem;
        display: block;
        margin-left: 0.5rem;
    }

    .alert-modern {
        border-radius: 12px;
        border: none;
        background: #fff0f0;
        color: #d32f2f;
        padding: 1rem 1.25rem;
        margin-bottom: 1.5rem;
        display: flex;
        align-items: flex-start;
        gap: 0.75rem;
        box-shadow: 0 4px 6px rgba(211, 47, 47, 0.05);
        animation: shake 0.5s cubic-bezier(0.36, 0.07, 0.19, 0.97) both;
    }

    #address-map-container {
        position: relative;
    }

    .map-controls {
        display: flex;
        gap: 0.5rem;
        margin-top: 10px;
    }

    .btn-map-control {
        padding: 0.4rem 0.8rem;
        font-size: 0.8rem;
        border-radius: 8px;
        transition: all 0.2s ease;
    }

    .loader-address {
        display: none;
        position: absolute;
        right: 1rem;
        bottom: 0.85rem;
        color: var(--front-forest);
        animation: rotate 1s linear infinite;
        z-index: 5;
    }

    @keyframes rotate {
        from { transform: rotate(0deg); }
        to { transform: rotate(360deg); }
    }

    @keyframes floatIn {
        0% { opacity: 0; transform: translateY(30px) scale(0.95); }
        100% { opacity: 1; transform: translateY(0) scale(1); }
    }

    @keyframes shake {
        10%, 90% { transform: translateX(-1px); }
        20%, 80% { transform: translateX(2px); }
        30%, 50%, 70% { transform: translateX(-4px); }
        40%, 60% { transform: translateX(4px); }
    }
</style>
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
