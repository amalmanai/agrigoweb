{% extends 'base.html.twig' %}

{% block title %}New Sale{% endblock %}
{% block page_title %}Create New Sale{% endblock %}

{% block body %}
<div class="max-w-2xl mx-auto">
    <div class="bg-white px-6 py-8 shadow-sm ring-1 ring-gray-900/5 rounded-xl sm:px-10">
        <div class="mb-8">
            <h2 class="text-2xl font-bold leading-9 tracking-tight text-gray-900">Add Sale Details</h2>
            <p class="mt-1 text-sm leading-6 text-gray-500">Fill in the information below to record a new harvest sale. Ensure the harvest item exists first.</p>
        </div>
        
        {{ include('vente/_form.html.twig') }}

        <div class="mt-6 flex items-center justify-start gap-x-4 border-t border-gray-100 pt-6">
            <a href="{{ path('app_vente_list') }}" class="text-sm font-semibold leading-6 text-gray-600 hover:text-gray-900 flex items-center group transition-colors">
                <i class="ph ph-arrow-left mr-2 group-hover:-translate-x-1 transition-transform"></i>
                Back to list
            </a>
        </div>
    </div>
</div>
{% endblock %}
