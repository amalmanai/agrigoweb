{% extends 'front/base.html.twig' %}

{% block title %}Ventes{% endblock %}

{% block content %}
<div class="container mt-5">
    <div class="row mb-4">
        <div class="col-md-8">
            <h1>Gestion des Ventes</h1>
        </div>
        <div class="col-md-4 text-end">
            <a href="{{ path('app_vente_new') }}" class="btn btn-primary">Enregistrer une vente</a>
        </div>
    </div>

    {% if ventes is empty %}
        <div class="alert alert-info">
            Aucune vente trouvée. <a href="{{ path('app_vente_new') }}">Enregistrer une vente</a>
        </div>
    {% else %}
        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead class="table-dark">
                    <tr>
                        <th>ID</th>
                        <th>Récolte</th>
                        <th>Acheteur</th>
                        <th>Prix (TND)</th>
                        <th>Date</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    {% for vente in ventes %}
                        <tr>
                            <td>{{ vente.id }}</td>
                            <td>{{ vente.recolte.nomRecolte|default('Vente anonyme') }}</td>
                            <td>{{ vente.nomAcheteur|default('Particulier') }}</td>
                            <td>{{ vente.prixVente }}</td>
                            <td>{{ vente.dateVente|date('d/m/Y') }}</td>
                            <td>
                                <a href="{{ path('app_vente_pdf', {id: vente.id}) }}" class="btn btn-sm btn-info">Voir</a>
                                <a href="{{ path('app_vente_edit', {id: vente.id}) }}" class="btn btn-sm btn-warning">Éditer</a>
                                <form method="post" action="{{ path('app_vente_delete', {id: vente.id}) }}" class="d-inline" onsubmit="return confirm('Etes-vous sûr de vouloir supprimer cet élément ?');">
                                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ vente.id) }}">
                                    <button class="btn btn-sm btn-danger">Supprimer</button>
                                </form>
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    {% endif %}
</div>
{% endblock %}

