{% extends 'base.html.twig' %}

{% block title %}Edit Harvest{% endblock %}
{% block page_title %}Edit Harvest #{{ recolte.id }}{% endblock %}

{% block body %}
<div class="max-w-2xl mx-auto">
    <div class="bg-white px-6 py-8 shadow-sm ring-1 ring-gray-900/5 rounded-xl sm:px-10">
        <div class="mb-8 flex justify-between items-center border-b border-gray-100 pb-4">
            <div>
                <h2 class="text-2xl font-bold leading-9 tracking-tight text-gray-900">Edit Harvest</h2>
                <p class="mt-1 text-sm leading-6 text-gray-500">Update the harvest details below.</p>
            </div>
            {{ include('recolte/_delete_form.html.twig') }}
        </div>
        
        {{ include('recolte/_form.html.twig', {'button_label': 'Update Harvest'}) }}

        <div class="mt-6 flex items-center justify-start gap-x-4 border-t border-gray-100 pt-6">
            <a href="{{ path('app_recolte_index') }}" class="text-sm font-semibold leading-6 text-gray-600 hover:text-gray-900 flex items-center group transition-colors">
                <i class="ph ph-arrow-left mr-2 group-hover:-translate-x-1 transition-transform"></i>
                Back to list
            </a>
        </div>
    </div>
</div>
{% endblock %}
