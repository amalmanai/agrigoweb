{% extends 'front/base.html.twig' %}

{% block title %}Récoltes{% endblock %}

{% block content %}
<div class="container mt-5">
    <div class="row mb-4">
        <div class="col-md-8">
            <h1>Gestion des Récoltes</h1>
        </div>
        <div class="col-md-4 text-end">
            <a href="{{ path('app_recolte_new') }}" class="btn btn-primary">Ajouter une récolte</a>
        </div>
    </div>

    {% if recoltes is empty %}
        <div class="alert alert-info">
            Aucune récolte trouvée. <a href="{{ path('app_recolte_new') }}">Créer une récolte</a>
        </div>
    {% else %}
        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead class="table-dark">
                    <tr>
                        <th>ID</th>
                        <th>Produit</th>
                        <th>Quantité</th>
                        <th>Coût Production</th>
                        <th>Date récolte</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    {% for recolte in recoltes %}
                        <tr>
                            <td>{{ recolte.id }}</td>
                            <td>{{ recolte.nomRecolte }}</td>
                            <td>{{ recolte.quantite }}</td>
                            <td>{{ recolte.coutProduction }}</td>
                            <td>{{ recolte.dateRecolte|date('d/m/Y') }}</td>
                            <td>
                                <a href="{{ path('app_recolte_show', {id: recolte.id}) }}" class="btn btn-sm btn-info">Voir</a>
                                <a href="{{ path('app_recolte_edit', {id: recolte.id}) }}" class="btn btn-sm btn-warning">Éditer</a>
                                <form method="post" action="{{ path('app_recolte_delete', {id: recolte.id}) }}" class="d-inline" onsubmit="return confirm('Etes-vous sûr de vouloir supprimer cet élément ?');">
                                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ recolte.id) }}">
                                    <button class="btn btn-sm btn-danger">Supprimer</button>
                                </form>
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    {% endif %}
</div>
{% endblock %}

