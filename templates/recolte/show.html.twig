{% extends 'base.html.twig' %}

{% block title %}Harvest Details{% endblock %}
{% block page_title %}Harvest Details{% endblock %}

{% block body %}
<div class="max-w-3xl mx-auto">
    <div class="overflow-hidden bg-white shadow-sm ring-1 ring-gray-900/5 rounded-xl">
        <div class="px-4 py-6 sm:px-6 flex justify-between items-center border-b border-gray-100">
            <div>
                <h3 class="text-base font-semibold leading-7 text-gray-900">Harvest: {{ recolte.name }}</h3>
                <p class="max-w-2xl text-sm leading-6 text-gray-500">Detailed information about this crop.</p>
            </div>
            <div class="flex gap-2">
                <a href="{{ path('app_recolte_edit', {'id': recolte.id}) }}" class="inline-flex items-center rounded-md bg-indigo-50 px-3 py-2 text-sm font-semibold text-indigo-600 shadow-sm hover:bg-indigo-100 transition-colors">
                    <i class="ph ph-pencil-simple text-lg mr-1.5"></i> Edit
                </a>
                {{ include('recolte/_delete_form.html.twig') }}
            </div>
        </div>
        <div class="border-t border-gray-100">
            <dl class="divide-y divide-gray-100">
                <div class="px-4 py-6 sm:grid sm:grid-cols-3 sm:gap-4 sm:px-6 hover:bg-gray-50 transition-colors">
                    <dt class="text-sm font-medium text-gray-900 flex items-center"><i class="ph ph-calendar-blank mr-2 text-gray-400"></i>Harvest Date</dt>
                    <dd class="mt-1 text-sm leading-6 text-gray-700 sm:col-span-2 sm:mt-0">{{ recolte.harvestDate ? recolte.harvestDate|date('Y-m-d') : '' }}</dd>
                </div>
                <div class="px-4 py-6 sm:grid sm:grid-cols-3 sm:gap-4 sm:px-6 hover:bg-gray-50 transition-colors">
                    <dt class="text-sm font-medium text-gray-900 flex items-center"><i class="ph ph-scales mr-2 text-gray-400"></i>Quantity</dt>
                    <dd class="mt-1 text-sm leading-6 text-gray-700 sm:col-span-2 sm:mt-0 font-medium">{{ recolte.quantity }} {{ recolte.unit }}</dd>
                </div>
                <div class="px-4 py-6 sm:grid sm:grid-cols-3 sm:gap-4 sm:px-6 hover:bg-gray-50 transition-colors">
                    <dt class="text-sm font-medium text-gray-900 flex items-center"><i class="ph ph-text-align-left mr-2 text-gray-400"></i>Description</dt>
                    <dd class="mt-1 text-sm leading-6 text-gray-700 sm:col-span-2 sm:mt-0">{{ recolte.description ?: 'No description provided.' }}</dd>
                </div>
            </dl>
        </div>
        <div class="px-4 py-4 sm:px-6 bg-gray-50">
            <a href="{{ path('app_recolte_index') }}" class="text-sm font-semibold leading-6 text-gray-600 hover:text-gray-900 flex items-center group transition-colors">
                <i class="ph ph-arrow-left mr-2 group-hover:-translate-x-1 transition-transform"></i>
                Back to list
            </a>
        </div>
    </div>
</div>
{% endblock %}
