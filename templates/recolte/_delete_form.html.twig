<form method="post" action="{{ path('app_recolte_delete', {'id': recolte.id}) }}" onsubmit="return confirm('Are you sure you want to delete this item?');" class="inline-block">
    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ recolte.id) }}">
    <button class="inline-flex items-center rounded-md bg-red-50 px-3 py-2 text-sm font-semibold text-red-600 shadow-sm hover:bg-red-100 transition-colors">
        <i class="ph ph-trash text-lg mr-1.5"></i>
        Delete
    </button>
</form>
