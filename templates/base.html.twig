<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}AgriGo{% endblock %}</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
    {% block stylesheets %}{% endblock %}
</head>
<body>
{% block body %}
<nav class="navbar navbar-expand-lg navbar-dark bg-dark mb-4">
    <div class="container-fluid">
        <a class="navbar-brand" href="{{ path('admin_culture_index') }}">AgriGo</a>
        <div class="navbar-nav ms-auto">
            <a class="nav-link" href="{{ path('app_culture_list') }}">Front Cultures</a>
            <a class="nav-link" href="{{ path('admin_culture_index') }}">Back Cultures</a>
            <a class="nav-link" href="{{ path('admin_parcelle_index') }}">Back Parcelles</a>
            <a class="nav-link" href="{{ path('admin_historique_culture_index') }}">Historiques</a>
            <a class="nav-link" href="{{ path('admin_alerte_risque_index') }}">Alertes</a>
        </div>
    </div>
</nav>

<main class="container">
    {% for label, messages in app.flashes %}
        {% for message in messages %}
            <div class="alert alert-{{ label == 'danger' ? 'danger' : 'success' }}" role="alert">{{ message }}</div>
        {% endfor %}
    {% endfor %}

    {% block content %}{% endblock %}
</main>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
{% block javascripts %}{% endblock %}
{% endblock %}
</body>
</html>
