<!DOCTYPE html>
<html>
    <head>
        <meta charset="UTF-8">
        <title>{% block title %}Agrigo{% endblock %}</title>
        <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.2em%22 font-size=%2296%22>🌿</text></svg>">
        <meta name="viewport" content="width=device-width, initial-scale=1">
        {% block stylesheets %}
            <link rel="preconnect" href="https://fonts.googleapis.com">
            <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
            <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&family=Outfit:wght@400;600;800&display=swap" rel="stylesheet">
            <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
            <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
            <style>
                :root {
                    --agrigo-green: #28a745;
                    --agrigo-light-gray: #f8f9fa;
                    --agrigo-dark-gray: #343a40;
                }
                body {
                    background-color: #f0f2f5;
                    font-family: 'Inter', sans-serif;
                    color: var(--agrigo-dark-gray);
                    overflow-x: hidden;
                }
                h1, h2, h3, h4, .navbar-brand {
                    font-family: 'Outfit', sans-serif;
                }
                .navbar {
                    background: rgba(255, 255, 255, 0.8) !important;
                    backdrop-filter: blur(15px);
                    box-shadow: 0 4px 30px rgba(0, 0, 0, 0.05);
                    border-bottom: 2px solid rgba(40, 167, 69, 0.1);
                    position: sticky;
                    top: 0;
                    z-index: 1000;
                }
                .navbar-brand {
                    font-weight: bold;
                    color: var(--agrigo-green) !important;
                    display: flex;
                    align-items: center;
                }
                .btn-primary {
                    background-color: var(--agrigo-green);
                    border-color: var(--agrigo-green);
                }
                .btn-primary:hover {
                    background-color: #218838;
                    border-color: #1e7e34;
                }
                .card {
                    border-radius: 24px;
                    border: 1px solid rgba(255, 255, 255, 0.3);
                    background: rgba(255, 255, 255, 0.7);
                    backdrop-filter: blur(10px);
                    box-shadow: 0 8px 32px rgba(31, 38, 135, 0.07);
                    transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
                }
                .card:hover {
                    transform: translateY(-10px);
                    box-shadow: 0 15px 45px rgba(40, 167, 69, 0.15);
                }
                .glass-panel {
                    background: rgba(255, 255, 255, 0.4);
                    backdrop-filter: blur(12px);
                    border: 1px solid rgba(255, 255, 255, 0.2);
                    border-radius: 30px;
                }
                .btn {
                    border-radius: 14px;
                    padding: 12px 28px;
                    font-weight: 600;
                    transition: all 0.3s ease;
                }
                .btn-success {
                    background: linear-gradient(135deg, #28a745 0%, #1e7e34 100%);
                    border: none;
                    box-shadow: 0 4px 15px rgba(40, 167, 69, 0.2);
                }
                .btn-success:hover {
                    transform: scale(1.05);
                    box-shadow: 0 6px 20px rgba(40, 167, 69, 0.3);
                }
            </style>
        {% endblock %}
    </head>
    <body>
        <nav class="navbar navbar-expand-lg mb-4">
            <div class="container">
                <a class="navbar-brand" href="{{ path('app_home') }}">
                    <img src="{{ asset('images/logo.png') }}" alt="Agrigo Logo" height="80" class="me-2">
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="navbarNav">
                    <ul class="navbar-nav me-auto">
                        {% if is_granted('ROLE_USER') %}
                            <li class="nav-item">
                                <a class="nav-link" href="{{ path('app_home') }}">Tableau de bord</a>
                            </li>
                        {% endif %}
                        {% if is_granted('ROLE_ADMIN') %}
                            <li class="nav-item">
                                <a class="nav-link" href="{{ path('app_admin_users') }}">Gestion Utilisateurs</a>
                            </li>
                        {% endif %}
                    </ul>
                    <ul class="navbar-nav ms-auto">
                        {% if app.user %}
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle" href="#" id="navbarDropdown" role="button" data-bs-toggle="dropdown">
                                    <i class="fas fa-user-circle me-1"></i> {{ app.user.userIdentifier }}
                                </a>
                                <ul class="dropdown-menu dropdown-menu-end">
                                    <li><a class="dropdown-item" href="{{ path('app_profile') }}"><i class="fas fa-user me-1"></i> Mon Profil</a></li>
                                    <li><hr class="dropdown-divider"></li>
                                    <li><a class="dropdown-item text-danger" href="{{ path('app_logout') }}"><i class="fas fa-sign-out-alt me-1"></i> Déconnexion</a></li>
                                </ul>
                            </li>
                        {% else %}
                            <li class="nav-item">
                                <a class="nav-link" href="{{ path('app_login') }}">Connexion</a>
                            </li>
                            <li class="nav-item">
                                <a class="btn btn-outline-success ms-2" href="{{ path('app_register') }}">Inscription</a>
                            </li>
                        {% endif %}
                    </ul>
                </div>
            </div>
        </nav>

        <div class="container">
            {% for label, messages in app.flashes %}
                {% for message in messages %}
                    <div class="alert alert-{{ label == 'error' ? 'danger' : label }} alert-dismissible fade show">
                        {{ message }}
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                {% endfor %}
            {% endfor %}

            {% block body %}{% endblock %}
        </div>

        <footer class="mt-5 py-5 border-top text-center text-muted">
            <div class="container">
                <img src="{{ asset('images/logo.png') }}" alt="Agrigo Logo" height="50" class="mb-3 opacity-75">
                <p class="mb-0">&copy; {{ "now"|date("Y") }} Agrigo - La Plateforme Intelligente de Gestion Agricole Tunisienne</p>
                <div class="mt-3">
                    <a href="#" class="text-muted mx-2"><i class="fab fa-facebook"></i></a>
                    <a href="#" class="text-muted mx-2"><i class="fab fa-twitter"></i></a>
                    <a href="#" class="text-muted mx-2"><i class="fab fa-instagram"></i></a>
                </div>
            </div>
        </footer>

        {% block javascripts %}
            <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
            <script>
                // Password Toggle Helper
                document.addEventListener('DOMContentLoaded', function() {
                    document.querySelectorAll('.password-toggle').forEach(btn => {
                        btn.addEventListener('click', function() {
                            const input = this.parentElement.querySelector('input');
                            const icon = this.querySelector('i');
                            if (input.type === 'password') {
                                input.type = 'text';
                                icon.classList.replace('fa-eye', 'fa-eye-slash');
                            } else {
                                input.type = 'password';
                                icon.classList.replace('fa-eye-slash', 'fa-eye');
                            }
                        });
                    });
                });
            </script>
        {% endblock %}
    </body>
</html>
