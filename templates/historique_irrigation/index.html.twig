{% extends layout %}
{% block title %}Historique d'irrigation{% endblock %}

{% block content %}
{% set pfx = app.request.attributes.get('_route') starts with 'admin_' ? 'admin_' : 'front_' %}
<h1 class="h3 mb-4">Historique d'irrigation</h1>

<form method="get" class="row g-2 align-items-end mb-4">
    <div class="col-md-4">
        <label class="form-label small text-muted mb-0">Recherche (nom du système)</label>
        <input type="search" name="q" value="{{ search_q }}" class="form-control form-control-sm" placeholder="…">
    </div>
    <div class="col-md-3">
        <label class="form-label small text-muted mb-0">Tri</label>
        <select name="tri" class="form-select form-select-sm">
            <option value="date_desc" {{ tri_courant == 'date_desc' ? 'selected' }}>Date (récent)</option>
            <option value="date_asc" {{ tri_courant == 'date_asc' ? 'selected' }}>Date (ancien)</option>
            <option value="nom_asc" {{ tri_courant == 'nom_asc' ? 'selected' }}>Système (A→Z)</option>
            <option value="nom_desc" {{ tri_courant == 'nom_desc' ? 'selected' }}>Système (Z→A)</option>
            <option value="duree_asc" {{ tri_courant == 'duree_asc' ? 'selected' }}>Durée (croissant)</option>
            <option value="duree_desc" {{ tri_courant == 'duree_desc' ? 'selected' }}>Durée (décroissant)</option>
        </select>
    </div>
    <div class="col-md-auto">
        <button type="submit" class="btn btn-sm btn-outline-primary">Filtrer</button>
        <a href="{{ path(pfx ~ 'historique_irrigation_index') }}" class="btn btn-sm btn-outline-secondary">Réinitialiser</a>
    </div>
    <div class="col-md-auto ms-md-auto">
        <a href="{{ path(pfx ~ 'historique_irrigation_new') }}" class="btn btn-sm btn-primary">Nouvel enregistrement</a>
    </div>
</form>

<div class="table-responsive">
    <table class="table table-striped table-hover align-middle">
        <thead>
            <tr>
                <th>Date</th>
                <th>Système</th>
                <th>Durée (min)</th>
                <th>Volume</th>
                <th class="text-end">Actions</th>
            </tr>
        </thead>
        <tbody>
        {% for h in historiques %}
            <tr>
                <td>{{ h.dateIrrigation ? h.dateIrrigation|date('d/m/Y H:i') : '—' }}</td>
                <td>{{ h.systemeIrrigation ? h.systemeIrrigation.nomSysteme : '—' }}</td>
                <td>{{ h.dureeMinutes ?? '—' }}</td>
                <td>{{ h.volumeEau ?? '—' }}</td>
                <td class="text-end">
                    <a href="{{ path(pfx ~ 'historique_irrigation_show', {id: h.id}) }}" class="btn btn-sm btn-outline-primary">Voir</a>
                    <a href="{{ path(pfx ~ 'historique_irrigation_edit', {id: h.id}) }}" class="btn btn-sm btn-outline-secondary">Modifier</a>
                </td>
            </tr>
        {% else %}
            <tr><td colspan="5" class="text-muted text-center py-4">Aucun historique.</td></tr>
        {% endfor %}
        </tbody>
    </table>
</div>
{% endblock %}
