{% extends layout %}
{% block title %}Historique #{{ historique.id }}{% endblock %}

{% block content %}
{% set pfx = app.request.attributes.get('_route') starts with 'admin_' ? 'admin_' : 'front_' %}
<div class="d-flex flex-wrap justify-content-between align-items-start gap-2 mb-4">
    <h1 class="h3 mb-0">Irrigation du {{ historique.dateIrrigation ? historique.dateIrrigation|date('d/m/Y H:i') : '—' }}</h1>
    <div class="d-flex flex-wrap gap-2">
        <a href="{{ path(pfx ~ 'historique_irrigation_edit', {id: historique.id}) }}" class="btn btn-primary btn-sm">Modifier</a>
        <a href="{{ path(pfx ~ 'historique_irrigation_index') }}" class="btn btn-outline-secondary btn-sm">Liste</a>
        {{ include('historique_irrigation/_delete_form.html.twig') }}
    </div>
</div>

<dl class="row">
    <dt class="col-sm-3">Système</dt>
    <dd class="col-sm-9">{{ historique.systemeIrrigation ? historique.systemeIrrigation.nomSysteme : '—' }}</dd>
    <dt class="col-sm-3">Durée (minutes)</dt>
    <dd class="col-sm-9">{{ historique.dureeMinutes ?? '—' }}</dd>
    <dt class="col-sm-3">Volume d'eau</dt>
    <dd class="col-sm-9">{{ historique.volumeEau ?? '—' }}</dd>
    <dt class="col-sm-3">Humidité avant</dt>
    <dd class="col-sm-9">{{ historique.humiditeAvant ?? '—' }}</dd>
    <dt class="col-sm-3">Déclenchement</dt>
    <dd class="col-sm-9">{{ historique.typeDeclenchement ?? '—' }}</dd>
</dl>
{% endblock %}
