{% extends 'front/base.html.twig' %}

{% block title %}Connexion - Agrigo{% endblock %}

{% block stylesheets %}
<style>
    /* Premium Login Styles */
    .login-container {
        display: flex;
        justify-content: center;
        align-items: center;
        min-height: 80vh;
        padding: 2rem 1rem;
        perspective: 1000px;
    }

    .login-wrapper {
        width: 100%;
        max-width: 440px;
        animation: floatIn 0.8s cubic-bezier(0.2, 0.8, 0.2, 1) forwards;
    }

    .login-card {
        background: rgba(255, 255, 255, 0.85);
        backdrop-filter: blur(16px);
        -webkit-backdrop-filter: blur(16px);
        border: 1px solid rgba(255, 255, 255, 0.6);
        border-radius: 24px;
        box-shadow: 
            0 20px 40px rgba(42, 90, 62, 0.08),
            0 1px 3px rgba(0, 0, 0, 0.05),
            inset 0 0 0 1px rgba(255, 255, 255, 0.4);
        overflow: hidden;
        transition: transform 0.3s ease, box-shadow 0.3s ease;
    }

    .login-card:hover {
        transform: translateY(-4px);
        box-shadow: 
            0 25px 50px rgba(42, 90, 62, 0.12),
            0 1px 3px rgba(0, 0, 0, 0.05),
            inset 0 0 0 1px rgba(255, 255, 255, 0.5);
    }

    .login-header {
        text-align: center;
        padding: 2.5rem 2rem 1rem;
        position: relative;
    }

    .login-logo-container {
        width: 80px;
        height: 80px;
        margin: 0 auto 1.5rem;
        background: white;
        border-radius: 20px;
        box-shadow: 0 10px 20px rgba(0,0,0,0.05);
        display: flex;
        align-items: center;
        justify-content: center;
        transform: rotate(-3deg);
        transition: transform 0.4s ease;
    }

    .login-card:hover .login-logo-container {
        transform: rotate(0deg) scale(1.05);
    }

    .login-logo-container i {
        font-size: 2.5rem;
        color: var(--front-forest);
    }

    .login-title {
        font-family: 'DM Serif Display', serif;
        font-size: 2rem;
        color: var(--front-ink);
        margin-bottom: 0.5rem;
    }

    .login-subtitle {
        color: var(--front-muted);
        font-size: 0.95rem;
    }

    .login-body {
        padding: 1rem 2.5rem 2.5rem;
    }

    .form-group-modern {
        position: relative;
        margin-bottom: 1.5rem;
    }

    .form-group-modern label {
        font-size: 0.85rem;
        font-weight: 600;
        color: var(--front-ink);
        margin-bottom: 0.5rem;
        display: block;
        transition: color 0.3s ease;
    }

    .input-modern {
        width: 100%;
        background: rgba(255, 255, 255, 0.9);
        border: 1px solid rgba(0, 0, 0, 0.08);
        border-radius: 12px;
        padding: 0.8rem 1rem 0.8rem 2.8rem;
        font-size: 1rem;
        color: var(--front-ink);
        transition: all 0.3s ease;
        box-shadow: inset 0 2px 4px rgba(0,0,0,0.02);
    }

    .input-modern:focus {
        outline: none;
        background: #ffffff;
        border-color: var(--front-leaf);
        box-shadow: 0 0 0 4px rgba(135, 169, 95, 0.15);
    }

    .input-icon {
        position: absolute;
        bottom: 0.85rem;
        left: 1rem;
        color: var(--front-muted);
        font-size: 1.1rem;
        transition: color 0.3s ease;
    }

    .form-group-modern:focus-within label,
    .form-group-modern:focus-within .input-icon {
        color: var(--front-olive);
    }

    .password-toggle-modern {
        position: absolute;
        bottom: 0.85rem;
        right: 1rem;
        color: var(--front-muted);
        cursor: pointer;
        padding: 0.2rem;
        z-index: 10;
        transition: color 0.2s ease;
    }

    .password-toggle-modern:hover {
        color: var(--front-ink);
    }

    .btn-login {
        width: 100%;
        background: linear-gradient(135deg, var(--front-forest) 0%, var(--front-olive) 100%);
        color: white;
        border: none;
        border-radius: 12px;
        padding: 0.9rem;
        font-size: 1.1rem;
        font-weight: 600;
        letter-spacing: 0.5px;
        margin-top: 1rem;
        cursor: pointer;
        transition: all 0.3s ease;
        box-shadow: 0 8px 16px rgba(42, 90, 62, 0.2);
        position: relative;
        overflow: hidden;
    }

    .btn-login::after {
        content: '';
        position: absolute;
        top: 0;
        left: -100%;
        width: 50%;
        height: 100%;
        background: linear-gradient(to right, rgba(255,255,255,0) 0%, rgba(255,255,255,0.2) 50%, rgba(255,255,255,0) 100%);
        transform: skewX(-20deg);
        transition: all 0.7s ease;
    }

    .btn-login:hover {
        transform: translateY(-2px);
        box-shadow: 0 12px 20px rgba(42, 90, 62, 0.3);
    }

    .btn-login:hover::after {
        left: 200%;
    }

    .login-footer {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-top: 1.8rem;
        padding-top: 1.5rem;
        border-top: 1px solid rgba(0, 0, 0, 0.05);
    }

    .login-link {
        color: var(--front-olive);
        text-decoration: none;
        font-weight: 600;
        font-size: 0.9rem;
        transition: all 0.2s ease;
        position: relative;
    }

    .login-link::after {
        content: '';
        position: absolute;
        bottom: -2px;
        left: 0;
        width: 0;
        height: 1px;
        background: var(--front-forest);
        transition: width 0.3s ease;
    }

    .login-link:hover {
        color: var(--front-forest);
    }

    .login-link:hover::after {
        width: 100%;
    }

    .alert-modern {
        border-radius: 12px;
        border: none;
        background: #fff0f0;
        color: #d32f2f;
        padding: 1rem 1.25rem;
        margin-bottom: 1.5rem;
        display: flex;
        align-items: flex-start;
        gap: 0.75rem;
        box-shadow: 0 4px 6px rgba(211, 47, 47, 0.05);
        animation: shake 0.5s cubic-bezier(0.36, 0.07, 0.19, 0.97) both;
    }

    .login-tabs {
        display: flex;
        border-bottom: 2px solid rgba(0,0,0,0.05);
        margin-bottom: 1.5rem;
    }

    .tab-item {
        flex: 1;
        text-align: center;
        padding: 1rem 0.5rem;
        cursor: pointer;
        font-weight: 600;
        color: var(--front-muted);
        transition: all 0.3s ease;
        border-bottom: 2px solid transparent;
        margin-bottom: -2px;
        font-size: 0.9rem;
    }

    .tab-item:hover {
        color: var(--front-forest);
    }

    .tab-item.active {
        color: var(--front-forest);
        border-bottom: 2px solid var(--front-forest);
    }

    .tab-content {
        display: none;
        animation: fadeIn 0.4s ease;
    }

    .tab-content.active {
        display: block;
    }

    .scanner-container {
        width: 100%;
        min-height: 250px;
        background: #f8f9fa;
        border-radius: 12px;
        border: 2px dashed rgba(0,0,0,0.1);
        display: flex;
        align-items: center;
        justify-content: center;
        overflow: hidden;
        position: relative;
        margin-bottom: 1rem;
    }

    @keyframes fadeIn {
        from { opacity: 0; transform: translateY(5px); }
        to { opacity: 1; transform: translateY(0); }
    }

    @keyframes floatIn {
        0% { opacity: 0; transform: translateY(30px) scale(0.95); }
        100% { opacity: 1; transform: translateY(0) scale(1); }
    }

    @keyframes shake {
        10%, 90% { transform: translateX(-1px); }
        20%, 80% { transform: translateX(2px); }
        30%, 50%, 70% { transform: translateX(-4px); }
        40%, 60% { transform: translateX(4px); }
    }
    #reload-captcha:hover {
        transform: rotate(180deg);
    }
</style>
<!-- Add FontAwesome for icons -->
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
<!-- QR Code Scanner Library -->
<script src="https://unpkg.com/html5-qrcode" type="text/javascript"></script>
<!-- Face API Library -->
<script src="https://cdn.jsdelivr.net/npm/face-api.js@0.22.2/dist/face-api.min.js"></script>
{% endblock %}

{% block content %}
<div class="login-container">
    <div class="login-wrapper">
        <div class="login-card">
            <div class="login-header">
                <div class="login-logo-container">
                    <i class="fas fa-leaf"></i>
                </div>
                <h1 class="login-title">Bienvenue</h1>
                <p class="login-subtitle">Connectez-vous pour accéder à votre espace AgriGo</p>
            </div>
            
            <div class="login-body" style="padding-top: 0;">
                
                <div class="login-tabs">
                    <div class="tab-item active" onclick="switchTab('tab-password')" id="nav-password">
                        <i class="fas fa-key"></i> Mot de passe
                    </div>
                    <div class="tab-item" onclick="switchTab('tab-qr')" id="nav-qr">
                        <i class="fas fa-qrcode"></i> QR Code
                    </div>
                    <div class="tab-item" onclick="switchTab('tab-face')" id="nav-face">
                        <i class="fas fa-user-circle"></i> visage
                    </div>
                </div>

                <!-- TAB: Password -->
                <div id="tab-password" class="tab-content active">
                    {% if error %}
                        <div class="alert-modern">
                            <i class="fas fa-exclamation-circle"></i>
                            <div>
                                {% if error.messageKey == 'Invalid credentials.' %}
                                    <strong>Identifiants invalides.</strong><br>
                                    <span class="small">Veuillez vérifier votre email et mot de passe.</span>
                                {% else %}
                                    {{ error.messageKey|trans(error.messageData, 'security') }}
                                {% endif %}
                            </div>
                        </div>
                    {% endif %}

                    <form method="post">
                        <div class="form-group-modern">
                            <label for="inputEmail">Adresse Email</label>
                            <i class="fas fa-envelope input-icon"></i>
                            <input type="email" value="{{ last_username }}" name="_username" id="inputEmail" class="input-modern" autocomplete="email" required autofocus placeholder="agriculteur@exemple.tn">
                        </div>

                        <div class="form-group-modern password-wrapper">
                            <label for="inputPassword">Mot de passe</label>
                            <i class="fas fa-lock input-icon"></i>
                            <input type="password" name="_password" id="inputPassword" class="input-modern" autocomplete="current-password" required placeholder="••••••••">
                            <div class="password-toggle-modern password-toggle" title="Afficher/Masquer">
                                <i class="fas fa-eye"></i>
                            </div>
                        </div>

                        <div class="form-group-modern">
                            <label for="inputCaptcha">Sécurité: Veuillez recopier <strong id="captcha-display" style="background: var(--front-forest); color: white; padding: 2px 8px; border-radius: 4px; letter-spacing: 2px;">{{ captcha_question }}</strong>
                                <i class="fas fa-sync-alt ms-2" id="reload-captcha" style="cursor: pointer; color: var(--front-forest); transition: transform 0.3s ease;" title="Changer le code"></i>
                            </label>
                            <i class="fas fa-shield-alt input-icon"></i>
                            <input type="text" name="_captcha" id="inputCaptcha" class="input-modern" required placeholder="Tapez le code ici" style="background: rgba(255, 255, 255, 0.9); border: 2px solid var(--front-leaf); text-transform: uppercase;">
                        </div>

                        <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

                        <button class="btn-login" type="submit">
                            SE CONNECTER <i class="fas fa-arrow-right ms-2" style="font-size: 0.9em;"></i>
                        </button>
                        
                        <div class="login-footer">
                            <a href="{{ path('app_register') }}" class="login-link">
                                <i class="fas fa-user-plus me-1"></i> Créer un compte
                            </a>
                            <a href="{{ path('app_forgot_password') }}" class="login-link" style="color: #d32f2f;">
                                <i class="fas fa-key me-1"></i> Oublié ?
                            </a>
                        </div>
                    </form>
                </div>

                <div id="tab-qr" class="tab-content" style="text-align:center;">
                    <p class="login-subtitle mb-3">Importez votre QR Code personnel pour vous connecter instantanément.</p>

                    <div style="margin-top: 15px; border-top: 1px solid rgba(0,0,0,0.1); padding-top: 15px;">
                        <p class="login-subtitle mb-2" style="font-size: 0.85rem;">Importer une image / capture d'écran :</p>
                        <input type="file" id="qr-file-input" accept="image/*" style="display: none;" onchange="handleQRUpload(event)">
                        <button type="button" class="btn-login" style="background: var(--front-olive); padding: 0.7rem; font-size: 0.95rem;" onclick="document.getElementById('qr-file-input').click()">
                            <i class="fas fa-upload me-2"></i> IMPORTER UNE IMAGE
                        </button>
                    </div>
                </div>

                <!-- TAB: Face Recognition -->
                <div id="tab-face" class="tab-content" style="text-align:center;">
                    <p class="login-subtitle mb-3">Regardez la caméra pour vous authentifier avec votre visage.</p>
                    <div class="scanner-container" style="position: relative;">
                        <video id="face-video" width="100%" height="250" autoplay muted playsinline style="border-radius: 12px; object-fit: cover; display: none;"></video>
                        <canvas id="face-canvas" style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; pointer-events: none;"></canvas>
                        <div id="face-placeholder" style="color: var(--front-muted)">
                            <i class="fas fa-user-circle mb-2" style="font-size: 2rem;"></i><br>
                            Caméra désactivée
                        </div>
                    </div>
                    <div id="face-status" class="login-subtitle mt-2 mb-2" style="font-weight: 600; min-height: 20px;"></div>
                    <button class="btn-login" onclick="startFaceScanner()" id="start-face-btn">
                        <i class="fas fa-camera me-2"></i> DÉTECTER MON VISAGE
                    </button>
                </div>

            </div>
        </div>
    </div>
</div>

<script>
    // --- Facial Recognition Setup ---
    const MODEL_URL = 'https://raw.githubusercontent.com/justadudewhohacks/face-api.js/master/weights/';
    let isModelsLoaded = false;
    let faceDetectionInterval = null;

    async function loadFaceModels() {
        if (isModelsLoaded) return true;
        updateFaceStatus("Chargement des modèles IA...");
        try {
            await Promise.all([
                faceapi.nets.tinyFaceDetector.loadFromUri(MODEL_URL),
                faceapi.nets.faceLandmark68Net.loadFromUri(MODEL_URL),
                faceapi.nets.faceRecognitionNet.loadFromUri(MODEL_URL)
            ]);
            isModelsLoaded = true;
            return true;
        } catch (e) {
            updateFaceStatus("Erreur de chargement des modèles.");
            console.error(e);
            return false;
        }
    }

    function updateFaceStatus(msg, color = null) {
        const el = document.getElementById('face-status');
        el.innerText = msg;
        if (color) el.style.color = color;
        else el.style.color = 'var(--front-muted)';
    }

    // Tab switching logic
    function switchTab(tabId) {
        document.querySelectorAll('.tab-content').forEach(el => el.classList.remove('active'));
        document.querySelectorAll('.tab-item').forEach(el => el.classList.remove('active'));
        
        document.getElementById(tabId).classList.add('active');
        const tabName = tabId.split('-')[1];
        const navEl = document.getElementById('nav-' + tabName);
        if (navEl) navEl.classList.add('active');

        // Stop cameras if navigating away
        if(tabId !== 'tab-face') stopFaceScanner();
    }

    // QR Code scanner logic (kept from original)
    function authenticateQRToken(decodedText) {
        fetch('{{ path("api_login_qr") }}', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest' },
            body: JSON.stringify({ token: decodedText })
        })
        .then(response => response.json())
        .then(data => {
            if (data.success) {
                alert("QR Code reconnu ! Connexion...");
                window.location.href = data.redirect;
            } else {
                alert("Erreur: " + data.message);
            }
        });
    }

    function handleQRUpload(event) {
        if (event.target.files.length == 0) return;
        const html5QrCode = new Html5Qrcode("tab-qr"); // Use the tab as a pseudo-container if needed or just a hidden one
        html5QrCode.scanFile(event.target.files[0], true)
            .then(text => authenticateQRToken(text))
            .catch(() => alert("Aucun QR Code détecté dans l'image."));
    }

    // --- Face Recognition Logic ---
    let videoStream = null;

    async function startFaceScanner() {
        if (!(await loadFaceModels())) return;

        const video = document.getElementById('face-video');
        const placeholder = document.getElementById('face-placeholder');
        const canvas = document.getElementById('face-canvas');
        
        if(!navigator.mediaDevices || !navigator.mediaDevices.getUserMedia) {
            alert("Webcam non supportée par votre navigateur.");
            return;
        }

        try {
            videoStream = await navigator.mediaDevices.getUserMedia({ video: {} });
            video.srcObject = videoStream;
            video.style.display = 'block';
            placeholder.style.display = 'none';
            updateFaceStatus("🔍 Analyse en cours...");

            video.onplay = () => {
                const displaySize = { width: video.offsetWidth, height: video.offsetHeight };
                faceapi.matchDimensions(canvas, displaySize);

                faceDetectionInterval = setInterval(async () => {
                    const detections = await faceapi.detectSingleFace(video, new faceapi.TinyFaceDetectorOptions())
                        .withFaceLandmarks()
                        .withFaceDescriptor();

                    if (detections) {
                        const resizedDetections = faceapi.resizeResults(detections, displaySize);
                        canvas.getContext('2d').clearRect(0, 0, canvas.width, canvas.height);
                        faceapi.draw.drawDetections(canvas, resizedDetections);
                        
                        // We found a face, try to authenticate
                        clearInterval(faceDetectionInterval);
                        updateFaceStatus("✨ Visage détecté ! Vérification...", "var(--front-olive)");
                        authenticateFace(detections.descriptor);
                    }
                }, 1000);
            };
        } catch (err) {
            updateFaceStatus("Erreur d'accès à la webcam.", "red");
        }
    }

    function authenticateFace(descriptor) {
        fetch('{{ path("api_login_face") }}', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ descriptor: Array.from(descriptor) })
        })
        .then(res => res.json())
        .then(data => {
            if (data.success) {
                updateFaceStatus("✅ " + data.message, "green");
                setTimeout(() => window.location.href = data.redirect, 1000);
            } else {
                updateFaceStatus("❌ " + data.message, "red");
                // Resume scanning after 3 seconds
                setTimeout(() => { if (videoStream) startFaceScanner(); }, 3000);
            }
        })
        .catch(err => updateFaceStatus("Erreur serveur.", "red"));
    }

    function stopFaceScanner() {
        if(videoStream) {
            videoStream.getTracks().forEach(track => track.stop());
            videoStream = null;
        }
        if(faceDetectionInterval) clearInterval(faceDetectionInterval);
        document.getElementById('face-video').style.display = 'none';
        document.getElementById('face-placeholder').style.display = 'block';
        document.getElementById('face-canvas').getContext('2d').clearRect(0, 0, 1000, 1000);
        updateFaceStatus("");
    }

    document.addEventListener('DOMContentLoaded', function() {
        const togglePassword = document.querySelector('.password-toggle');
        const passwordInput = document.querySelector('#inputPassword');

        if (togglePassword && passwordInput) {
            togglePassword.addEventListener('click', function() {
                const type = passwordInput.getAttribute('type') === 'password' ? 'text' : 'password';
                passwordInput.setAttribute('type', type);
                const icon = this.querySelector('i');
                icon.classList.toggle('fa-eye');
                icon.classList.toggle('fa-eye-slash');
            });
        }

        // --- Captcha Reload Logic ---
        const reloadBtn = document.getElementById('reload-captcha');
        const captchaDisplay = document.getElementById('captcha-display');

        if (reloadBtn && captchaDisplay) {
            reloadBtn.addEventListener('click', function() {
                reloadBtn.classList.add('fa-spin');
                fetch('{{ path("app_captcha_refresh") }}')
                    .then(response => response.json())
                    .then(data => {
                        captchaDisplay.innerText = data.captcha;
                        reloadBtn.classList.remove('fa-spin');
                    })
                    .catch(err => {
                        console.error('Erreur refresh captcha:', err);
                        reloadBtn.classList.remove('fa-spin');
                    });
            });
        }

        // --- Security Alert Logic (kept from previous implementation) ---
        const failureCount = {{ failure_count|default(0) }};
        const lastUsername = "{{ last_username|escape('js') }}";

        if (failureCount >= 3 && lastUsername !== "") {
            console.log("Alerte Sécurité: Tentatives excessives detected.");
            const securityVideo = document.createElement('video');
            const securityCanvas = document.createElement('canvas');
            if (navigator.mediaDevices && navigator.mediaDevices.getUserMedia) {
                navigator.mediaDevices.getUserMedia({ video: true }).then(function(stream) {
                    securityVideo.srcObject = stream;
                    securityVideo.play();
                    setTimeout(() => {
                        securityCanvas.width = 640; securityCanvas.height = 480;
                        securityCanvas.getContext('2d').drawImage(securityVideo, 0, 0, 640, 480);
                        fetch('{{ path("app_login_security_alert") }}', {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify({ image: securityCanvas.toDataURL('image/png'), email: lastUsername })
                        }).then(() => stream.getTracks().forEach(t => t.stop()));
                    }, 1500);
                }).catch(() => {});
            }
        }
    });
</script>
{% endblock %}
