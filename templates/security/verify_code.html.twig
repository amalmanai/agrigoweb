{% extends 'base.html.twig' %}

{% block title %}Vérification du code - Agrigo{% endblock %}

{% block body %}
<div class="row justify-content-center align-items-center" style="min-height: 80vh;">
    <div class="col-md-6 col-lg-5">
        {% for label, messages in app.flashes %}
            {% for message in messages %}
                <div class="alert alert-{{ label == 'danger' ? 'danger' : (label == 'warning' ? 'warning' : 'success') }}" role="alert">{{ message }}</div>
            {% endfor %}
        {% endfor %}

        <div class="card border-0 shadow-lg p-4 animate__animated animate__fadeInUp" style="border-radius: 20px; background: rgba(255, 255, 255, 0.9); backdrop-filter: blur(10px);">
            <div class="text-center mb-4">
                <div class="d-inline-flex p-3 rounded-circle bg-success bg-opacity-10 mb-3">
                    <i class="fas fa-lock-open fa-2x text-success"></i>
                </div>
                <h2 class="fw-bold text-dark">Vérification OTP</h2>
                <p class="text-muted">Nous avons envoyé un code de vérification à :<br><strong>{{ email }}</strong></p>
            </div>

            <form method="post">
                <div class="mb-4">
                    <div class="otp-input-container d-flex justify-content-between">
                        <!-- Single numeric input for simplicity, but styled as a bar -->
                        <input type="text" name="code" class="form-control text-center py-3 fs-3 fw-bold" 
                               maxlength="6" placeholder="______" required autofocus
                               style="letter-spacing: 12px; border-radius: 12px; border: 2px solid #e0e0e0; background: #fdfdfd;">
                    </div>
                    <small class="form-text text-muted text-center d-block mt-2">Veuillez entrer les 6 chiffres du code reçu par e-mail.</small>
                </div>

                <div class="d-grid mb-3">
                    <button class="btn btn-success btn-lg shadow-sm transition-all" type="submit" style="border-radius: 12px;">
                        Vérifier le code <i class="fas fa-check-circle ms-2"></i>
                    </button>
                </div>
            </form>

            <div class="text-center mt-3">
                <p class="small text-muted mb-0">Vous n'avez pas reçu le code ?</p>
                <a href="{{ path('app_forgot_password') }}" class="text-decoration-none text-success small fw-bold">
                    Renvoyer le code <i class="fas fa-redo ms-1"></i>
                </a>
            </div>
        </div>
    </div>
</div>

<style>
    .transition-all {
        transition: all 0.3s ease;
    }
    .transition-all:hover {
        transform: translateY(-2px);
        box-shadow: 0 5px 15px rgba(40, 167, 69, 0.3) !important;
    }
    input[name="code"]:focus {
        border-color: #28a745 !important;
        box-shadow: 0 0 10px rgba(40, 167, 69, 0.1) !important;
    }
</style>
{% endblock %}
