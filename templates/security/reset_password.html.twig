{% extends 'front/base.html.twig' %}

{% block title %}Changement de mot de passe - Agrigo{% endblock %}

{% block content %}
<div class="row justify-content-center align-items-center" style="min-height: 80vh;">
    <div class="col-md-6 col-lg-5">
        <div class="card border-0 shadow-lg p-4 animate__animated animate__fadeInUp" style="border-radius: 20px; background: rgba(255, 255, 255, 0.9); backdrop-filter: blur(10px);">
            <div class="text-center mb-4">
                <div class="d-inline-flex p-3 rounded-circle bg-success bg-opacity-10 mb-3">
                    <i class="fas fa-shield-alt fa-2x text-success"></i>
                </div>
                <h2 class="fw-bold text-dark">Nouveau mot de passe</h2>
                <p class="text-muted">Presque fini ! Sécurisez maintenant votre compte avec un nouveau mot de passe fort.</p>
            </div>

            <form method="post" novalidate>
                <div class="mb-3">
                    <label class="form-label text-dark fw-semibold">Nouveau mot de passe</label>
                    <div class="input-group password-wrapper">
                        <span class="input-group-text bg-white border-end-0"><i class="fas fa-lock text-muted"></i></span>
                        <input type="password" name="password" class="form-control border-start-0 ps-0" placeholder="••••••••" required autofocus minlength="8">
                        <span class="input-group-text bg-white border-start-0 password-toggle">
                            <i class="fas fa-eye text-muted"></i>
                        </span>
                    </div>
                </div>

                <div class="mb-4">
                    <label class="form-label text-dark fw-semibold">Confirmer le mot de passe</label>
                    <div class="input-group password-wrapper">
                        <span class="input-group-text bg-white border-end-0"><i class="fas fa-lock text-muted"></i></span>
                        <input type="password" name="password_repeat" class="form-control border-start-0 ps-0" placeholder="••••••••" required minlength="8">
                        <span class="input-group-text bg-white border-start-0 password-toggle">
                            <i class="fas fa-eye text-muted"></i>
                        </span>
                    </div>
                </div>

                <button class="btn btn-success btn-lg w-100 shadow-sm transition-all mb-3" type="submit" style="border-radius: 12px;">
                    Réinitialiser & Se connecter <i class="fas fa-chevron-right ms-2"></i>
                </button>
            </form>
        </div>
    </div>
</div>

<style>
    .transition-all {
        transition: all 0.3s ease;
    }
    .transition-all:hover {
        transform: translateY(-2px);
        box-shadow: 0 5px 15px rgba(40, 167, 69, 0.3) !important;
    }
    .password-toggle { cursor: pointer; }
</style>
{% endblock %}
