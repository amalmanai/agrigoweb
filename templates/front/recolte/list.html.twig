{% extends 'front/base.html.twig' %}

{% block title %}Mes Récoltes{% endblock %}

{% block content %}
<div class="row mb-4 align-items-center">
    <div class="col-md-6">
        <h1 class="h3 mb-0 text-gray-800">Mes Récoltes</h1>
    </div>
    <div class="col-md-6 text-end">
        <a href="{{ path('app_recolte_new') }}" class="btn btn-primary shadow-sm glass-button">
            <i class="bi bi-plus text-white-50"></i> Ajouter une Récolte
        </a>
    </div>
</div>

<div class="card shadow mb-4 glass-panel border-0">
    <div class="card-header py-3 bg-transparent border-0 d-flex justify-content-between align-items-center">
        <h6 class="m-0 font-weight-bold text-primary">Historique des Récoltes</h6>
        <form class="d-none d-sm-inline-block form-inline ml-auto mr-md-3 my-2 my-md-0 mw-100 navbar-search" method="get" action="{{ path('app_recolte_list') }}">
            <div class="input-group glass-input flex-nowrap">
                <input type="text" class="form-control bg-transparent border-0 small" placeholder="Rechercher..." name="search" value="{{ search }}">
                <button class="btn btn-primary border-0" type="submit">
                    <i class="bi bi-search"></i>
                </button>
            </div>
        </form>
    </div>
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-hover glass-table" width="100%" cellspacing="0">
                <thead>
                    <tr>
                        <th>
                            <a href="{{ path('app_recolte_list', {'sort': 'name', 'direction': sort == 'name' and direction == 'ASC' ? 'DESC' : 'ASC', 'search': search}) }}" class="text-decoration-none text-dark">
                                Produit {% if sort == 'name' %}<i class="bi bi-arrow-{{ direction == 'ASC' ? 'up' : 'down' }}"></i>{% endif %}
                            </a>
                        </th>
                        <th>
                            <a href="{{ path('app_recolte_list', {'sort': 'quantity', 'direction': sort == 'quantity' and direction == 'ASC' ? 'DESC' : 'ASC', 'search': search}) }}" class="text-decoration-none text-dark">
                                Quantité {% if sort == 'quantity' %}<i class="bi bi-arrow-{{ direction == 'ASC' ? 'up' : 'down' }}"></i>{% endif %}
                            </a>
                        </th>
                        <th>
                            <a href="{{ path('app_recolte_list', {'sort': 'harvestDate', 'direction': sort == 'harvestDate' and direction == 'ASC' ? 'DESC' : 'ASC', 'search': search}) }}" class="text-decoration-none text-dark">
                                Date de récolte {% if sort == 'harvestDate' %}<i class="bi bi-arrow-{{ direction == 'ASC' ? 'up' : 'down' }}"></i>{% endif %}
                            </a>
                        </th>
                        <th>
                            <a href="{{ path('app_recolte_list', {'sort': 'productionCost', 'direction': sort == 'productionCost' and direction == 'ASC' ? 'DESC' : 'ASC', 'search': search}) }}" class="text-decoration-none text-dark">
                                Coût de production {% if sort == 'productionCost' %}<i class="bi bi-arrow-{{ direction == 'ASC' ? 'up' : 'down' }}"></i>{% endif %}
                            </a>
                        </th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    {% for recolte in recoltes %}
                    <tr>
                        <td class="font-weight-bold">{{ recolte.name }}</td>
                        <td><span class="badge bg-success glass-badge">{{ recolte.quantity }} {{ recolte.unit }}</span></td>
                        <td>{{ recolte.harvestDate|date('d/m/Y') }}</td>
                        <td class="text-primary font-weight-bold">{{ recolte.productionCost }} €</td>
                        <td>
                            <div class="btn-group gap-2">
                                <a href="{{ path('app_recolte_show', {'id': recolte.id}) }}" class="btn btn-sm btn-info text-white rounded shadow-sm" title="Voir">
                                    <i class="bi bi-eye"></i>
                                </a>
                                <a href="{{ path('app_recolte_edit', {'id': recolte.id}) }}" class="btn btn-sm btn-warning text-white rounded shadow-sm" title="Modifier">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <form method="post" action="{{ path('app_recolte_delete', {'id': recolte.id}) }}" onsubmit="return confirm('Supprimer cette récolte ?');" class="d-inline">
                                    <input type="hidden" name="_token" value="{{ csrf_token('delete_front_recolte_' ~ recolte.id) }}">
                                    <button type="submit" class="btn btn-sm btn-danger rounded shadow-sm" title="Supprimer">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                    {% else %}
                    <tr>
                        <td colspan="5" class="text-center py-4 text-muted">Aucune récolte trouvée.</td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
</div>
{% endblock %}
