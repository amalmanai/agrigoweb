{% extends 'front/base.html.twig' %}

{% block title %}Mes Récoltes{% endblock %}

{% block content %}
<style>
    .glass-card {
        background: rgba(255, 255, 255, 0.98);
        backdrop-filter: blur(10px);
        border-radius: 1.25rem;
        border: 1px solid rgba(255, 255, 255, 0.6);
        box-shadow: 0 8px 30px rgba(0, 0, 0, 0.04);
        transition: all 0.3s ease;
        overflow: hidden;
    }
    
    .glass-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 15px 35px rgba(0, 0, 0, 0.08);
    }
    
    .status-badge {
        font-size: 0.8rem;
        padding: 0.5rem 1.25rem;
        border-radius: 50rem;
        font-weight: 700;
        letter-spacing: 0.5px;
    }

    .action-btn {
        width: 36px; height: 36px;
        border-radius: 10px;
        display: inline-flex; align-items: center; justify-content: center;
        transition: all 0.2s; text-decoration: none; border: none;
    }
    .action-btn:hover { transform: translateY(-3px); }
    
    .btn-info-soft { background: #e3f2fd; color: #4e73df; }
    .btn-info-soft:hover { background: #4e73df; color: white; }
    .btn-warning-soft { background: #fff6e5; color: #f6c23e; }
    .btn-warning-soft:hover { background: #f6c23e; color: white; }
    .btn-danger-soft { background: #fdf3f4; color: #e74a3b; }
    .btn-danger-soft:hover { background: #e74a3b; color: white; }
    
    /* Search and Sort custom styling */
    .glass-input {
        background: rgba(255, 255, 255, 0.9);
        border-radius: 50rem;
        padding: 0.2rem 1rem;
        border: 1px solid rgba(255, 255, 255, 0.8);
        box-shadow: 0 4px 15px rgba(0, 0, 0, 0.05);
    }
    .glass-input input, .glass-input select {
        box-shadow: none !important;
    }
</style>

<div class="container-fluid py-4">
    <!-- Header -->
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-4 gap-3">
        <div>
            <h1 class="h2 mb-1 text-gray-800 fw-bold" style="letter-spacing: -0.5px;">Mes Récoltes</h1>
            <p class="text-muted mb-0">Découvrez et gérez votre historique de rendement agricole sous forme de grille.</p>
        </div>
        <a href="{{ path('app_recolte_new') }}" class="btn text-white rounded-pill px-4 shadow-sm fw-bold" style="background: linear-gradient(135deg, #1cc88a 0%, #13855c 100%); border: none;">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="me-2 mb-1" viewBox="0 0 16 16">
              <path fill-rule="evenodd" d="M8 2a.5.5 0 0 1 .5.5v5h5a.5.5 0 0 1 0 1h-5v5a.5.5 0 0 1-1 0v-5h-5a.5.5 0 0 1 0-1h5v-5A.5.5 0 0 1 8 2Z"/>
            </svg> Ajouter une Récolte
        </a>
    </div>

    <!-- Actions Bar: Search and Sort -->
    <div class="row mb-5">
        <div class="col-12 col-xl-10">
            <form method="get" action="{{ path('app_recolte_list') }}" class="d-flex flex-column flex-md-row gap-3">
                <!-- Search -->
                <div class="input-group glass-input flex-grow-1 border bg-white">
                    <span class="input-group-text bg-transparent border-0 text-muted"><i class="bi bi-search"></i></span>
                    <input type="text" class="form-control bg-transparent border-0" placeholder="Rechercher une récolte..." name="search" value="{{ search }}">
                </div>
                
                <div class="d-flex gap-2">
                    <!-- Sort Dropdown -->
                    <div class="d-flex align-items-center">
                        <select name="sort" class="form-select bg-white rounded-pill px-4 py-2 border shadow-sm text-muted fw-bold">
                            {% for key, label in sortOptions %}
                                <option value="{{ key }}" {% if sort == key %}selected{% endif %}>{{ label }}</option>
                            {% endfor %}
                        </select>
                    </div>
                    <!-- Direction Dropdown -->
                    <div class="d-flex align-items-center">
                        <select name="direction" class="form-select bg-white rounded-pill px-4 py-2 border shadow-sm text-muted">
                            <option value="ASC" {% if direction == 'ASC' %}selected{% endif %}>Croissant</option>
                            <option value="DESC" {% if direction == 'DESC' %}selected{% endif %}>Décroissant</option>
                        </select>
                    </div>
                    <button class="btn btn-dark rounded-pill px-4 shadow-sm" type="submit">
                        Filtrer
                    </button>
                </div>
            </form>
        </div>
    </div>

    {% if recoltes is empty %}
        <div class="glass-card text-center p-5 mt-4">
            <h4 class="text-gray-800 fw-bold">Aucune récolte trouvée</h4>
            <p class="text-muted">Commencez dès maintenant en enregistrant votre première récolte de la saison.</p>
            <a href="{{ path('app_recolte_new') }}" class="btn rounded-pill text-white px-4 mt-2 fw-bold" style="background-color: #1cc88a">Ajouter ma première récolte</a>
        </div>
    {% else %}
        <div class="row g-4">
            {% for recolte in recoltes %}
                <div class="col-12 col-md-6 col-xl-4">
                    <div class="glass-card h-100 p-4 d-flex flex-column position-relative">
                        <!-- Top Row: Quantity Badge & Date -->
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <span class="status-badge bg-success text-white shadow-sm d-flex align-items-center gap-1">
                                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" viewBox="0 0 16 16"><path fill-rule="evenodd" d="M10.5 3.5a2.5 2.5 0 0 0-5 0V4h5v-.5zm1 0V4H15v10a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V4h3.5v-.5a3.5 3.5 0 1 1 7 0zm-.646 5.354a.5.5 0 0 0-.708-.708L7.5 10.793 6.354 9.646a.5.5 0 1 0-.708.708l1.5 1.5a.5.5 0 0 0 .708 0l3-3z"/></svg>
                                {{ recolte.quantity }} {{ recolte.unit }}
                            </span>
                            <span class="text-muted small fw-bold">
                                {{ recolte.harvestDate|date('d/m/Y') }}
                            </span>
                        </div>

                        <!-- Main Info -->
                        <h4 class="fw-bold text-gray-800 mb-2 mt-1">
                            {{ recolte.name }}
                        </h4>

                        <!-- Cost Info -->
                        <div class="mt-2 mb-4 p-3 rounded-3 border bg-white shadow-sm">
                            <div class="text-muted small mb-1 text-uppercase fw-bold" style="letter-spacing: 0.5px">Coût de production</div>
                            <div>
                                <span class="fs-4 fw-bolder text-primary">{{ recolte.productionCost }}</span>
                                <span class="text-muted fw-bold">TND</span>
                            </div>
                        </div>

                        <div class="mt-auto">
                            <hr class="opacity-25 mb-4 mt-2">
                            
                            <!-- Bottom Row: 3 Actions (Voir, Modifier, Supprimer) -->
                            <div class="d-flex justify-content-end gap-2">
                                <a href="{{ path('app_recolte_show', {'id': recolte.id}) }}" class="action-btn btn-info-soft" title="Voir">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16"><path d="M10.5 8a2.5 2.5 0 1 1-5 0 2.5 2.5 0 0 1 5 0z"/><path d="M0 8s3-5.5 8-5.5S16 8 16 8s-3 5.5-8 5.5S0 8 0 8zm8 3.5a3.5 3.5 0 1 0 0-7 3.5 3.5 0 0 0 0 7z"/></svg>
                                </a>
                                <a href="{{ path('app_recolte_edit', {'id': recolte.id}) }}" class="action-btn btn-warning-soft" title="Modifier">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16"><path d="M12.146.146a.5.5 0 0 1 .708 0l3 3a.5.5 0 0 1 0 .708l-10 10a.5.5 0 0 1-.168.11l-5 2a.5.5 0 0 1-.65-.65l2-5a.5.5 0 0 1 .11-.168l10-10zM11.207 2.5 13.5 4.793 14.793 3.5 12.5 1.207 11.207 2.5zm1.586 3L10.5 3.207 4 9.707V10h.5a.5.5 0 0 1 .5.5v.5h.5a.5.5 0 0 1 .5.5v.5h.293l6.5-6.5zm-9.761 5.175-.106.106-1.528 3.821 3.821-1.528.106-.106A.5.5 0 0 1 5 12.5V12h-.5a.5.5 0 0 1-.5-.5V11h-.5a.5.5 0 0 1-.468-.325z"/></svg>
                                </a>
                                <form method="post" action="{{ path('app_recolte_delete', {'id': recolte.id}) }}" class="m-0" onsubmit="return confirm('Confirmer la suppression de cette récolte ?');">
                                    <input type="hidden" name="_token" value="{{ csrf_token('delete_front_recolte_' ~ recolte.id) }}">
                                    <button class="action-btn btn-danger-soft" title="Supprimer">
                                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16"><path d="M5.5 5.5A.5.5 0 0 1 6 6v6a.5.5 0 0 1-1 0V6a.5.5 0 0 1 .5-.5Zm2.5 0a.5.5 0 0 1 .5.5v6a.5.5 0 0 1-1 0V6a.5.5 0 0 1 .5-.5Zm3 .5a.5.5 0 0 0-1 0v6a.5.5 0 0 0 1 0V6Z"/><path d="M14.5 3a1 1 0 0 1-1 1H13v9a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V4h-.5a1 1 0 0 1-1-1V2a1 1 0 0 1 1-1H6a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1h3.5a1 1 0 0 1 1 1v1ZM4.118 4 4 4.059V13a1 1 0 0 0 1 1h6a1 1 0 0 0 1-1V4.059L11.882 4H4.118ZM2.5 3h11V2h-11v1Z"/></svg>
                                    </button>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            {% endfor %}
        </div>
    {% endif %}
</div>
{% endblock %}
