{% extends 'front/base.html.twig' %}

{% block title %}Produits{% endblock %}

{% block content %}
<div class="row mb-4 align-items-center">
    <div class="col-md-6">
        <h1 class="h3 mb-0 text-gray-800">Catalogue des Produits</h1>
    </div>
    <div class="col-md-6 text-end">
        <a href="{{ path('app_produit_new') }}" class="btn btn-primary shadow-sm glass-button">
            <i class="bi bi-plus text-white-50"></i> Ajouter un Produit
        </a>
    </div>
</div>

<div class="card shadow mb-4 glass-panel border-0">
    <div class="card-header py-3 bg-transparent border-0 d-flex justify-content-between align-items-center">
        <h6 class="m-0 font-weight-bold text-primary">Liste des Produits</h6>
        <form class="d-none d-sm-inline-block form-inline ml-auto mr-md-3 my-2 my-md-0 mw-100 navbar-search" method="get" action="{{ path('app_produit_list') }}">
            <div class="input-group glass-input flex-nowrap">
                <input type="text" class="form-control bg-transparent border-0 small" placeholder="Rechercher..." name="search" value="{{ search }}">
                <button class="btn btn-primary border-0" type="submit">
                    <i class="bi bi-search"></i>
                </button>
            </div>
        </form>
    </div>
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-hover glass-table" width="100%" cellspacing="0">
                <thead>
                    <tr>
                        <th>Nom</th>
                        <th>Catégorie</th>
                        <th>Quantité</th>
                        <th>Prix U.</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    {% for produit in produits %}
                    <tr>
                        <td class="font-weight-bold">{{ produit.nomProduit }}</td>
                        <td>{{ produit.categorie }}</td>
                        <td>
                            <span class="badge {% if produit.quantiteDisponible <= produit.seuilAlerte %}bg-danger{% else %}bg-success{% endif %} glass-badge">
                                {{ produit.quantiteDisponible }} {{ produit.unite }}
                            </span>
                        </td>
                        <td>{{ produit.prixUnitaire }} €</td>
                        <td>
                            <div class="btn-group gap-2">
                                <a href="{{ path('app_produit_show', {'id_produit': produit.idProduit}) }}" class="btn btn-sm btn-info text-white rounded shadow-sm" title="Voir">
                                    <i class="bi bi-eye"></i>
                                </a>
                                <a href="{{ path('app_produit_edit', {'id_produit': produit.idProduit}) }}" class="btn btn-sm btn-warning text-white rounded shadow-sm" title="Modifier">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <form method="post" action="{{ path('app_produit_delete', {'id_produit': produit.idProduit}) }}" onsubmit="return confirm('Supprimer ce produit ?');" class="d-inline">
                                    <input type="hidden" name="_token" value="{{ csrf_token('delete_front_produit_' ~ produit.idProduit) }}">
                                    <button type="submit" class="btn btn-sm btn-danger rounded shadow-sm" title="Supprimer">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                    {% else %}
                    <tr>
                        <td colspan="5" class="text-center py-4 text-muted">Aucun produit trouvé.</td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
</div>
{% endblock %}
