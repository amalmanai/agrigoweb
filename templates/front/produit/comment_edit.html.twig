{% extends 'front/base.html.twig' %}

{% block title %}Modifier Commentaire - Produit{% endblock %}

{% block content %}
<div class="d-sm-flex align-items-center justify-content-between mb-4">
    <h1 class="h3 mb-0 text-gray-800">Modifier Commentaire</h1>
    <a href="{{ path('app_produit_show', {'id_produit': produit.idProduit}) }}" class="d-none d-sm-inline-block btn btn-sm btn-secondary shadow-sm glass-button">
        <i class="bi bi-arrow-left text-white-50"></i> Retour
    </a>
</div>

<div class="row justify-content-center">
    <div class="col-xl-8 col-lg-9">
        <div class="card shadow mb-4 glass-panel border-0">
            <div class="card-header py-3 bg-transparent border-0">
                <h6 class="m-0 font-weight-bold text-primary">{{ produit.nomProduit }}</h6>
            </div>
            <div class="card-body">
                <div class="alert alert-info" role="alert">
                    <i class="bi bi-info-circle"></i> Modifiez votre commentaire ci-dessous.
                </div>

                {{ form_start(form) }}
                    {{ form_row(form.contenu) }}
                    
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary glass-button">
                            <i class="bi bi-check-circle"></i> Enregistrer les modifications
                        </button>
                        <a href="{{ path('app_produit_show', {'id_produit': produit.idProduit}) }}" class="btn btn-secondary glass-button">
                            <i class="bi bi-x-circle"></i> Annuler
                        </a>
                    </div>
                {{ form_end(form) }}
            </div>
        </div>
    </div>
</div>
{% endblock %}
