{% extends 'front/base.html.twig' %}

{% block title %}Détails Produit{% endblock %}

{% block content %}
<div class="d-sm-flex align-items-center justify-content-between mb-4">
    <h1 class="h3 mb-0 text-gray-800">Détails du Produit</h1>
    <a href="{{ path('app_produit_list') }}" class="d-none d-sm-inline-block btn btn-sm btn-secondary shadow-sm glass-button">
        <i class="bi bi-arrow-left text-white-50"></i> Retour
    </a>
</div>

<div class="row justify-content-center">
    <div class="col-xl-8 col-lg-9">
        <div class="card shadow mb-4 glass-panel border-0">
            <div class="card-header py-3 bg-transparent border-0 d-flex justify-content-between align-items-center">
                <h6 class="m-0 font-weight-bold text-primary">{{ produit.nomProduit }}</h6>
                <a href="{{ path('app_produit_edit', {'id_produit': produit.idProduit}) }}" class="btn btn-sm btn-warning text-white glass-button">
                    <i class="bi bi-pencil"></i> Modifier
                </a>
            </div>
            <div class="card-body">
                <table class="table glass-table">
                    <tbody>
                        <tr>
                            <th class="w-25 text-muted">ID</th>
                            <td class="font-weight-bold">{{ produit.idProduit }}</td>
                        </tr>
                        <tr>
                            <th class="text-muted">Nom</th>
                            <td>{{ produit.nomProduit }}</td>
                        </tr>
                        <tr>
                            <th class="text-muted">Catégorie</th>
                            <td>{{ produit.categorie }}</td>
                        </tr>
                        <tr>
                            <th class="text-muted">Quantité</th>
                            <td>
                                <span class="badge {% if produit.quantiteDisponible <= produit.seuilAlerte %}bg-danger{% else %}bg-success{% endif %} glass-badge">
                                    {{ produit.quantiteDisponible }} {{ produit.unite }}
                                </span>
                            </td>
                        </tr>
                        <tr>
                            <th class="text-muted">Seuil d'Alerte</th>
                            <td>{{ produit.seuilAlerte }} {{ produit.unite }}</td>
                        </tr>
                        <tr>
                            <th class="text-muted">Date d'Expiration</th>
                            <td>{{ produit.dateExpiration ? produit.dateExpiration|date('d/m/Y') : 'Non spécifiée' }}</td>
                        </tr>
                        <tr>
                            <th class="text-muted">Prix Unitaire</th>
                            <td class="text-success font-weight-bold">{{ produit.prixUnitaire }} €</td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>

        <div id="commentaires" class="card shadow mb-4 glass-panel border-0">
            <div class="card-header py-3 bg-transparent border-0">
                <h6 class="m-0 font-weight-bold text-primary">Commentaires</h6>
            </div>
            <div class="card-body">
                {% if commentForm is defined %}
                    {{ form_start(commentForm, { action: path('app_produit_comment', {'id_produit': produit.idProduit}) }) }}
                    <div class="mb-3">
                        {{ form_row(commentForm.contenu) }}
                    </div>
                    <button class="btn btn-primary">Publier le commentaire</button>
                    {{ form_end(commentForm) }}
                {% endif %}

                <hr class="my-4">

                {% for comment in comments %}
                    <div class="border rounded-4 p-3 mb-3 bg-white">
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <strong>{{ comment.user ? comment.user.prenomUser ~ ' ' ~ comment.user.nomUser : 'Utilisateur' }}</strong>
                            <small class="text-muted">{{ comment.dateCommentaire ? comment.dateCommentaire|date('d/m/Y H:i') : '-' }}</small>
                        </div>
                        <div>{{ comment.contenu }}</div>
                        {% if is_granted('ROLE_ADMIN') %}
                            <form method="post" action="{{ path('app_produit_comment_delete', {'id_produit': produit.idProduit, 'id_commentaire': comment.idCommentaire}) }}" onsubmit="return confirm('Supprimer ce commentaire ?');" class="mt-3">
                                <input type="hidden" name="_token" value="{{ csrf_token('delete_comment_' ~ comment.idCommentaire) }}">
                                <button class="btn btn-sm btn-danger" type="submit">
                                    <i class="bi bi-trash"></i> Supprimer
                                </button>
                            </form>
                        {% endif %}
                    </div>
                {% else %}
                    <div class="text-muted">Aucun commentaire pour ce produit.</div>
                {% endfor %}
            </div>
        </div>
    </div>
</div>
{% endblock %}
