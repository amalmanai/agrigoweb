<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}AgriGo{% endblock %}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=Source+Sans+3:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
    <style>
        :root {
            --front-forest: #2a5a3e;
            --front-olive: #4f6f39;
            --front-leaf: #87a95f;
            --front-cream: #f7f3e8;
            --front-ink: #1f2933;
            --front-muted: #5f6d68;
        }

        body {
            font-family: 'Source Sans 3', sans-serif;
            color: var(--front-ink);
            background:
                radial-gradient(1200px 520px at 8% -20%, #dce9d4 0%, transparent 60%),
                radial-gradient(1000px 460px at 100% -10%, #e7edd2 0%, transparent 58%),
                linear-gradient(180deg, #f9f7f0 0%, #eef3e4 100%);
            min-height: 100vh;
        }

        .front-nav {
            background: rgba(42, 90, 62, 0.92);
            backdrop-filter: blur(5px);
            border-bottom: 1px solid rgba(255, 255, 255, 0.2);
        }

        .navbar-brand {
            font-family: 'DM Serif Display', serif;
            font-size: 1.65rem;
            letter-spacing: 0.3px;
        }

        .front-nav .nav-link {
            color: rgba(255, 255, 255, 0.88);
            font-weight: 600;
        }

        .front-nav .nav-link:hover {
            color: #ffffff;
        }

        .front-avatar-link {
            display: inline-flex;
            align-items: center;
            gap: 0.45rem;
            margin-left: 0.35rem;
        }

        .front-avatar-img,
        .front-avatar-fallback {
            width: 34px;
            height: 34px;
            border-radius: 50%;
            border: 2px solid rgba(255, 255, 255, 0.6);
            object-fit: cover;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            background: rgba(255, 255, 255, 0.18);
            color: #ffffff;
            font-weight: 700;
            font-size: 0.86rem;
        }

        .front-hero {
            margin-top: 1.25rem;
            margin-bottom: 1.25rem;
            border-radius: 20px;
            overflow: hidden;
            background:
                linear-gradient(120deg, rgba(36, 72, 53, 0.95), rgba(83, 114, 62, 0.9)),
                url('https://images.unsplash.com/photo-1593113598332-cd288d649433?auto=format&fit=crop&w=1600&q=80') center/cover;
            color: #f6f8f3;
            box-shadow: 0 20px 40px rgba(36, 63, 47, 0.18);
        }

        .front-hero-inner {
            padding: clamp(1.2rem, 2.4vw, 2rem);
            display: flex;
            justify-content: space-between;
            align-items: flex-end;
            gap: 1rem;
            flex-wrap: wrap;
        }

        .front-kicker {
            font-size: 0.82rem;
            letter-spacing: 1.6px;
            text-transform: uppercase;
            opacity: 0.9;
            margin-bottom: 0.45rem;
        }

        .front-hero h1 {
            margin: 0;
            font-family: 'DM Serif Display', serif;
            font-size: clamp(1.65rem, 4vw, 2.6rem);
            line-height: 1.05;
            max-width: 16ch;
        }

        .front-badges {
            display: flex;
            gap: 0.65rem;
            flex-wrap: wrap;
        }

        .front-badge {
            background: rgba(255, 255, 255, 0.16);
            border: 1px solid rgba(255, 255, 255, 0.24);
            padding: 0.5rem 0.9rem;
            border-radius: 999px;
            font-size: 0.9rem;
            backdrop-filter: blur(4px);
        }

        .front-shell {
            background: #fffefa;
            border: 1px solid #deead6;
            border-radius: 20px;
            box-shadow: 0 18px 44px rgba(58, 74, 48, 0.11);
            padding: clamp(1rem, 2.2vw, 1.8rem);
        }

        .front-shell .table thead th {
            background-color: #2f5b40;
            color: #f4f8f2;
            border-color: #395f4a;
        }

        .front-shell .btn-primary {
            background-color: var(--front-forest);
            border-color: var(--front-forest);
        }

        .front-shell .btn-primary:hover {
            background-color: #214b33;
            border-color: #214b33;
        }

        .front-shell .btn-outline-secondary {
            border-color: #7a8d7d;
            color: #3d5448;
        }

        .front-shell .btn-outline-secondary:hover {
            background: #eff4e9;
            color: #294534;
            border-color: #607567;
        }

        @media (max-width: 768px) {
            .front-hero-inner {
                align-items: flex-start;
            }
        }
    </style>
    {% block stylesheets %}{% endblock %}
</head>
<body>
<nav class="navbar navbar-expand-lg navbar-dark front-nav sticky-top">
    <div class="container-fluid">
        <a class="navbar-brand fw-semibold" href="{{ path('app_front_home') }}">Agrigo</a>
        <div class="navbar-nav ms-auto">
            <a class="nav-link" href="{{ path('app_front_home') }}">Accueil</a>
            <a class="nav-link" href="{{ path('app_culture_list') }}">Cultures</a>
            <a class="nav-link" href="{{ path('app_parcelle_list') }}">Parcelles</a>
            <a class="nav-link" href="{{ path('app_recolte_list') }}">Recoltes</a>
            <a class="nav-link" href="{{ path('app_vente_list') }}">Ventes</a>
            <a class="nav-link" href="{{ path('app_produit_list') }}">Produits</a>
            <a class="nav-link" href="{{ path('app_mouvement_stock_list') }}">Mouvements de Stock</a>
            <a class="nav-link" href="{{ path('front_systeme_irrigation_index') }}">Irrigation</a>
            {% if app.user and 'ROLE_ADMIN' in app.user.roles %}
                <a class="nav-link" href="{{ path('app_admin_dashboard') }}">Administration</a>
            {% endif %}
            {% if app.user %}
                {% set userPhoto = app.user.photoPath %}
                {% if userPhoto %}
                    {% set userPhotoSrc = userPhoto starts with 'http' ? userPhoto : asset('uploads/profiles/' ~ userPhoto) %}
                {% endif %}
                <a class="nav-link front-avatar-link" href="{{ path('app_profile_edit') }}" title="Modifier le profil">
                    {% if userPhoto %}
                        <img src="{{ userPhotoSrc }}" alt="Profil" class="front-avatar-img">
                    {% else %}
                        <span class="front-avatar-fallback">{{ app.user.prenomUser|default('U')|slice(0, 1)|upper }}</span>
                    {% endif %}
                    <span class="d-none d-md-inline">Profil</span>
                </a>
                <a class="nav-link" href="{{ path('app_logout') }}">Logout</a>
            {% else %}
                <a class="nav-link" href="{{ path('app_login') }}">Connexion</a>
            {% endif %}
        </div>
    </div>
</nav>

<main class="container pb-4">
    <section class="front-hero">
        <div class="front-hero-inner">
            <div>
                <p class="front-kicker">Agriculture Durable</p>
                <h1>Growing smarter fields with AgriGo </h1>
            </div>
            <div class="front-badges">
                <span class="front-badge">Data-Driven Crops</span>
                <span class="front-badge">Healthy Parcels</span>
                <span class="front-badge">Risk Visibility</span>
            </div>
        </div>
    </section>

    {% for label, messages in app.flashes %}
        {% for message in messages %}
            <div class="alert alert-{{ label == 'danger' ? 'danger' : 'success' }}" role="alert">{{ message }}</div>
        {% endfor %}
    {% endfor %}

    <section class="front-shell">
        {% block content %}{% endblock %}
    </section>
</main>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
{% block javascripts %}
    {{ importmap('app') }}
{% endblock %}
</body>
</html>
