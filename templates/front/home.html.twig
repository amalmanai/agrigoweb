{% extends 'front/base.html.twig' %}

{% block title %}Bienvenue - AGRI GO{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        /* Modern Premium Aesthetics for Home */
        body {
            background-color: var(--front-cream, #f8fbf7);
        }

        .front-nav {
            background: rgba(255, 255, 255, 0.85);
            backdrop-filter: blur(16px);
            border-bottom: 1px solid rgba(0,0,0,0.05);
        }

        .front-nav .nav-link, 
        .front-nav .navbar-brand {
            color: var(--front-forest, #2a5a3e) !important;
        }

        .front-nav .nav-link:hover {
            color: var(--front-olive, #547045) !important;
        }

        .front-avatar-fallback {
            border-color: var(--front-forest, #2a5a3e) !important;
            color: var(--front-forest, #2a5a3e) !important;
        }

        .home-hero {
            position: relative;
            min-height: 85vh;
            display: flex;
            align-items: center;
            justify-content: center;
            text-align: center;
            color: #ffffff;
            background: 
                linear-gradient(135deg, rgba(42, 90, 62, 0.85) 0%, rgba(20, 71, 40, 0.9) 100%),
                url('https://images.unsplash.com/photo-1523741543316-beb7fc7023d8?auto=format&fit=crop&w=1800&q=80') center/cover fixed;
            overflow: hidden;
        }

        .home-hero::before {
            content: '';
            position: absolute;
            top: 0; left: 0; right: 0; bottom: 0;
            background: radial-gradient(circle at center, transparent 0%, rgba(0,0,0,0.3) 100%);
        }

        .hero-inner {
            position: relative;
            z-index: 2;
            width: min(1000px, 92vw);
            animation: floatUp 1s cubic-bezier(0.2, 0.8, 0.2, 1) forwards;
        }

        .hero-kicker {
            display: inline-block;
            background: rgba(255,255,255,0.2);
            backdrop-filter: blur(10px);
            padding: 0.6rem 1.8rem;
            border-radius: 30px;
            text-transform: uppercase;
            letter-spacing: 2px;
            font-size: 0.85rem;
            font-weight: 700;
            margin-bottom: 1.5rem;
            border: 1px solid rgba(255,255,255,0.3);
            box-shadow: 0 4px 15px rgba(0,0,0,0.1);
        }

        .hero-title {
            font-family: 'DM Serif Display', serif;
            font-size: clamp(2.5rem, 6vw, 4.8rem);
            line-height: 1.1;
            margin: 0;
            text-shadow: 0 10px 30px rgba(0, 0, 0, 0.3);
        }

        .hero-subtitle {
            font-size: clamp(1.1rem, 2vw, 1.3rem);
            max-width: 75ch;
            margin: 1.8rem auto 0;
            color: rgba(255, 255, 255, 0.9);
            line-height: 1.6;
        }

        .section-wrapper {
            width: min(1260px, 94vw);
            margin: 6rem auto;
            position: relative;
        }

        .section-eyebrow {
            color: var(--front-forest, #2a5a3e);
            text-transform: uppercase;
            letter-spacing: 2px;
            font-size: 0.9rem;
            font-weight: 700;
            text-align: center;
            margin-bottom: 0.5rem;
        }

        .section-title {
            font-family: 'DM Serif Display', serif;
            font-size: clamp(2rem, 4vw, 3rem);
            color: var(--front-ink, #22332a);
            text-align: center;
            margin: 0 0 3rem;
        }

        /* Glassmorphism Cards */
        .glass-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
            gap: 2.5rem;
            margin-top: 2rem;
        }

        .glass-card {
            background: rgba(255, 255, 255, 0.7);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            border: 1px solid rgba(255, 255, 255, 0.8);
            border-radius: 24px;
            padding: 3rem 2.5rem;
            box-shadow: 0 20px 40px rgba(42, 90, 62, 0.05);
            transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
            position: relative;
            overflow: hidden;
            display: flex;
            flex-direction: column;
            align-items: flex-start;
        }

        .glass-card::before {
            content: '';
            position: absolute;
            top: 0; left: 0; width: 100%; height: 5px;
            background: linear-gradient(90deg, var(--front-forest, #2a5a3e), var(--front-leaf, #87a95f));
            transform: scaleX(0);
            transform-origin: left;
            transition: transform 0.4s ease;
        }

        .glass-card:hover {
            transform: translateY(-10px);
            box-shadow: 0 30px 60px rgba(42, 90, 62, 0.12);
            background: rgba(255, 255, 255, 0.95);
        }

        .glass-card:hover::before {
            transform: scaleX(1);
        }

        .glass-card-icon {
            width: 65px;
            height: 65px;
            background: #ffffff;
            border-radius: 18px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.8rem;
            color: var(--front-olive, #547045);
            margin-bottom: 1.8rem;
            box-shadow: 0 10px 20px rgba(0,0,0,0.06);
            transition: transform 0.3s ease;
        }

        .glass-card:hover .glass-card-icon {
            transform: scale(1.1) rotate(5deg);
        }

        .glass-card h3 {
            font-family: 'DM Serif Display', serif;
            color: var(--front-ink, #22332a);
            font-size: 1.6rem;
            margin-bottom: 1rem;
            line-height: 1.2;
        }

        .glass-card p {
            color: var(--front-muted, #647668);
            line-height: 1.7;
            margin: 0;
            font-size: 1.05rem;
        }

        /* Split Section */
        .split-feature {
            margin-top: 6rem;
            display: grid;
            grid-template-columns: 1fr 1fr;
            border-radius: 36px;
            overflow: hidden;
            box-shadow: 0 40px 80px rgba(0,0,0,0.15);
        }

        .split-image {
            background: url('https://images.unsplash.com/photo-1500937386664-56d1dfef3854?auto=format&fit=crop&w=1200&q=80') center/cover;
            min-height: 600px;
        }

        .split-content {
            background: linear-gradient(135deg, var(--front-forest, #2a5a3e) 0%, var(--front-olive, #547045) 100%);
            color: white;
            padding: 5rem 4rem;
            display: flex;
            flex-direction: column;
            justify-content: center;
        }

        .split-content .section-eyebrow {
            color: rgba(255,255,255,0.7);
            text-align: left;
            margin-bottom: 1rem;
        }

        .split-content h3 {
            font-family: 'DM Serif Display', serif;
            font-size: clamp(2rem, 3.5vw, 3rem);
            margin: 0 0 1.5rem;
            line-height: 1.1;
        }
        
        .split-content p {
            font-size: 1.1rem;
            color: rgba(255,255,255,0.9);
            line-height: 1.6;
            margin-bottom: 2rem;
        }

        .split-content ul {
            list-style: none;
            padding: 0;
            margin: 0;
        }

        .split-content li {
            position: relative;
            padding-left: 3rem;
            margin-bottom: 1.5rem;
            font-size: 1.15rem;
            display: flex;
            align-items: center;
        }

        .split-content li i {
            position: absolute;
            left: 0;
            background: white;
            color: var(--front-forest, #2a5a3e);
            width: 32px;
            height: 32px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 0.9rem;
            box-shadow: 0 4px 10px rgba(0,0,0,0.2);
        }

        /* Modules Section */
        .modules-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
            gap: 1.5rem;
            margin-top: 3rem;
        }

        .module-card {
            background: #ffffff;
            border-radius: 20px;
            padding: 2rem;
            border: 1px solid rgba(0,0,0,0.06);
            transition: all 0.3s ease;
            position: relative;
            box-shadow: 0 10px 20px rgba(0,0,0,0.02);
        }
        
        .module-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 15px 30px rgba(0,0,0,0.08);
            border-color: var(--front-leaf, #87a95f);
        }

        .module-index {
            font-family: 'DM Serif Display', serif;
            font-size: 4rem;
            font-weight: 700;
            color: rgba(42, 90, 62, 0.05); /* very light transparent */
            position: absolute;
            top: 10px;
            right: 20px;
            line-height: 1;
            transition: color 0.3s ease;
        }
        
        .module-card:hover .module-index {
            color: rgba(42, 90, 62, 0.1);
        }

        .module-card h4 {
            font-family: 'DM Serif Display', serif;
            color: var(--front-ink, #22332a);
            font-size: 1.4rem;
            margin: 1rem 0 0.8rem;
            position: relative;
            z-index: 2;
        }

        .module-card p {
            color: var(--front-muted, #647668);
            line-height: 1.6;
            margin: 0;
            position: relative;
            z-index: 2;
        }

        /* Vision Panel */
        .vision-panel {
            margin-top: 5rem;
            background: linear-gradient(120deg, #ffffff 0%, #f4f7f4 100%);
            border-radius: 24px;
            padding: 4rem;
            text-align: center;
            box-shadow: 0 20px 40px rgba(0,0,0,0.04);
            border: 1px solid rgba(255,255,255,1);
        }

        .vision-panel h3 {
            font-family: 'DM Serif Display', serif;
            font-size: 2.2rem;
            color: var(--front-ink, #22332a);
            margin-bottom: 1.5rem;
        }

        .vision-panel p {
            font-size: 1.2rem;
            line-height: 1.8;
            color: var(--front-muted, #647668);
            max-width: 800px;
            margin: 0 auto;
        }

        /* Newsletter */
        .newsletter {
            margin-top: 6rem;
            background: white;
            padding: 6rem 0;
            border-top: 1px solid rgba(0,0,0,0.05);
        }

        .newsletter-inner {
            width: min(800px, 94vw);
            margin: 0 auto;
            text-align: center;
        }

        .newsletter h4 {
            font-family: 'DM Serif Display', serif;
            font-size: 2.5rem;
            color: var(--front-ink, #22332a);
            margin-bottom: 1rem;
        }

        .newsletter p {
            font-size: 1.1rem;
            color: var(--front-muted, #647668);
            margin-bottom: 2.5rem;
        }

        .newsletter-input-group {
            position: relative;
            max-width: 500px;
            margin: 0 auto;
        }

        .newsletter-input-group input {
            background: var(--front-cream, #f8fbf7);
            border: 2px solid rgba(0,0,0,0.08);
            border-radius: 50px;
            padding: 1.2rem 2rem;
            width: 100%;
            font-size: 1.1rem;
            transition: all 0.3s ease;
            text-align: center;
            color: var(--front-ink, #22332a);
        }

        .newsletter-input-group input:focus {
            outline: none;
            border-color: var(--front-forest, #2a5a3e);
            box-shadow: 0 10px 20px rgba(42, 90, 62, 0.1);
            background: white;
        }
        
        .newsletter-input-group i {
            position: absolute;
            left: 1.5rem;
            top: 50%;
            transform: translateY(-50%);
            color: var(--front-muted, #647668);
            font-size: 1.2rem;
        }

        /* Footer overrides */
        .site-footer {
            background: #111816;
            color: #d5dbd4;
            padding: 4rem 0 2rem;
        }

        .footer-inner {
            width: min(1260px, 94vw);
            margin: 0 auto;
            display: grid;
            grid-template-columns: 1.5fr repeat(4, 1fr);
            gap: 3rem;
        }

        .footer-title {
            color: #ffffff;
            font-family: 'DM Serif Display', serif;
            font-size: 1.4rem;
            margin-bottom: 1.5rem;
            letter-spacing: 0.5px;
        }

        .footer-inner ul {
            padding-left: 0;
            list-style: none;
            margin: 0;
        }

        .footer-inner li {
            margin-bottom: 0.8rem;
            color: #9ba69f;
            cursor: pointer;
            transition: color 0.2s;
        }
        
        .footer-inner li:hover {
            color: #ffffff;
        }

        .footer-bottom {
            width: min(1260px, 94vw);
            margin: 3rem auto 0;
            border-top: 1px solid rgba(255,255,255,0.1);
            padding-top: 1.5rem;
            color: #79837c;
            font-size: 0.95rem;
            text-align: center;
        }

        @keyframes floatUp {
            from { opacity: 0; transform: translateY(40px); }
            to { opacity: 1; transform: translateY(0); }
        }

        @media (max-width: 992px) {
            .split-feature { grid-template-columns: 1fr; }
            .split-image { min-height: 400px; }
            .split-content { padding: 4rem 2rem; }
            .footer-inner { grid-template-columns: 1fr 1fr; gap: 2rem; }
            .vision-panel { padding: 3rem 2rem; }
        }
        
        @media (max-width: 768px) {
            .footer-inner { grid-template-columns: 1fr; }
            .hero-title { font-size: 2.8rem; }
        }
    </style>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
{% endblock %}

{% block content %}
<section class="home-hero">
    <div class="hero-inner">
        <div class="hero-kicker">AGRI GO - Tunisia 2026</div>
        <h1 class="hero-title">Plateforme Intelligente de Gestion Agricole</h1>
        <p class="hero-subtitle">AGRI GO modernise l'agriculture en remplaçant les processus manuels par un écosystème numérique intégré. Notre mission : fournir des outils digitaux pratiques, locaux et accessibles pour l'exploitation agricole de demain.</p>
    </div>
</section>

<div class="section-wrapper">
    <p class="section-eyebrow">Les Défis Actuels</p>
    <h2 class="section-title">L'agriculture tunisienne a besoin d'une transition digitale locale</h2>
    <div class="glass-grid">
        <article class="glass-card">
            <div class="glass-card-icon"><i class="fas fa-chart-line"></i></div>
            <h3>Pertes de rendement</h3>
            <p>Les pratiques manuelles actuelles engendrent toujours des pertes majeures, dont environ 30% de perte de rendement et 40% de gaspillage d'eau dus à des décisions retardées sur le terrain.</p>
        </article>
        <article class="glass-card">
            <div class="glass-card-icon"><i class="fas fa-tractor"></i></div>
            <h3>Obstacles opérationnels</h3>
            <p>Les agriculteurs font face à une gestion morcelée, des coûts d'irrigation en hausse et des erreurs humaines récurrentes causées par les notes papier et les tableurs non connectés.</p>
        </article>
        <article class="glass-card">
            <div class="glass-card-icon"><i class="fas fa-satellite-dish"></i></div>
            <h3>Manque d'outils adaptés</h3>
            <p>Les produits disponibles sur le marché sont souvent onéreux, faibles en capacités prédictives et insuffisamment adaptés au climat et aux opérations locales tunisiennes.</p>
        </article>
    </div>

    <div class="split-feature">
        <div class="split-image" aria-hidden="true"></div>
        <div class="split-content">
            <p class="section-eyebrow">Notre Solution</p>
            <h3>Une agriculture intelligente, locale et accessible</h3>
            <p>AGRI GO est conçu pour la Tunisie de 2026 avec un objectif clair : moderniser les opérations agricoles grâce à des modules connectés qui améliorent la productivité tout en réduisant le gaspillage des ressources.</p>
            <ul>
                <li><i class="fas fa-check"></i> Impact visé : +25% de productivité et -35% d'eau</li>
                <li><i class="fas fa-check"></i> Adapté aux exploitations morcelées et contraintes locales</li>
                <li><i class="fas fa-check"></i> De la planification à la récolte dans un seul écosystème</li>
            </ul>
        </div>
    </div>

    <div class="section-wrapper" style="margin-top: 8rem;">
        <p class="section-eyebrow">Architecture de la plateforme</p>
        <h2 class="section-title">Cinq modules interconnectés</h2>
        <div class="modules-grid">
            <article class="module-card">
                <div class="module-index">01</div>
                <h4>Cultures & Parcelles</h4>
                <p>Cartographie interactive, actions liées à la météo et alertes automatisées pour les maladies ou le stress hydrique.</p>
            </article>
            <article class="module-card">
                <div class="module-index">02</div>
                <h4>Irrigation Intelligente</h4>
                <p>Pilotage automatique de l'irrigation qui s'enclenche lorsque l'humidité du sol descend en dessous de 30%.</p>
            </article>
            <article class="module-card">
                <div class="module-index">03</div>
                <h4>Stocks Prédictifs</h4>
                <p>Recommandations d'achats intelligentes pour optimiser les inventaires et réduire le gaspillage de ressources.</p>
            </article>
            <article class="module-card">
                <div class="module-index">04</div>
                <h4>Gestion de l'Équipe</h4>
                <p>Planification des tâches et pointage GPS pour les travailleurs via un flux de travail mobile dédié.</p>
            </article>
            <a href="{{ path('app_vente_list') }}" class="text-decoration-none h-100 d-block">
                <article class="module-card h-100">
                    <div class="module-index">05</div>
                    <h4>Récoltes & Ventes</h4>
                    <p>Génération automatique de documents et suivi du cycle de vie des cultures, de la récolte à la vente.</p>
                </article>
            </a>
        </div>
    </div>

    <div class="vision-panel">
        <h3>Vision du Projet</h3>
        <p>AGRI GO transforme l'agriculture d'une gestion manuelle vers un modèle opérationnel axé sur les données qui est compréhensible, abordable et adapté aux réalités tunisiennes. Construit pour répondre aux défis concrets du terrain avec un impact mesurable, et non pas juste pour digitaliser des formulaires.</p>
    </div>

    </div>
</div>

<section class="newsletter">
    <div class="newsletter-inner">
        <h4>Suivre l'Évolution d'AGRI GO</h4>
        <p>Restez connecté(e) aux mises à jour du projet, aux démonstrations des modules, aux étapes de déploiement et aux améliorations globales.</p>
        <div class="newsletter-input-group">
            <i class="fas fa-envelope"></i>
            <input type="text" value="agrigo.team@project.local" readonly aria-label="newsletter-contact">
        </div>
    </div>
</section>

<footer class="site-footer">
    <div class="footer-inner">
        <div>
            <h3 class="footer-title">AGRI GO</h3>
            <p style="color:#9ba69f; margin-bottom: 1rem; line-height: 1.6;">Plateforme de gestion agricole intelligente conçue pour l'agriculture tunisienne de demain.</p>
            <p style="color:#9ba69f;"><strong>Positionnement :</strong> Smart + Local + Accessible</p>
        </div>
        <div>
            <h4 class="footer-title">Liens Utiles</h4>
            <ul><li>Accueil</li><li>Cultures</li><li>Parcelles</li><li>Administration</li></ul>
        </div>
        <div>
            <h4 class="footer-title">Modules Principaux</h4>
            <ul><li>Cultures & Parcelles</li><li>Irrigation Intelligente</li><li>Stocks Prédictifs</li><li>Équipe</li><li>Récoltes & Ventes</li></ul>
        </div>
        <div>
            <h4 class="footer-title">Défis du Terrain</h4>
            <ul><li>Pertes de Rendement</li><li>Gaspillage d'Eau</li><li>Terres Morcelées</li><li>Erreurs Manuelles</li></ul>
        </div>
        <div>
            <h4 class="footer-title">Impact Espéré</h4>
            <ul><li>+25% de Récolte</li><li>-35% de Consommation d'Eau</li><li>Décisions Rapides</li><li>Gestion Intégrée</li></ul>
        </div>
    </div>
    <div class="footer-bottom">© 2026 AGRI GO. Construit comme une réponse numérique pratique aux défis de l'agriculture tunisienne.</div>
</footer>
{% endblock %}
