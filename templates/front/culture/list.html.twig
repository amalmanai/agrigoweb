{% extends 'front/base.html.twig' %}

{% block title %}Cultures - Front{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .front-metric-grid {
            display: grid;
            grid-template-columns: repeat(4, minmax(0, 1fr));
            gap: 0.75rem;
            margin-bottom: 1rem;
        }

        .front-metric {
            background: linear-gradient(180deg, #f9fbf5 0%, #eef5e9 100%);
            border: 1px solid #d9e8d0;
            border-radius: 14px;
            padding: 0.85rem 0.95rem;
        }

        .front-metric .label {
            font-size: 0.75rem;
            text-transform: uppercase;
            letter-spacing: 0.08em;
            color: #6a786c;
            font-weight: 700;
        }

        .front-metric .value {
            font-size: 1.25rem;
            font-weight: 800;
            color: #254636;
            line-height: 1.15;
        }

        .trend-card {
            border: 1px solid #d9e8d0;
            border-radius: 14px;
            background: #fff;
            box-shadow: 0 8px 18px rgba(56, 77, 49, 0.08);
        }

        .trend-canvas {
            height: 220px;
        }

        @media (max-width: 992px) {
            .front-metric-grid {
                grid-template-columns: 1fr 1fr;
            }
        }

        @media (max-width: 576px) {
            .front-metric-grid {
                grid-template-columns: 1fr;
            }
        }
    </style>
{% endblock %}

{% block content %}
<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h3 m-0">Cultures</h1>
    <div class="d-flex gap-2">
        <a href="{{ path('app_culture_new') }}" class="btn btn-primary">Ajouter une culture</a>
        {% if is_granted('ROLE_ADMIN') %}
            <a href="{{ path('admin_culture_index') }}" class="btn btn-outline-secondary">Vue administration</a>
        {% endif %}
    </div>
</div>

<div class="front-metric-grid">
    <div class="front-metric">
        <div class="label">Cultures</div>
        <div class="value">{{ cultureCount }}</div>
    </div>
    <div class="front-metric">
        <div class="label">Rendement moyen</div>
        <div class="value">{{ averageYield|number_format(2, '.', ' ') }}</div>
    </div>
    <div class="front-metric">
        <div class="label">Alertes rouges</div>
        <div class="value">{{ healthStatus.red }}</div>
    </div>
    <div class="front-metric">
        <div class="label">Etat global</div>
        <div class="value">{{ healthStatus.status|upper }}</div>
    </div>
</div>

<div class="card mb-3">
    <div class="card-body d-flex flex-wrap justify-content-between align-items-center gap-3">
        <div>
            <h2 class="h6 m-0">System Health Status</h2>
            <small class="text-muted">Statut global des risques automatiques</small>
        </div>
        <div class="d-flex align-items-center gap-3">
            <span class="badge text-bg-success">Green: {{ healthStatus.green }}</span>
            <span class="badge text-bg-warning">Yellow: {{ healthStatus.yellow }}</span>
            <span class="badge text-bg-danger">Red: {{ healthStatus.red }}</span>
            <span class="badge text-bg-{{ healthStatus.status == 'red' ? 'danger' : (healthStatus.status == 'yellow' ? 'warning' : 'success') }} text-uppercase">{{ healthStatus.status }}</span>
        </div>
    </div>
</div>

<div class="card mb-3 trend-card">
    <div class="card-body">
        <div class="d-flex justify-content-between align-items-center mb-2">
            <div>
                <h2 class="h6 m-0">Alert Trend (Last 7 Days)</h2>
                <small class="text-muted">Vue compacte côté front</small>
            </div>
        </div>
        <div class="trend-canvas">
            <canvas id="alertsTrendChart"></canvas>
        </div>
    </div>
</div>

{% include '_partials/list_filter.html.twig' with {
    routeName: 'app_culture_list',
    resetRoute: 'app_culture_list',
    search: search,
    sort: sort,
    direction: direction,
    sortOptions: sortOptions
} %}

<div class="table-responsive">
    <table class="table table-striped table-hover align-middle">
        <thead class="table-dark">
        <tr>
            <th>ID</th>
            <th>Image</th>
            <th>Nom</th>
            <th>Date semis</th>
            <th>Date recolte estimee</th>
            <th>Etat</th>
            <th>Rendement prevu</th>
            <th>Rendement estime</th>
            <th>Parcelle</th>
            <th>IA</th>
            <th>Meteo</th>
            <th>Action</th>
        </tr>
        </thead>
        <tbody>
        {% for culture in cultures %}
            <tr>
                {% set recommendation = recommendationsByCulture[culture.id] ?? null %}
                {% set weather = weatherByCulture[culture.id] ?? null %}
                <td>{{ culture.id }}</td>
                {% set imagePath = culture.imageName ? vich_uploader_asset(culture, 'imageFile') : '/uploads/cultures/no-image.svg' %}
                <td>
                    <img src="{{ imagePath }}" alt="culture-image" style="width:68px;height:52px;object-fit:cover;border-radius:8px;border:1px solid #dbe2d8;">
                </td>
                <td>{{ culture.nomCulture }}</td>
                <td>{{ culture.dateSemis ? culture.dateSemis|date('Y-m-d') : '-' }}</td>
                <td>{{ culture.dateRecolteEstimee ? culture.dateRecolteEstimee|date('Y-m-d') : '-' }}</td>
                <td>{{ culture.etatCroissance ?? '-' }}</td>
                <td>{{ culture.rendementPrevu is not null ? culture.rendementPrevu : '-' }}</td>
                <td>{{ culture.rendementEstime is not null ? culture.rendementEstime : '-' }}</td>
                <td>{{ culture.parcelle ? culture.parcelle.nomParcelle : 'Aucune' }}</td>
                <td>
                    {% if recommendation %}
                        <div><strong>{{ recommendation.crop }}</strong></div>
                        <small class="text-muted">Confiance {{ recommendation.confidence }}%</small>
                    {% else %}
                        <small class="text-muted">-</small>
                    {% endif %}
                </td>
                <td>
                    {% if weather %}
                        <div><strong>{{ weather.temperature }} C</strong></div>
                        <small class="text-muted">{{ weather.description }}</small>
                    {% elseif culture.parcelle and culture.parcelle.coordonneesGps %}
                        <small class="text-muted">Meteo temporairement indisponible</small>
                    {% else %}
                        <small class="text-muted">Coordonnees GPS manquantes</small>
                    {% endif %}
                </td>
                <td>
                    <a href="{{ path('app_culture_show', {id: culture.id}) }}" class="btn btn-sm btn-primary">Details</a>
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="12" class="text-center text-muted">Aucune culture disponible.</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>
</div>

<div class="mt-3 d-flex justify-content-center">
    {{ knp_pagination_render(cultures) }}
</div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.3/dist/chart.umd.min.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const canvas = document.getElementById('alertsTrendChart');
            if (!canvas || typeof Chart === 'undefined') {
                return;
            }

            const trend = {{ alertsTrend|json_encode(constant('JSON_UNESCAPED_UNICODE') b-or constant('JSON_INVALID_UTF8_SUBSTITUTE'))|raw }};

            new Chart(canvas, {
                type: 'line',
                data: {
                    labels: trend.labels || [],
                    datasets: [
                        {
                            label: 'Total alertes',
                            data: trend.totals || [],
                            borderColor: '#0d6efd',
                            backgroundColor: 'rgba(13, 110, 253, 0.12)',
                            tension: 0.25,
                            fill: true,
                        },
                        {
                            label: 'Rouges',
                            data: trend.red || [],
                            borderColor: '#dc3545',
                            backgroundColor: 'rgba(220, 53, 69, 0.1)',
                            tension: 0.25,
                            fill: false,
                        },
                        {
                            label: 'Jaunes',
                            data: trend.yellow || [],
                            borderColor: '#f59f00',
                            backgroundColor: 'rgba(245, 159, 0, 0.1)',
                            tension: 0.25,
                            fill: false,
                        }
                    ]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    animation: false,
                    plugins: {
                        legend: { position: 'bottom' }
                    },
                    scales: {
                        y: {
                            beginAtZero: true,
                            ticks: { precision: 0 }
                        }
                    }
                }
            });
        });
    </script>
{% endblock %}


