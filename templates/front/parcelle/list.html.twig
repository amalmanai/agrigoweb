{% extends 'front/base.html.twig' %}

{% block title %}Parcelles - Front{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        #parcellesTunisiaMap {
            height: 320px;
            border-radius: 14px;
            border: 1px solid #d8e1c8;
            overflow: hidden;
        }

        .front-metric-grid {
            display: grid;
            grid-template-columns: repeat(4, minmax(0, 1fr));
            gap: 0.75rem;
            margin-bottom: 1rem;
        }

        .front-metric {
            background: linear-gradient(180deg, #f9fbf5 0%, #eef5e9 100%);
            border: 1px solid #d9e8d0;
            border-radius: 14px;
            padding: 0.85rem 0.95rem;
        }

        .front-metric .label {
            font-size: 0.75rem;
            text-transform: uppercase;
            letter-spacing: 0.08em;
            color: #6a786c;
            font-weight: 700;
        }

        .front-metric .value {
            font-size: 1.25rem;
            font-weight: 800;
            color: #254636;
            line-height: 1.15;
        }

        .parcelle-card {
            border: 1px solid #dbe8d4;
            border-radius: 14px;
            padding: 0.9rem;
            background: #fff;
            box-shadow: 0 8px 18px rgba(56, 77, 49, 0.08);
            height: 100%;
        }

        .parcelle-card h3 {
            margin: 0 0 0.45rem;
            color: #274736;
            font-size: 1.08rem;
            font-weight: 700;
        }

        .parcelle-card p {
            margin: 0.15rem 0;
            color: #4f6255;
        }

        .parcelle-cards {
            display: grid;
            grid-template-columns: repeat(2, minmax(0, 1fr));
            gap: 0.9rem;
            margin-bottom: 1rem;
        }

        @media (max-width: 992px) {
            .front-metric-grid {
                grid-template-columns: 1fr 1fr;
            }

            .parcelle-cards {
                grid-template-columns: 1fr;
            }
        }

        @media (max-width: 576px) {
            .front-metric-grid {
                grid-template-columns: 1fr;
            }
        }
    </style>
{% endblock %}

{% block content %}
<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h3 m-0">Parcelles</h1>
    <div class="d-flex gap-2">
        <a href="{{ path('app_parcelle_new') }}" class="btn btn-primary">Ajouter une parcelle</a>
        <a href="{{ path('app_culture_list') }}" class="btn btn-outline-secondary">Voir les cultures</a>
    </div>
</div>

<div class="front-metric-grid">
    <div class="front-metric">
        <div class="label">Parcelles</div>
        <div class="value">{{ parcellesCount }}</div>
    </div>
    <div class="front-metric">
        <div class="label">Surface totale</div>
        <div class="value">{{ totalSurface|number_format(2, '.', ' ') }} ha</div>
    </div>
    <div class="front-metric">
        <div class="label">Points GPS</div>
        <div class="value">{{ parcellesWithGpsCount }}</div>
    </div>
    <div class="front-metric">
        <div class="label">Vue carte</div>
        <div class="value">Active</div>
    </div>
</div>

<div class="card mb-3">
    <div class="card-body">
        <div class="d-flex justify-content-between align-items-center mb-2">
            <h2 class="h6 m-0">Carte des parcelles</h2>
            <small class="text-muted">Points GPS detectes: {{ parcelleMapPoints|length }}</small>
        </div>
        <div id="parcellesTunisiaMap"></div>
    </div>
</div>

{% include '_partials/list_filter.html.twig' with {
    routeName: 'app_parcelle_list',
    resetRoute: 'app_parcelle_list',
    search: search,
    sort: sort,
    direction: direction,
    sortOptions: sortOptions
} %}

<section class="parcelle-cards">
    {% for parcelle in parcelles %}
        <article class="parcelle-card">
            {% set recommendation = recommendationsByParcelle[parcelle.id] ?? null %}
            {% set weather = weatherByParcelle[parcelle.id] ?? null %}
            <h3>{{ parcelle.nomParcelle }}</h3>
            <p><strong>Surface:</strong> {{ parcelle.surface|number_format(2, '.', ' ') }} ha</p>
            <p><strong>Type de sol:</strong> {{ parcelle.typeSol ?? 'Non defini' }}</p>
            <p><strong>Coordonnees:</strong> {{ parcelle.coordonneesGps ?? 'Non renseignees' }}</p>
            <p><strong>Cultures liees:</strong> {{ parcelle.cultures|length }}</p>

            <hr>
            <p class="mb-1"><strong>IA:</strong>
                {% if recommendation %}
                    {{ recommendation.crop }} ({{ recommendation.confidence }}%)
                {% else %}
                    -
                {% endif %}
            </p>
            <p class="mb-1"><strong>Meteo:</strong>
                {% if weather %}
                    {{ weather.temperature }} C - {{ weather.description }}
                {% elseif parcelle.coordonneesGps %}
                    Meteo temporairement indisponible
                {% else %}
                    Coordonnees GPS manquantes
                {% endif %}
            </p>
            <div class="mt-3">
                <a class="btn btn-sm btn-primary" href="{{ path('app_parcelle_show', {id: parcelle.id}) }}">Details</a>
            </div>
        </article>
    {% else %}
        <p class="text-muted">Aucune parcelle disponible.</p>
    {% endfor %}
</section>

<div class="mt-3 d-flex justify-content-center">
    {{ knp_pagination_render(parcelles) }}
</div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin="" />
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo=" crossorigin=""></script>
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const mapElement = document.getElementById('parcellesTunisiaMap');
            if (!mapElement || typeof L === 'undefined') {
                return;
            }

            const points = {{ parcelleMapPoints|json_encode(constant('JSON_UNESCAPED_UNICODE') b-or constant('JSON_INVALID_UTF8_SUBSTITUTE'))|raw }};
            const tunisiaCenter = [33.8869, 9.5375];
            const tunisiaBounds = L.latLngBounds([
                [30.2, 7.5],
                [37.8, 12.6],
            ]);

            const map = L.map(mapElement, {
                zoomControl: true,
                maxBounds: tunisiaBounds.pad(0.35),
                maxBoundsViscosity: 0.9,
            }).setView(tunisiaCenter, 6);

            L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
                maxZoom: 19,
                attribution: '&copy; OpenStreetMap contributors',
            }).addTo(map);

            const markerBounds = [];
            points.forEach((point) => {
                const marker = L.circleMarker([point.lat, point.lon], {
                    radius: 7,
                    color: '#0d6efd',
                    weight: 2,
                    fillColor: '#66a3ff',
                    fillOpacity: 0.75,
                }).addTo(map);

                marker.bindPopup(
                    '<strong>' + (point.name || 'Parcelle') + '</strong><br>' +
                    'ID: ' + (point.id ?? '-') + '<br>' +
                    'Surface: ' + (point.surface ?? '-') + ' ha<br>' +
                    'Sol: ' + (point.soil || '-') + '<br>' +
                    'GPS: ' + point.lat.toFixed(6) + ', ' + point.lon.toFixed(6)
                );

                markerBounds.push([point.lat, point.lon]);
            });

            if (markerBounds.length > 0) {
                map.fitBounds(markerBounds, { padding: [24, 24], maxZoom: 12 });
            }
        });
    </script>
{% endblock %}
