{{ form_start(form, {'attr': {'novalidate': 'novalidate'}}) }}
<div class="mb-3">
    {{ form_label(form.nomParcelle) }}
    {{ form_widget(form.nomParcelle) }}
    {{ form_errors(form.nomParcelle) }}
</div>
<div class="mb-3">
    {{ form_label(form.surface) }}
    {{ form_widget(form.surface) }}
    {{ form_errors(form.surface) }}
</div>
<div class="mb-3">
    {{ form_label(form.coordonneesGps) }}
    {{ form_widget(form.coordonneesGps, {'attr': {'data-parcelle-gps-input': 'true'}}) }}
    {{ form_errors(form.coordonneesGps) }}
    <div class="form-text">Cliquez sur la carte pour definir automatiquement les coordonnees GPS.</div>
    <div id="parcelle-map" style="height: 360px; border-radius: 14px; border: 1px solid #d8e1ef; overflow: hidden; margin-top: 0.75rem;"></div>
    <div id="parcelle-map-status" class="form-text mt-2">Aucun point selectionne.</div>
</div>
<div class="mb-3">
    {{ form_label(form.typeSol) }}
    {{ form_widget(form.typeSol) }}
    {{ form_errors(form.typeSol) }}
</div>
<div class="d-flex gap-2">
    {{ form_widget(form.submit, {label: button_label|default('Enregistrer')}) }}
    <a class="btn btn-outline-secondary" href="{{ cancel_path|default(path('app_parcelle_list')) }}">Annuler</a>
</div>
{{ form_end(form) }}
