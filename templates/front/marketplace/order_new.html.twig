{% extends 'front/base.html.twig' %}

{% block title %}Nouvelle Commande{% endblock %}

{% block content %}
<div class="row g-4">
    <div class="col-lg-7">
        <h2 class="mb-3" style="font-family:'DM Serif Display',serif;">Confirmer la commande</h2>
        <div class="card border-0 shadow-sm mb-3">
            <div class="card-body">
                <h5>{{ vente.recolte.name|default(vente.description)|default('Produit') }}</h5>
                <p class="text-muted mb-1">Vente #{{ vente.id }}</p>
                <p class="mb-1">Prix unitaire: <strong>{{ vente.price }} TND</strong></p>
                <p class="mb-0">Stock disponible: <strong>{{ available_quantity }}</strong></p>
            </div>
        </div>

        {{ form_start(form, {'attr': {'class': 'd-grid gap-3'}}) }}
            <div>
                {{ form_label(form.quantity) }}
                {{ form_widget(form.quantity, {'attr': {'class': 'form-control'}}) }}
                {{ form_errors(form.quantity) }}
            </div>
            <div>
                {{ form_label(form.deliveryAddress) }}
                {{ form_widget(form.deliveryAddress, {'attr': {'class': 'form-control'}}) }}
                {{ form_errors(form.deliveryAddress) }}
            </div>
            <div>
                {{ form_label(form.note) }}
                {{ form_widget(form.note, {'attr': {'class': 'form-control'}}) }}
                {{ form_errors(form.note) }}
            </div>
            <div class="d-flex gap-2">
                <a href="{{ path('app_marketplace_index') }}" class="btn btn-outline-secondary">Retour</a>
                <button class="btn btn-primary" type="submit">Valider ma commande</button>
            </div>
        {{ form_end(form) }}
    </div>

    <div class="col-lg-5">
        <div class="card border-0 shadow-sm bg-light h-100">
            <div class="card-body">
                <h6 class="mb-2">Pickup Location</h6>
                {% if vente.recolte and vente.recolte.parcelle %}
                    {% set pickup = vente.recolte.parcelle.nomParcelle %}
                    {% if vente.recolte.parcelle.coordonneesGps %}
                        {% set pickup = pickup ~ ' (' ~ vente.recolte.parcelle.coordonneesGps ~ ')' %}
                    {% endif %}
                {% else %}
                    {% set pickup = vente.recolte ? vente.recolte.adresse : null %}
                {% endif %}
                <p class="text-muted">{{ pickup|default('Non renseignee') }}</p>

                <h6 class="mb-2">Informations vendeur</h6>
                <p class="text-muted mb-0">
                    ID vendeur: #{{ vente.recolte.userId|default('N/A') }}
                </p>
            </div>
        </div>
    </div>
</div>
{% endblock %}
