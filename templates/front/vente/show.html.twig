{% extends 'front/base.html.twig' %}

{% block title %}Détails de la Vente{% endblock %}

{% block content %}
<div class="d-sm-flex align-items-center justify-content-between mb-4">
    <h1 class="h3 mb-0 text-gray-800">Détails de la Vente</h1>
    <a href="{{ path('app_vente_list') }}" class="d-none d-sm-inline-block btn btn-sm btn-secondary shadow-sm glass-button">
        <i class="bi bi-arrow-left text-white-50"></i> Retour
    </a>
</div>

<div class="row justify-content-center">
    <div class="col-xl-8 col-lg-9">
        <div class="card shadow mb-4 glass-panel border-0">
            <div class="card-header py-3 bg-transparent border-0 d-flex justify-content-between align-items-center">
                <h6 class="m-0 font-weight-bold text-primary">Vente #{{ vente.id }}</h6>
                {% if is_owner %}
                    <a href="{{ path('app_vente_edit', {'id': vente.id}) }}" class="btn btn-sm btn-warning text-white glass-button">
                        <i class="bi bi-pencil"></i> Modifier
                    </a>
                {% endif %}
            </div>
            <div class="card-body">
                <table class="table glass-table">
                    <tbody>
                        <tr>
                            <th class="w-25 text-muted">Acheteur</th>
                            <td class="font-weight-bold">{{ vente.buyerName }}</td>
                        </tr>
                        <tr>
                            <th class="text-muted">Description</th>
                            <td>{{ vente.description }}</td>
                        </tr>
                        <tr>
                            <th class="text-muted">Récolte Concernée</th>
                            <td>
                                {% if vente.recolte %}
                                    <span class="badge bg-info glass-badge text-dark">{{ vente.recolte.name }}</span> (ID: {{ vente.recolte.id }})
                                {% else %}
                                    <span class="text-muted">Aucune récolte liée</span>
                                {% endif %}
                            </td>
                        </tr>
                        <tr>
                            <th class="text-muted">Valeur estimée</th>
                            <td>
                                {% if vente.recolte and vente.recolte.productionCost is not null %}
                                    <span class="text-success font-weight-bold h4">{{ vente.recolte.productionCost }} €</span>
                                {% else %}
                                    <span class="text-muted">Non disponible</span>
                                {% endif %}
                            </td>
                        </tr>
                        <tr>
                            <th class="text-muted">Pickup Location</th>
                            <td>{{ pickup_location_label }}</td>
                        </tr>
                        <tr>
                            <th class="text-muted">Adresse de livraison</th>
                            <td>{{ vente.buyerName ? 'Via acheteur: ' ~ vente.buyerName : 'À convenir avec l\'acheteur' }}</td>
                        </tr>
                        <tr>
                            <th class="text-muted">Statut</th>
                            <td>
                                <span class="badge 
                                    {% if vente.status == 'terminee' or vente.status == 'terminée' %}bg-success
                                    {% elseif vente.status == 'en attente' %}bg-warning text-dark
                                    {% else %}bg-secondary{% endif %} glass-badge">
                                    {{ vente.status }}
                                </span>
                            </td>
                        </tr>

                    </tbody>
                </table>

                <div class="row g-3 mt-2">
                    <div class="col-md-6">
                        <div class="p-3 rounded-3 border" style="background:#f1fff7;border-color:#caecd9 !important;">
                            <div class="fw-bold text-success mb-1"><i class="bi bi-geo-alt-fill"></i> Pickup</div>
                            <div class="small text-muted">{{ pickup_location_label }}</div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="p-3 rounded-3 border" style="background:#fff8f0;border-color:#ffe1c4 !important;">
                            <div class="fw-bold" style="color:#d26d08;"><i class="bi bi-truck"></i> Delivery</div>
                            <div class="small text-muted">{{ delivery_location_label|default('Adresse de livraison non renseignee') }}</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Map Section: direct inline Leaflet, no async fetch needed -->
        <div class="card shadow mb-4 glass-panel border-0">
            <div class="card-header py-3 bg-transparent border-0">
                <h6 class="m-0 font-weight-bold text-primary"><i class="bi bi-map"></i> Localisation</h6>
            </div>
            <div class="card-body">
                <div class="mb-3 p-3 rounded-3 border d-flex justify-content-between" style="background:#f8faf8;border-color:#dfeadb !important;">
                    <div>
                        <div class="fw-bold text-success"><i class="bi bi-geo-alt-fill"></i> Pickup</div>
                        <div class="small text-muted">{{ pickup_location_label }}</div>
                    </div>
                    <div class="text-end">
                        <div class="fw-bold" style="color:#d26d08;"><i class="bi bi-truck"></i> Delivery</div>
                        <div class="small text-muted">Région de Sousse, Tunisie</div>
                    </div>
                </div>
                <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
                <div id="vente-show-map" style="height:400px;border-radius:8px;overflow:hidden;"></div>
                <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
                <script>
                document.addEventListener('DOMContentLoaded', function () {
                    var map = L.map('vente-show-map').setView([36.1, 9.5], 6);
                    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
                        attribution: '© OpenStreetMap contributors', maxZoom: 19
                    }).addTo(map);

                    var pickupLatLng = [36.8065, 10.1815];
                    var deliveryLatLng = [35.8256, 10.637];

                    var greenIcon = L.icon({
                        iconUrl: 'https://raw.githubusercontent.com/pointhi/leaflet-color-markers/master/img/marker-icon-2x-green.png',
                        shadowUrl: 'https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.9.4/images/marker-shadow.png',
                        iconSize:[25,41], iconAnchor:[12,41], popupAnchor:[1,-34], shadowSize:[41,41]
                    });
                    var redIcon = L.icon({
                        iconUrl: 'https://raw.githubusercontent.com/pointhi/leaflet-color-markers/master/img/marker-icon-2x-red.png',
                        shadowUrl: 'https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.9.4/images/marker-shadow.png',
                        iconSize:[25,41], iconAnchor:[12,41], popupAnchor:[1,-34], shadowSize:[41,41]
                    });

                    L.marker(pickupLatLng, {icon: greenIcon})
                        .bindPopup('<strong>🚜 Pickup</strong><br>{{ pickup_location_label|e('js') }}')
                        .addTo(map).openPopup();

                    L.marker(deliveryLatLng, {icon: redIcon})
                        .bindPopup('<strong>📦 Delivery</strong><br>Région de Sousse, Tunisie')
                        .addTo(map);

                    L.polyline([pickupLatLng, deliveryLatLng], {
                        color: '#FF6B6B', weight: 3, opacity: 0.7, dashArray: '8,6'
                    }).addTo(map);

                    map.fitBounds([pickupLatLng, deliveryLatLng], {padding: [40, 40]});
                    setTimeout(function(){ map.invalidateSize(); }, 200);
                });
                </script>
                <div class="mt-3 small text-muted d-flex gap-4">
                    <span><i class="bi bi-geo-alt-fill text-success"></i> <strong>Vert:</strong> Pickup (récolte)</span>
                    <span><i class="bi bi-geo-alt-fill text-danger"></i> <strong>Rouge:</strong> Livraison</span>
                    <span>© OpenStreetMap</span>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
