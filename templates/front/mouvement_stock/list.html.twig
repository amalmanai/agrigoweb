{% extends 'front/base.html.twig' %}

{% block title %}Mouvements de Stock{% endblock %}

{% block content %}
<div class="row mb-4 align-items-center">
    <div class="col-md-6">
        <h1 class="h3 mb-0 text-gray-800">Mes Mouvements de Stock</h1>
    </div>
    <div class="col-md-6 text-end">
        <a href="{{ path('app_mouvement_stock_new') }}" class="btn btn-primary shadow-sm glass-button">
            <i class="bi bi-plus text-white-50"></i> Ajouter un Mouvement
        </a>
    </div>
</div>

<div class="card shadow mb-4 glass-panel border-0">
    <div class="card-header py-3 bg-transparent border-0 d-flex justify-content-between align-items-center">
        <h6 class="m-0 font-weight-bold text-primary">Historique</h6>
        <form class="d-none d-sm-inline-block form-inline ml-auto mr-md-3 my-2 my-md-0 mw-100 navbar-search" method="get" action="{{ path('app_mouvement_stock_list') }}">
            <div class="input-group glass-input flex-nowrap">
                <input type="text" class="form-control bg-transparent border-0 small" placeholder="Rechercher..." name="search" value="{{ search }}">
                <button class="btn btn-primary border-0" type="submit">
                    <i class="bi bi-search"></i>
                </button>
            </div>
        </form>
    </div>
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-hover glass-table" width="100%" cellspacing="0">
                <thead>
                    <tr>
                        <th>Date</th>
                        <th>Type</th>
                        <th>Produit ID</th>
                        <th>Quantité</th>
                        <th>Motif</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    {% for mouvement in mouvements %}
                    <tr>
                        <td>{{ mouvement.dateMouvement ? mouvement.dateMouvement|date('Y-m-d') : '' }}</td>
                        <td>
                            <span class="badge {% if mouvement.typeMouvement == 'Entrée' %}bg-success{% else %}bg-warning{% endif %} glass-badge text-white">
                                {{ mouvement.typeMouvement }}
                            </span>
                        </td>
                        <td>
                            <div class="d-flex flex-column">
                                <span class="fw-bold">{{ mouvement.produit.nomProduit ?? 'Produit inconnu' }}</span>
                                <small class="text-muted">#{{ mouvement.idProduit }}</small>
                            </div>
                        </td>
                        <td class="text-primary fw-bold">{{ mouvement.quantite }}</td>
                        <td>{{ mouvement.motif }}</td>
                        <td>
                            <div class="btn-group gap-2">
                                <a href="{{ path('app_mouvement_stock_show', {'id_mouvement': mouvement.idMouvement}) }}" class="btn btn-sm btn-info text-white rounded shadow-sm" title="Voir">
                                    <i class="bi bi-eye"></i>
                                </a>
                                <a href="{{ path('app_mouvement_stock_edit', {'id_mouvement': mouvement.idMouvement}) }}" class="btn btn-sm btn-warning text-white rounded shadow-sm" title="Modifier">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <form method="post" action="{{ path('app_mouvement_stock_delete', {'id_mouvement': mouvement.idMouvement}) }}" onsubmit="return confirm('Supprimer ce mouvement ?');" class="d-inline">
                                    <input type="hidden" name="_token" value="{{ csrf_token('delete_front_mouvement_stock_' ~ mouvement.idMouvement) }}">
                                    <button type="submit" class="btn btn-sm btn-danger rounded shadow-sm" title="Supprimer">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                    {% else %}
                    <tr>
                        <td colspan="6" class="text-center py-4 text-muted">Aucun mouvement trouvé.</td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
</div>
{% endblock %}
