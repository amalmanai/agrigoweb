{% extends 'front/base.html.twig' %}

{% block title %}Détails Mouvement{% endblock %}

{% block content %}
<div class="d-sm-flex align-items-center justify-content-between mb-4">
    <h1 class="h3 mb-0 text-gray-800">Détails du Mouvement</h1>
    <a href="{{ path('app_mouvement_stock_list') }}" class="d-none d-sm-inline-block btn btn-sm btn-secondary shadow-sm glass-button">
        <i class="bi bi-arrow-left text-white-50"></i> Retour
    </a>
</div>

<div class="row justify-content-center">
    <div class="col-xl-8 col-lg-9">
        <div class="card shadow mb-4 glass-panel border-0">
            <div class="card-header py-3 bg-transparent border-0 d-flex justify-content-between align-items-center">
                <h6 class="m-0 font-weight-bold text-primary">Mouvement #{{ mouvement_stock.idMouvement }}</h6>
                <a href="{{ path('app_mouvement_stock_edit', {'id_mouvement': mouvement_stock.idMouvement}) }}" class="btn btn-sm btn-warning text-white glass-button">
                    <i class="bi bi-pencil"></i> Modifier
                </a>
            </div>
            <div class="card-body">
                <table class="table glass-table">
                    <tbody>
                        <tr>
                            <th class="w-25 text-muted">ID</th>
                            <td class="font-weight-bold">{{ mouvement_stock.idMouvement }}</td>
                        </tr>
                        <tr>
                            <th class="text-muted">Date</th>
                            <td>{{ mouvement_stock.dateMouvement }}</td>
                        </tr>
                        <tr>
                            <th class="text-muted">Type</th>
                            <td>
                                <span class="badge {% if mouvement_stock.typeMouvement == 'Entrée' %}bg-success{% else %}bg-warning{% endif %} glass-badge text-white">
                                    {{ mouvement_stock.typeMouvement }}
                                </span>
                            </td>
                        </tr>
                        <tr>
                            <th class="text-muted">ID Produit</th>
                            <td class="font-weight-bold">#{{ mouvement_stock.idProduit }}</td>
                        </tr>
                        <tr>
                            <th class="text-muted">Quantité</th>
                            <td class="text-primary font-weight-bold">{{ mouvement_stock.quantite }}</td>
                        </tr>
                        <tr>
                            <th class="text-muted">Motif</th>
                            <td>{{ mouvement_stock.motif }}</td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
{% endblock %}
