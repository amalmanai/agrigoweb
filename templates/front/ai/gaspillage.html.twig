{% extends 'front/base.html.twig' %}

{% block title %}Gaspillage IA - AgriGo{% endblock %}

{% block content %}
<div class="d-flex justify-content-between align-items-center flex-wrap gap-3 mb-4">
    <div>
        <p class="section-eyebrow text-start mb-1">Intelligence artificielle</p>
        <h1 class="h3 m-0">Détection de gaspillage</h1>
    </div>
    <a href="{{ path('app_front_home') }}" class="btn btn-outline-secondary">Retour à l'accueil</a>
</div>

<div class="row g-3 mb-4">
    <div class="col-md-4">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body">
                <div class="text-muted small text-uppercase fw-semibold">Fenêtre d'analyse</div>
                <div class="display-6 fw-bold">{{ analysis.windowMonths }} mois</div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body">
                <div class="text-muted small text-uppercase fw-semibold">Anomalies détectées</div>
                <div class="display-6 fw-bold text-danger">{{ analysis.anomaliesCount }}</div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body">
                <div class="text-muted small text-uppercase fw-semibold">Lecture</div>
                <div class="fw-semibold">Compare la dernière consommation à la moyenne + 2 écarts types.</div>
            </div>
        </div>
    </div>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body table-responsive">
        <table class="table align-middle mb-0">
            <thead>
            <tr>
                <th>Produit</th>
                <th>Dernier mois</th>
                <th>Moyenne</th>
                <th>Seuil</th>
                <th>Résultat</th>
            </tr>
            </thead>
            <tbody>
            {% for row in analysis.analyses %}
                <tr>
                    <td>{{ row.produit.nom }}</td>
                    <td>{{ row.consommationDernierMois }}</td>
                    <td>{{ row.moyenne }}</td>
                    <td>{{ row.seuil }}</td>
                    <td>
                        {% if row.anomalie %}
                            <span class="badge bg-danger">Anomalie</span>
                        {% else %}
                            <span class="badge bg-success">Normal</span>
                        {% endif %}
                    </td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="5" class="text-center text-muted py-4">Aucune donnée disponible.</td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
    </div>
</div>
{% endblock %}
