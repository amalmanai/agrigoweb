{% extends 'front/base.html.twig' %}

{% block title %}Modifier le Profil - AgriGo{% endblock %}

{% block stylesheets %}
<style>
    .profile-container {
        display: flex;
        justify-content: center;
        align-items: center;
        min-height: 70vh;
        padding: 2rem 1rem;
        perspective: 1000px;
    }

    .profile-wrapper {
        width: 100%;
        max-width: 800px;
        animation: floatIn 0.8s cubic-bezier(0.2, 0.8, 0.2, 1) forwards;
    }

    .profile-card {
        background: rgba(255, 255, 255, 0.85);
        backdrop-filter: blur(16px);
        -webkit-backdrop-filter: blur(16px);
        border: 1px solid rgba(255, 255, 255, 0.6);
        border-radius: 24px;
        box-shadow: 
            0 20px 40px rgba(42, 90, 62, 0.08),
            0 1px 3px rgba(0, 0, 0, 0.05),
            inset 0 0 0 1px rgba(255, 255, 255, 0.4);
        overflow: hidden;
        transition: transform 0.3s ease, box-shadow 0.3s ease;
    }

    .profile-card:hover {
        transform: translateY(-4px);
        box-shadow: 
            0 25px 50px rgba(42, 90, 62, 0.12),
            0 1px 3px rgba(0, 0, 0, 0.05),
            inset 0 0 0 1px rgba(255, 255, 255, 0.5);
    }

    .profile-header {
        text-align: center;
        padding: 2.5rem 2rem 1.5rem;
        position: relative;
        border-bottom: 1px solid rgba(0, 0, 0, 0.05);
    }

    .profile-logo-container {
        width: 70px;
        height: 70px;
        margin: 0 auto 1rem;
        background: white;
        border-radius: 20px;
        box-shadow: 0 10px 20px rgba(0,0,0,0.05);
        display: flex;
        align-items: center;
        justify-content: center;
        transform: rotate(-3deg);
        transition: transform 0.4s ease;
    }

    .profile-card:hover .profile-logo-container {
        transform: rotate(0deg) scale(1.05);
    }

    .profile-logo-container i {
        font-size: 2rem;
        color: var(--front-forest);
    }

    .profile-title {
        font-family: 'DM Serif Display', serif;
        font-size: 1.8rem;
        color: var(--front-ink);
        margin-bottom: 0.25rem;
    }

    .profile-subtitle {
        color: var(--front-muted);
        font-size: 0.95rem;
    }

    .profile-body {
        padding: 2rem 3rem 3rem;
    }

    .form-group-modern {
        position: relative;
        margin-bottom: 1.5rem;
    }

    .form-group-modern label {
        font-size: 0.85rem;
        font-weight: 600;
        color: var(--front-ink);
        margin-bottom: 0.5rem;
        display: block;
        transition: color 0.3s ease;
    }

    .input-modern {
        width: 100%;
        background: rgba(255, 255, 255, 0.9);
        border: 1px solid rgba(0, 0, 0, 0.08);
        border-radius: 12px;
        padding: 0.8rem 1rem;
        font-size: 1rem;
        color: var(--front-ink);
        transition: all 0.3s ease;
        box-shadow: inset 0 2px 4px rgba(0,0,0,0.02);
    }

    .input-modern:focus {
        outline: none;
        background: #ffffff;
        border-color: var(--front-leaf);
        box-shadow: 0 0 0 4px rgba(135, 169, 95, 0.15);
    }

    .input-modern.is-invalid {
        border-color: #dc3545;
        box-shadow: 0 0 0 4px rgba(220, 53, 69, 0.15);
    }

    .form-group-modern:focus-within label {
        color: var(--front-olive);
    }

    .btn-save {
        background: linear-gradient(135deg, var(--front-forest) 0%, var(--front-olive) 100%);
        color: white;
        border: none;
        border-radius: 12px;
        padding: 0.9rem 2rem;
        font-size: 1.05rem;
        font-weight: 600;
        letter-spacing: 0.5px;
        cursor: pointer;
        transition: all 0.3s ease;
        box-shadow: 0 8px 16px rgba(42, 90, 62, 0.2);
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
    }

    .btn-save:hover {
        transform: translateY(-2px);
        box-shadow: 0 12px 20px rgba(42, 90, 62, 0.3);
        color: white;
    }

    .btn-cancel {
        background: rgba(0, 0, 0, 0.05);
        color: var(--front-ink);
        border: 1px solid rgba(0, 0, 0, 0.1);
        border-radius: 12px;
        padding: 0.9rem 2rem;
        font-size: 1.05rem;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.3s ease;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
    }

    .btn-cancel:hover {
        background: rgba(0, 0, 0, 0.08);
        transform: translateY(-2px);
        color: var(--front-ink);
    }

    .alert-modern {
        border-radius: 12px;
        border: none;
        background: #fff0f0;
        color: #d32f2f;
        padding: 1rem 1.25rem;
        margin-bottom: 1.5rem;
        display: flex;
        align-items: flex-start;
        gap: 0.75rem;
        box-shadow: 0 4px 6px rgba(211, 47, 47, 0.05);
        animation: shake 0.5s cubic-bezier(0.36, 0.07, 0.19, 0.97) both;
    }

    .invalid-feedback-modern {
        color: #d32f2f;
        font-size: 0.85rem;
        margin-top: 0.4rem;
        display: flex;
        align-items: center;
        gap: 0.35rem;
    }

    .buttons-container {
        display: flex;
        gap: 1rem;
        margin-top: 2.5rem;
        padding-top: 1.5rem;
        border-top: 1px solid rgba(0, 0, 0, 0.05);
    }

    @keyframes floatIn {
        0% { opacity: 0; transform: translateY(30px) scale(0.95); }
        100% { opacity: 1; transform: translateY(0) scale(1); }
    }

    @keyframes shake {
        10%, 90% { transform: translateX(-1px); }
        20%, 80% { transform: translateX(2px); }
        30%, 50%, 70% { transform: translateX(-4px); }
        40%, 60% { transform: translateX(4px); }
    }

    @media (max-width: 768px) {
        .profile-body {
            padding: 1.5rem;
        }
        .buttons-container {
            flex-direction: column;
        }
        .btn-save, .btn-cancel {
            width: 100%;
            justify-content: center;
        }
    }
</style>
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
{% endblock %}

{% block content %}
<div class="profile-container">
    <div class="profile-wrapper">
        <div class="profile-card">
            <div class="profile-header">
                <div class="profile-logo-container">
                    <i class="fas fa-user-edit"></i>
                </div>
                <h1 class="profile-title">Modifier le Profil</h1>
                <p class="profile-subtitle">Mettez à jour vos informations personnelles</p>
            </div>
            
            <div class="profile-body">
                {% if form.vars.errors | length > 0 %}
                    <div class="alert-modern">
                        <i class="fas fa-exclamation-triangle mt-1"></i>
                        <div>
                            <strong>Erreurs</strong><br>
                            {% for error in form.vars.errors %}
                                <span class="small">{{ error.message }}</span><br>
                            {% endfor %}
                        </div>
                    </div>
                {% endif %}

                {{ form_start(form, {'attr': {'novalidate': 'novalidate'}}) }}
                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group-modern">
                                {{ form_label(form.nomUser, 'Nom') }}
                                {{ form_widget(form.nomUser, {
                                    attr: {class: 'input-modern ' ~ (form.nomUser.vars.errors | length > 0 ? 'is-invalid' : '')}
                                }) }}
                                {% if form.nomUser.vars.errors | length > 0 %}
                                    <div class="invalid-feedback-modern">
                                        {% for error in form.nomUser.vars.errors %}
                                            <i class="fas fa-times-circle"></i> {{ error.message }}
                                        {% endfor %}
                                    </div>
                                {% endif %}
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group-modern">
                                {{ form_label(form.prenomUser, 'Prénom') }}
                                {{ form_widget(form.prenomUser, {
                                    attr: {class: 'input-modern ' ~ (form.prenomUser.vars.errors | length > 0 ? 'is-invalid' : '')}
                                }) }}
                                {% if form.prenomUser.vars.errors | length > 0 %}
                                    <div class="invalid-feedback-modern">
                                        {% for error in form.prenomUser.vars.errors %}
                                            <i class="fas fa-times-circle"></i> {{ error.message }}
                                        {% endfor %}
                                    </div>
                                {% endif %}
                            </div>
                        </div>
                    </div>

                    <div class="form-group-modern">
                        {{ form_label(form.emailUser, 'Adresse Email') }}
                        {{ form_widget(form.emailUser, {
                            attr: {class: 'input-modern ' ~ (form.emailUser.vars.errors | length > 0 ? 'is-invalid' : '')}
                        }) }}
                        {% if form.emailUser.vars.errors | length > 0 %}
                            <div class="invalid-feedback-modern">
                                {% for error in form.emailUser.vars.errors %}
                                    <i class="fas fa-times-circle"></i> {{ error.message }}
                                {% endfor %}
                            </div>
                        {% endif %}
                    </div>

                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group-modern">
                                {{ form_label(form.numUser, 'Numéro de Téléphone') }}
                                {{ form_widget(form.numUser, {
                                    attr: {class: 'input-modern ' ~ (form.numUser.vars.errors | length > 0 ? 'is-invalid' : '')}
                                }) }}
                                {% if form.numUser.vars.errors | length > 0 %}
                                    <div class="invalid-feedback-modern">
                                        {% for error in form.numUser.vars.errors %}
                                            <i class="fas fa-times-circle"></i> {{ error.message }}
                                        {% endfor %}
                                    </div>
                                {% endif %}
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group-modern">
                                {{ form_label(form.adresseUser, 'Adresse') }}
                                {{ form_widget(form.adresseUser, {
                                    attr: {class: 'input-modern ' ~ (form.adresseUser.vars.errors | length > 0 ? 'is-invalid' : '')}
                                }) }}
                                {% if form.adresseUser.vars.errors | length > 0 %}
                                    <div class="invalid-feedback-modern">
                                        {% for error in form.adresseUser.vars.errors %}
                                            <i class="fas fa-times-circle"></i> {{ error.message }}
                                        {% endfor %}
                                    </div>
                                {% endif %}
                            </div>
                        </div>
                    </div>

                    <div class="form-group-modern">
                        {{ form_label(form.photoPath, 'Photo de profil') }}
                        {{ form_widget(form.photoPath, {
                            attr: {class: 'input-modern ' ~ (form.photoPath.vars.errors | length > 0 ? 'is-invalid' : '')}
                        }) }}
                        {% if form.photoPath.vars.errors | length > 0 %}
                            <div class="invalid-feedback-modern">
                                {% for error in form.photoPath.vars.errors %}
                                    <i class="fas fa-times-circle"></i> {{ error.message }}
                                {% endfor %}
                            </div>
                        {% endif %}
                    </div>

                    <div class="buttons-container">
                        <button type="submit" class="btn-save">
                            <i class="fas fa-save"></i> Enregistrer les modifications
                        </button>
                        <a href="{{ path('app_profile') }}" class="btn-cancel">
                            <i class="fas fa-times"></i> Annuler
                        </a>
                    </div>
                {{ form_end(form) }}
            </div>
        </div>
    </div>
</div>
{% endblock %}