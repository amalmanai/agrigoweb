{% extends 'back/base.html.twig' %}

{% block title %}Modifier la Récolte - Admin AgriGo{% endblock %}

{% block content %}
<div class="space-y-6">
    {# Header #}
    <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-4">
        <div>
            <p class="text-xs font-semibold tracking-widest uppercase text-agri-green mb-1">Administration</p>
            <h1 class="text-3xl font-serif font-bold text-gray-900">Modifier la récolte</h1>
            <p class="text-gray-500 mt-1 text-sm">Modifiez les informations de la récolte #{{ recolte.id }}.</p>
        </div>
        <a href="{{ path('admin_recolte_index') }}" class="inline-flex items-center gap-2 px-4 py-2 bg-gray-100 text-gray-700 text-sm font-medium rounded-xl hover:bg-gray-200 transition">
            <i class="ph ph-arrow-left"></i> Retour aux récoltes
        </a>
    </div>

    {# Form Card #}
    <div class="bg-white border border-gray-100 rounded-2xl shadow-sm p-8">
        {{ form_start(form, {'attr': {'class': 'space-y-6'}}) }}
        
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            {# Culture #}
            <div class="md:col-span-2">
                {{ form_label(form.culture, 'Culture', {'label_attr': {'class': 'block text-sm font-semibold text-gray-700 mb-2'}}) }}
                {{ form_widget(form.culture, {'attr': {'class': 'w-full px-4 py-3 border border-gray-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-lime-500 focus:border-transparent transition'}}) }}
                {{ form_errors(form.culture) }}
            </div>

            {# Quantité #}
            <div>
                {{ form_label(form.quantity, 'Quantité (kg)', {'label_attr': {'class': 'block text-sm font-semibold text-gray-700 mb-2'}}) }}
                {{ form_widget(form.quantity, {'attr': {'class': 'w-full px-4 py-3 border border-gray-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-lime-500 focus:border-transparent transition'}}) }}
                {{ form_errors(form.quantity) }}
            </div>

            {# Coût de production #}
            <div>
                {{ form_label(form.coutProduction, 'Coût de production (€)', {'label_attr': {'class': 'block text-sm font-semibold text-gray-700 mb-2'}}) }}
                {{ form_widget(form.coutProduction, {'attr': {'class': 'w-full px-4 py-3 border border-gray-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-lime-500 focus:border-transparent transition'}}) }}
                {{ form_errors(form.coutProduction) }}
            </div>

            {# Date de récolte #}
            <div>
                {{ form_label(form.dateRecolte, 'Date de récolte', {'label_attr': {'class': 'block text-sm font-semibold text-gray-700 mb-2'}}) }}
                {{ form_widget(form.dateRecolte, {'attr': {'class': 'w-full px-4 py-3 border border-gray-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-lime-500 focus:border-transparent transition'}}) }}
                {{ form_errors(form.dateRecolte) }}
            </div>

            {# Statut #}
            <div>
                {{ form_label(form.statut, 'Statut', {'label_attr': {'class': 'block text-sm font-semibold text-gray-700 mb-2'}}) }}
                {{ form_widget(form.statut, {'attr': {'class': 'w-full px-4 py-3 border border-gray-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-lime-500 focus:border-transparent transition'}}) }}
                {{ form_errors(form.statut) }}
            </div>

            {# Notes #}
            <div class="md:col-span-2">
                {{ form_label(form.notes, 'Notes (optionnel)', {'label_attr': {'class': 'block text-sm font-semibold text-gray-700 mb-2'}}) }}
                {{ form_widget(form.notes, {'attr': {'class': 'w-full px-4 py-3 border border-gray-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-lime-500 focus:border-transparent transition', 'rows': 4}}) }}
                {{ form_errors(form.notes) }}
            </div>
        </div>

        {# Actions #}
        <div class="flex items-center justify-end gap-4 pt-6 border-t border-gray-100">
            <a href="{{ path('admin_recolte_index') }}" class="px-6 py-3 text-gray-700 hover:text-gray-900 font-medium transition">
                Annuler
            </a>
            <button type="submit" class="px-6 py-3 bg-lime-600 text-white font-medium rounded-xl hover:bg-lime-700 transition shadow-sm">
                Mettre à jour la récolte
            </button>
        </div>

        {{ form_end(form) }}
    </div>
</div>
{% endblock %}
