{% extends 'back/base.html.twig' %}

{% block title %}Gestion des Récoltes - Back{% endblock %}

{% block content %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="h3 m-0 text-dark">Gestion des Récoltes</h1>
        <p class="text-muted small mb-0">Consultez et gérez toutes les récoltes de l'exploitation.</p>
    </div>
    <div class="d-flex gap-2">
        <a href="{{ path('admin_recolte_new') }}" class="btn btn-primary">
            <i class="bi bi-plus-lg"></i> Nouvelle Récolte
        </a>
        <a href="{{ path('app_admin_dashboard') }}" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left"></i> Retour
        </a>
    </div>
</div>

<div class="card bg-primary text-white border-0 shadow-sm mb-4">
    <div class="card-body">
        <div class="d-flex justify-content-between align-items-center">
            <div>
                <div class="text-white-50 small font-weight-bold text-uppercase mb-1">Coût total de production</div>
                <div class="h3 mb-0 font-weight-bold">{{ total_cost|number_format(2, ',', ' ') }} €</div>
            </div>
            <i class="bi bi-flower1 h1 text-white-50"></i>
        </div>
    </div>
</div>

<div class="mb-4">
    <form method="get" action="{{ path('admin_recolte_index') }}" class="d-flex w-50">
        <input type="text" name="search" class="form-control me-2" placeholder="Rechercher par nom..." value="{{ search|default('') }}">
        <button type="submit" class="btn btn-outline-primary"><i class="bi bi-search"></i></button>
        {% if search|default('') %}
            <a href="{{ path('admin_recolte_index') }}" class="btn btn-outline-secondary ms-2"><i class="bi bi-x"></i></a>
        {% endif %}
    </form>
</div>

<div class="table-responsive">
    <table class="table table-striped table-hover border">
        <thead class="table-dark">
            <tr>
                <th>
                    <a href="{{ path('admin_recolte_index', {'sort': 'id', 'direction': sort == 'id' and direction == 'ASC' ? 'DESC' : 'ASC', 'search': search|default('')}) }}" class="text-white text-decoration-none">
                        ID {% if sort == 'id' %}<i class="bi bi-arrow-{{ direction == 'ASC' ? 'up' : 'down' }}"></i>{% endif %}
                    </a>
                </th>
                <th>
                    <a href="{{ path('admin_recolte_index', {'sort': 'name', 'direction': sort == 'name' and direction == 'ASC' ? 'DESC' : 'ASC', 'search': search|default('')}) }}" class="text-white text-decoration-none">
                        Nom {% if sort == 'name' %}<i class="bi bi-arrow-{{ direction == 'ASC' ? 'up' : 'down' }}"></i>{% endif %}
                    </a>
                </th>
                <th>
                    <a href="{{ path('admin_recolte_index', {'sort': 'quantity', 'direction': sort == 'quantity' and direction == 'ASC' ? 'DESC' : 'ASC', 'search': search|default('')}) }}" class="text-white text-decoration-none">
                        Quantité {% if sort == 'quantity' %}<i class="bi bi-arrow-{{ direction == 'ASC' ? 'up' : 'down' }}"></i>{% endif %}
                    </a>
                </th>
                <th>
                    <a href="{{ path('admin_recolte_index', {'sort': 'productionCost', 'direction': sort == 'productionCost' and direction == 'ASC' ? 'DESC' : 'ASC', 'search': search|default('')}) }}" class="text-white text-decoration-none">
                        Coût {% if sort == 'productionCost' %}<i class="bi bi-arrow-{{ direction == 'ASC' ? 'up' : 'down' }}"></i>{% endif %}
                    </a>
                </th>
                <th>
                    <a href="{{ path('admin_recolte_index', {'sort': 'harvestDate', 'direction': sort == 'harvestDate' and direction == 'ASC' ? 'DESC' : 'ASC', 'search': search|default('')}) }}" class="text-white text-decoration-none">
                        Date {% if sort == 'harvestDate' %}<i class="bi bi-arrow-{{ direction == 'ASC' ? 'up' : 'down' }}"></i>{% endif %}
                    </a>
                </th>
                <th class="text-center">Actions</th>
            </tr>
        </thead>
        <tbody>
            {% for recolte in recoltes %}
            <tr>
                <td class="fw-bold">#{{ recolte.id }}</td>
                <td>{{ recolte.name ?: '-' }}</td>
                <td>{{ recolte.quantity ? recolte.quantity|number_format(2, ',', ' ') : '-' }} {{ recolte.unit ?: 'kg' }}</td>
                <td class="text-success fw-bold">{{ recolte.productionCost ? recolte.productionCost|number_format(2, ',', ' ') : '-' }} €</td>
                <td>{{ recolte.harvestDate ? recolte.harvestDate|date('d/m/Y') : '-' }}</td>
                <td class="text-center">
                    <div class="btn-group">
                        <a href="{{ path('admin_recolte_show', {'id': recolte.id}) }}" class="btn btn-sm btn-info text-white" title="Voir">
                            <i class="bi bi-eye"></i>
                        </a>
                        <a href="{{ path('admin_recolte_edit', {'id': recolte.id}) }}" class="btn btn-sm btn-warning" title="Modifier">
                            <i class="bi bi-pencil"></i>
                        </a>
                        <form method="post" action="{{ path('admin_recolte_delete', {'id': recolte.id}) }}" onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer cette récolte ?');" class="d-inline">
                            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ recolte.id) }}">
                            <button type="submit" class="btn btn-sm btn-danger" title="Supprimer">
                                <i class="bi bi-trash"></i>
                            </button>
                        </form>
                    </div>
                </td>
            </tr>
            {% else %}
            <tr>
                <td colspan="7" class="text-center py-4 text-muted">
                    Aucune récolte enregistrée
                </td>
            </tr>
            {% endfor %}
        </tbody>
    </table>
</div>
{% endblock %}

