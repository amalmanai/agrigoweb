{% extends 'back/base.html.twig' %}

{% block title %}Gestion des Ventes - Back{% endblock %}

{% block content %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="h3 m-0 text-dark">Gestion des Ventes</h1>
        <p class="text-muted small mb-0">Consultez et gérez toutes les ventes de l'exploitation.</p>
    </div>
    <div class="d-flex gap-2">
        <a href="{{ path('admin_vente_new') }}" class="btn btn-primary">
            <i class="bi bi-plus-lg"></i> Nouvelle Vente
        </a>
        <a href="{{ path('app_admin_dashboard') }}" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left"></i> Retour
        </a>
    </div>
</div>

<div class="card bg-success text-white border-0 shadow-sm mb-4">
    <div class="card-body">
        <div class="d-flex justify-content-between align-items-center">
            <div>
                <div class="text-white-50 small font-weight-bold text-uppercase mb-1">Revenu total des ventes</div>
                <div class="h3 mb-0 font-weight-bold">{{ total_revenue|number_format(2, ',', ' ') }} €</div>
            </div>
            <i class="bi bi-cash-stack h1 text-white-50"></i>
        </div>
    </div>
</div>

<div class="mb-4">
    <form method="get" action="{{ path('admin_vente_index') }}" class="d-flex w-50">
        <input type="text" name="search" class="form-control me-2" placeholder="Rechercher (Description, Acheteur, Statut)..." value="{{ search|default('') }}">
        <button type="submit" class="btn btn-outline-primary"><i class="bi bi-search"></i></button>
        {% if search|default('') %}
            <a href="{{ path('admin_vente_index') }}" class="btn btn-outline-secondary ms-2"><i class="bi bi-x"></i></a>
        {% endif %}
    </form>
</div>

<div class="table-responsive">
    <table class="table table-striped table-hover border">
        <thead class="table-dark">
            <tr>
                <th>
                    <a href="{{ path('admin_vente_index', {'sort': 'id', 'direction': sort == 'id' and direction == 'ASC' ? 'DESC' : 'ASC', 'search': search|default('')}) }}" class="text-white text-decoration-none">
                        ID {% if sort == 'id' %}<i class="bi bi-arrow-{{ direction == 'ASC' ? 'up' : 'down' }}"></i>{% endif %}
                    </a>
                </th>
                <th>
                    <a href="{{ path('admin_vente_index', {'sort': 'description', 'direction': sort == 'description' and direction == 'ASC' ? 'DESC' : 'ASC', 'search': search|default('')}) }}" class="text-white text-decoration-none">
                        Description {% if sort == 'description' %}<i class="bi bi-arrow-{{ direction == 'ASC' ? 'up' : 'down' }}"></i>{% endif %}
                    </a>
                </th>
                <th>
                    <a href="{{ path('admin_vente_index', {'sort': 'price', 'direction': sort == 'price' and direction == 'ASC' ? 'DESC' : 'ASC', 'search': search|default('')}) }}" class="text-white text-decoration-none">
                        Prix {% if sort == 'price' %}<i class="bi bi-arrow-{{ direction == 'ASC' ? 'up' : 'down' }}"></i>{% endif %}
                    </a>
                </th>
                <th>
                    <a href="{{ path('admin_vente_index', {'sort': 'saleDate', 'direction': sort == 'saleDate' and direction == 'ASC' ? 'DESC' : 'ASC', 'search': search|default('')}) }}" class="text-white text-decoration-none">
                        Date {% if sort == 'saleDate' %}<i class="bi bi-arrow-{{ direction == 'ASC' ? 'up' : 'down' }}"></i>{% endif %}
                    </a>
                </th>
                <th>
                    <a href="{{ path('admin_vente_index', {'sort': 'buyerName', 'direction': sort == 'buyerName' and direction == 'ASC' ? 'DESC' : 'ASC', 'search': search|default('')}) }}" class="text-white text-decoration-none">
                        Acheteur {% if sort == 'buyerName' %}<i class="bi bi-arrow-{{ direction == 'ASC' ? 'up' : 'down' }}"></i>{% endif %}
                    </a>
                </th>
                <th>
                    <a href="{{ path('admin_vente_index', {'sort': 'status', 'direction': sort == 'status' and direction == 'ASC' ? 'DESC' : 'ASC', 'search': search|default('')}) }}" class="text-white text-decoration-none">
                        Statut {% if sort == 'status' %}<i class="bi bi-arrow-{{ direction == 'ASC' ? 'up' : 'down' }}"></i>{% endif %}
                    </a>
                </th>
                <th class="text-center">Actions</th>
            </tr>
        </thead>
        <tbody>
            {% for vente in ventes %}
            <tr>
                <td class="fw-bold">#{{ vente.id }}</td>
                <td>{{ vente.description }}</td>
                <td class="text-success fw-bold">{{ vente.price|number_format(2, ',', ' ') }} €</td>
                <td>{{ vente.saleDate ? vente.saleDate|date('d/m/Y') : '-' }}</td>
                <td>{{ vente.buyerName ?: '-' }}</td>
                <td>
                    {% if vente.status %}
                        <span class="badge {% if vente.status == 'terminée' %}bg-success{% elseif vente.status == 'en attente' %}bg-warning text-dark{% else %}bg-secondary{% endif %}">
                            {{ vente.status }}
                        </span>
                    {% else %}
                        <span class="text-muted">-</span>
                    {% endif %}
                </td>
                <td class="text-center">
                    <div class="btn-group">
                        <a href="{{ path('admin_vente_show', {'id': vente.id}) }}" class="btn btn-sm btn-info text-white" title="Voir">
                            <i class="bi bi-eye"></i>
                        </a>
                        <a href="{{ path('admin_vente_edit', {'id': vente.id}) }}" class="btn btn-sm btn-warning" title="Modifier">
                            <i class="bi bi-pencil"></i>
                        </a>
                        <form method="post" action="{{ path('admin_vente_delete', {'id': vente.id}) }}" onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer cette vente ?');" class="d-inline">
                            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ vente.id) }}">
                            <button type="submit" class="btn btn-sm btn-danger" title="Supprimer">
                                <i class="bi bi-trash"></i>
                            </button>
                        </form>
                    </div>
                </td>
            </tr>
            {% else %}
            <tr>
                <td colspan="7" class="text-center py-4 text-muted">
                    Aucune vente enregistrée
                </td>
            </tr>
            {% endfor %}
        </tbody>
    </table>
</div>
{% endblock %}

