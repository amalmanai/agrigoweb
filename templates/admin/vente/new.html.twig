{% extends 'back/base.html.twig' %}

{% block title %}{{ vente.id ? 'Modifier' : 'Nouvelle' }} Vente - Admin AgriGo{% endblock %}

{% block content %}
<div class="space-y-6">
    {# Header #}
    <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-4">
        <div>
            <p class="text-xs font-semibold tracking-widest uppercase text-agri-green mb-1">Administration</p>
            <h1 class="text-3xl font-serif font-bold text-gray-900">
                {{ vente.id ? 'Modifier la vente' : 'Nouvelle vente' }}
            </h1>
            <p class="text-gray-500 mt-1 text-sm">
                {{ vente.id ? 'Modifiez les informations de la vente.' : 'Enregistrez une nouvelle vente.' }}
            </p>
        </div>
        <a href="{{ path('admin_vente_index') }}" class="inline-flex items-center gap-2 px-4 py-2 bg-gray-100 text-gray-700 text-sm font-medium rounded-xl hover:bg-gray-200 transition">
            <i class="ph ph-arrow-left"></i> Retour aux ventes
        </a>
    </div>

    {# Form Card #}
    <div class="bg-white border border-gray-100 rounded-2xl shadow-sm p-8">
        {{ form_start(form, {'attr': {'class': 'space-y-6'}}) }}
        
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            {# Description #}
            <div class="md:col-span-2">
                {{ form_label(form.description, 'Description', {'label_attr': {'class': 'block text-sm font-semibold text-gray-700 mb-2'}}) }}
                {{ form_widget(form.description, {'attr': {'class': 'w-full px-4 py-3 border border-gray-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:border-transparent transition'}}) }}
                {{ form_errors(form.description) }}
            </div>

            {# Prix #}
            <div>
                {{ form_label(form.price, 'Prix (€)', {'label_attr': {'class': 'block text-sm font-semibold text-gray-700 mb-2'}}) }}
                {{ form_widget(form.price, {'attr': {'class': 'w-full px-4 py-3 border border-gray-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:border-transparent transition'}}) }}
                {{ form_errors(form.price) }}
            </div>

            {# Date de vente #}
            <div>
                {{ form_label(form.saleDate, 'Date de vente', {'label_attr': {'class': 'block text-sm font-semibold text-gray-700 mb-2'}}) }}
                {{ form_widget(form.saleDate, {'attr': {'class': 'w-full px-4 py-3 border border-gray-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:border-transparent transition'}}) }}
                {{ form_errors(form.saleDate) }}
            </div>

            {# Nom de l'acheteur #}
            <div>
                {{ form_label(form.buyerName, 'Nom de l\'acheteur', {'label_attr': {'class': 'block text-sm font-semibold text-gray-700 mb-2'}}) }}
                {{ form_widget(form.buyerName, {'attr': {'class': 'w-full px-4 py-3 border border-gray-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:border-transparent transition'}}) }}
                {{ form_errors(form.buyerName) }}
            </div>

            {# Statut #}
            <div>
                {{ form_label(form.status, 'Statut', {'label_attr': {'class': 'block text-sm font-semibold text-gray-700 mb-2'}}) }}
                {{ form_widget(form.status, {'attr': {'class': 'w-full px-4 py-3 border border-gray-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:border-transparent transition'}}) }}
                {{ form_errors(form.status) }}
            </div>

            {# Récolte associée #}
            <div class="md:col-span-2">
                {{ form_label(form.recolte, 'Récolte associée (optionnel)', {'label_attr': {'class': 'block text-sm font-semibold text-gray-700 mb-2'}}) }}
                {{ form_widget(form.recolte, {'attr': {'class': 'w-full px-4 py-3 border border-gray-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:border-transparent transition'}}) }}
                {{ form_errors(form.recolte) }}
            </div>
        </div>

        {# Actions #}
        <div class="flex items-center justify-end gap-4 pt-6 border-t border-gray-100">
            <a href="{{ path('admin_vente_index') }}" class="px-6 py-3 text-gray-700 hover:text-gray-900 font-medium transition">
                Annuler
            </a>
            <button type="submit" class="px-6 py-3 bg-emerald-600 text-white font-medium rounded-xl hover:bg-emerald-700 transition shadow-sm">
                {{ vente.id ? 'Mettre à jour' : 'Créer' }} la vente
            </button>
        </div>

        {{ form_end(form) }}
    </div>
</div>
{% endblock %}
