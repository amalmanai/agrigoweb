{% extends 'back/base.html.twig' %}

{% block title %}Détails Mouvement{% endblock %}

{% block content %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h3 m-0 text-dark">Mouvement #{{ mouvement_stock.idMouvement }}</h1>
    <div class="d-flex gap-2">
        <a href="{{ path('admin_mouvement_stock_edit', {'id_mouvement': mouvement_stock.idMouvement}) }}" class="btn btn-warning">
            <i class="bi bi-pencil"></i> Modifier
        </a>
        <a href="{{ path('admin_mouvement_stock_index') }}" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left"></i> Retour
        </a>
    </div>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body">
        <table class="table">
            <tbody>
                <tr>
                    <th class="w-25">ID</th>
                    <td>{{ mouvement_stock.idMouvement }}</td>
                </tr>
                <tr>
                    <th>Type de Mouvement</th>
                    <td>
                        <span class="badge {% if mouvement_stock.typeMouvement == 'Entrée' %}bg-success{% else %}bg-warning text-dark{% endif %}">
                            {{ mouvement_stock.typeMouvement }}
                        </span>
                    </td>
                </tr>
                <tr>
                    <th>ID Produit</th>
                    <td>{{ mouvement_stock.idProduit }}</td>
                </tr>
                <tr>
                    <th>Quantité</th>
                    <td class="fw-bold">{{ mouvement_stock.quantite }}</td>
                </tr>
                <tr>
                    <th>Date</th>
                    <td>{{ mouvement_stock.dateMouvement }}</td>
                </tr>
                <tr>
                    <th>Motif</th>
                    <td>{{ mouvement_stock.motif }}</td>
                </tr>
                <tr>
                    <th>ID Utilisateur (Admin/Resp.)</th>
                    <td>{{ mouvement_stock.idUser }}</td>
                </tr>
            </tbody>
        </table>
    </div>
</div>
{% endblock %}
