{% extends 'back/base.html.twig' %}

{% block title %}Modifier l'utilisateur{% endblock %}

{% block content %}
<div class="container mt-5">
    <div class="row mb-4 align-items-center">
        <div class="col-md-8">
            <h1 class="h2 text-success"><i class="fas fa-user-edit me-2"></i>Modifier l'utilisateur</h1>
            <p class="text-muted">{{ user.fullName }} &bull; {{ user.emailUser }}</p>
        </div>
        <div class="col-md-4 text-end">
            <a href="{{ path('app_admin_users') }}" class="btn btn-outline-secondary">
                <i class="fas fa-arrow-left me-1"></i>Retour à la liste
            </a>
        </div>
    </div>

    <div class="row">
        <div class="col-md-8">
            {{ form_start(form, {'attr': {'novalidate': 'novalidate'}}) }}
                <div class="card shadow-sm mb-4">
                    <div class="card-header bg-white">
                        <i class="fas fa-id-card me-1"></i>Informations Personnelles
                    </div>
                    <div class="card-body">
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                {{ form_row(form.nomUser, {
                                    'attr': {'class': 'form-control'}
                                }) }}
                            </div>
                            <div class="col-md-6 mb-3">
                                {{ form_row(form.prenomUser, {
                                    'attr': {'class': 'form-control'}
                                }) }}
                            </div>
                        </div>

                        <div class="mb-3">
                            {{ form_row(form.emailUser, {
                                'attr': {'class': 'form-control'}
                            }) }}
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                {{ form_row(form.numUser, {
                                    'attr': {'class': 'form-control'}
                                }) }}
                            </div>
                            <div class="col-md-6 mb-3">
                                {{ form_row(form.roleUser, {
                                    'attr': {'class': 'form-select'}
                                }) }}
                            </div>
                        </div>

                        <div class="mb-3">
                            {{ form_row(form.adresseUser, {
                                'attr': {'class': 'form-control'}
                            }) }}
                        </div>

                        <div class="mb-3">
                            {{ form_row(form.photoPath, {
                                'attr': {'class': 'form-control'}
                            }) }}
                        </div>


                    </div>
                </div>

                <div class="d-grid gap-2 d-md-flex justify-content-md-start mb-5">
                    <button type="submit" class="btn btn-success px-5">
                        <i class="fas fa-save me-2"></i>Enregistrer les modifications
                    </button>
                    <a href="{{ path('app_admin_users') }}" class="btn btn-light px-4">Annuler</a>
                </div>
            {{ form_end(form) }}
        </div>
        <div class="col-md-4">
            <div class="card shadow-sm border-success">
                <div class="card-header bg-success text-white">
                    <i class="fas fa-info-circle me-1"></i>Guide Admin
                </div>
                <div class="card-body">
                    <p class="small text-muted">En tant qu'administrateur, vous pouvez modifier toutes les informations de l'utilisateur, y compris son rôle.</p>
                    <hr>
                    <div class="d-flex align-items-center">
                        <div class="flex-shrink-0">
                            {% if user.photoPath %}
                                <img src="{{ user.photoPath }}" alt="Current Photo" class="rounded-circle shadow-sm" style="width: 64px; height: 64px; object-fit: cover;">
                            {% else %}
                                <div class="rounded-circle bg-light d-flex align-items-center justify-content-center border" style="width: 64px; height: 64px;">
                                    <i class="fas fa-user-slash text-muted"></i>
                                </div>
                            {% endif %}
                        </div>
                        <div class="flex-grow-1 ms-3">
                            <h6 class="mb-0">Aperçu Photo</h6>
                            <small class="text-muted">Photo actuelle de l'utilisateur</small>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
