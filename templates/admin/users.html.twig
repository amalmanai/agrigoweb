{% extends 'base.html.twig' %}

{% block title %}Gestion des Utilisateurs - {{ parent() }}{% endblock %}

{% block body %}
<div class="container mt-5">
    <div class="card">
        <div class="card-header d-flex justify-content-between align-items-center">
            <h2 class="mb-0"><i class="fas fa-users"></i> Gestion des Utilisateurs</h2>
            <a href="{{ path('admin_culture_index') }}" class="btn btn-outline-light btn-sm">
                <i class="fas fa-arrow-left"></i> Retour cultures
            </a>
        </div>
<div class="card-body">
            {# KPI Cards #}
            <div class="row mb-4">
                <div class="col-md-4">
                    <div class="card text-white bg-primary mb-3 shadow-sm">
                        <div class="card-body">
                            <h5 class="card-title"><i class="fas fa-users"></i> Total Utilisateurs</h5>
                            <p class="card-text fs-2 fw-bold">{{ totalUsers ?? 0 }}</p>
                        </div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="card text-white bg-success mb-3 shadow-sm">
                        <div class="card-body">
                            <h5 class="card-title"><i class="fas fa-user-check"></i> Comptes Actifs</h5>
                            <p class="card-text fs-2 fw-bold">{{ activeUsers ?? 0 }}</p>
                        </div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="card text-white bg-secondary mb-3 shadow-sm">
                        <div class="card-body">
                            <h5 class="card-title"><i class="fas fa-user-slash"></i> Comptes Inactifs</h5>
                            <p class="card-text fs-2 fw-bold">{{ inactiveUsers ?? 0 }}</p>
                        </div>
                    </div>
                </div>
            </div>

            {# Advanced Filters Form #}
            <form method="GET" class="mb-4 p-3 bg-light rounded shadow-sm">
                <h5 class="mb-3 text-muted"><i class="fas fa-filter"></i> Filtres et Tris Avancés</h5>
                <div class="row g-2">
                    <div class="col-md-4">
                        <input type="text" name="q" class="form-control" placeholder="Recherche textuelle..." value="{{ query|default('')|e('html_attr') }}">
                    </div>
                    <div class="col-md-2">
                        <select name="role" class="form-select">
                            <option value="">Tous les rôles</option>
                            <option value="ROLE_ADMIN" {% if role|default('') == 'ROLE_ADMIN' %}selected{% endif %}>Admin</option>
                            <option value="ROLE_USER" {% if role|default('') == 'ROLE_USER' %}selected{% endif %}>User</option>
                        </select>
                    </div>
                    <div class="col-md-2">
                        <select name="status" class="form-select">
                            <option value="">Tous les statuts</option>
                            <option value="1" {% if status|default('') == '1' %}selected{% endif %}>Actif</option>
                            <option value="0" {% if status|default('') == '0' %}selected{% endif %}>Inactif</option>
                        </select>
                    </div>
                    <div class="col-md-2">
                        <select name="sort" class="form-select">
                            <option value="idUser" {% if sortBy|default('idUser') == 'idUser' %}selected{% endif %}>Trier par ID</option>
                            <option value="nomUser" {% if sortBy|default('') == 'nomUser' %}selected{% endif %}>Trier par Nom</option>
                            <option value="emailUser" {% if sortBy|default('') == 'emailUser' %}selected{% endif %}>Trier par Email</option>
                            <option value="roleUser" {% if sortBy|default('') == 'roleUser' %}selected{% endif %}>Trier par Rôle</option>
                        </select>
                    </div>
                    <div class="col-md-2 d-flex">
                        <button type="submit" class="btn btn-success me-2 w-100">
                            <i class="fas fa-search"></i> Appliquer
                        </button>
                        <a href="{{ path('app_admin_users') }}" class="btn btn-outline-secondary" title="Réinitialiser">
                            <i class="fas fa-sync-alt"></i>
                        </a>
                    </div>
                </div>
            </form>

            <div class="mb-3 d-flex justify-content-between align-items-center border-bottom pb-2">
                <span class="badge bg-green text-white fs-6 px-3 py-2">{{ users|length }} résultat(s)</span>
                <a href="{{ path('app_admin_users_export_pdf', app.request.query.all) }}" class="btn btn-danger">
                    <i class="fas fa-file-pdf"></i> Exporter en PDF
                </a>
            </div>
            <div class="table-responsive">
                <table class="table table-striped">
                    <thead>
                        <tr>
                            <th>Photo</th>
                            <th>ID</th>
                            <th>Nom</th>
                            <th>Email</th>
                            <th>Téléphone</th>
                            <th>Adresse</th>
                            <th>Rôle</th>
                            <th>Statut</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for user in users %}
                        <tr>
                            <td>
                                {% if user.photoPath %}
                                    <img src="{{ asset('uploads/users/' ~ user.photoPath) }}" alt="Photo" class="rounded-circle" style="width: 40px; height: 40px; object-fit: cover;">
                                {% else %}
                                    <div class="rounded-circle bg-light d-flex align-items-center justify-content-center" style="width: 40px; height: 40px;">
                                        <i class="fas fa-user text-muted"></i>
                                    </div>
                                {% endif %}
                            </td>
                            <td>{{ user.idUser }}</td>
                            <td>{{ user.prenomUser }} {{ user.nomUser }}</td>
                            <td>{{ user.emailUser }}</td>
                            <td>{{ user.numUser }}</td>
                            <td>{{ user.adresseUser }}</td>
                            <td>
                                {% if user.roleUser == 'ROLE_ADMIN' %}
                                    <span class="badge bg-danger">Admin</span>
                                {% else %}
                                    <span class="badge bg-info">User</span>
                                {% endif %}
                            </td>
                            <td>
                                {% if user.isActive %}
                                    <span class="badge bg-success">Actif</span>
                                {% else %}
                                    <span class="badge bg-secondary">Inactif</span>
                                {% endif %}
                            </td>
                            <td>
                                <div class="btn-group">
                                    <a href="{{ path('app_admin_user_detail', {'id': user.idUser}) }}" class="btn btn-sm btn-outline-info" title="Voir">
                                        <i class="fas fa-eye"></i>
                                    </a>
                                    <a href="{{ path('app_admin_user_edit', {'id': user.idUser}) }}" class="btn btn-sm btn-outline-warning" title="Éditer">
                                        <i class="fas fa-edit"></i>
                                    </a>
                                    <a href="{{ path('app_admin_user_toggle', {'id': user.idUser}) }}" class="btn btn-sm btn-outline-secondary" title="{{ user.isActive ? 'Désactiver' : 'Activer' }}">
                                        <i class="fas fa-toggle-on"></i>
                                    </a>
                                    <a href="{{ path('app_admin_user_delete', {'id': user.idUser}) }}" class="btn btn-sm btn-outline-danger" title="Supprimer" onclick="return confirm('Êtes-vous sûr de vouloir supprimer cet utilisateur ?')">
                                        <i class="fas fa-trash"></i>
                                    </a>
                                </div>
                            </td>
                        </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
{% endblock %}