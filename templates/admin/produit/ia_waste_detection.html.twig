{% extends 'back/base.html.twig' %}

{% block title %}Gaspillage IA - Back{% endblock %}

{% block content %}
<div class="d-flex justify-content-between align-items-center flex-wrap gap-3 mb-4">
    <div>
        <h1 class="h3 m-0 text-dark">Gaspillage IA</h1>
        <p class="text-muted small mb-0">Détection des anomalies de consommation.</p>
    </div>
    <a href="{{ path('admin_produit_index') }}" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left"></i> Retour aux produits
    </a>
</div>

<div class="row g-3 mb-4">
    <div class="col-md-4">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body">
                <div class="text-muted small text-uppercase fw-semibold">Anomalies détectées</div>
                <div class="display-6 fw-bold text-danger">{{ anomaliesCount|default(0) }}</div>
            </div>
        </div>
    </div>
    <div class="col-md-8">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body d-flex align-items-center">
                <div class="text-muted">
                    Le modèle compare la consommation récente à la tendance historique et signale les écarts inhabituels.
                </div>
            </div>
        </div>
    </div>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body table-responsive">
        <table class="table align-middle mb-0">
            <thead>
                <tr>
                    <th>Produit</th>
                    <th>Dernier mois</th>
                    <th>Moyenne</th>
                    <th>Seuil</th>
                    <th>Confiance</th>
                    <th>Résultat</th>
                </tr>
            </thead>
            <tbody>
                {% for row in analyses %}
                    <tr>
                        <td>{{ row.produit.nomProduit|default('N/A') }}</td>
                        <td>{{ row.consommationDernierMois|default(0) }}</td>
                        <td>{{ row.moyenne|default(0) }}</td>
                        <td>{{ row.seuil|default(0) }}</td>
                        <td>{{ row.confiance|default('N/A') }}</td>
                        <td>
                            {% if row.anomalie|default(false) %}
                                <span class="badge bg-danger">Anomalie</span>
                            {% else %}
                                <span class="badge bg-success">Normal</span>
                            {% endif %}
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="6" class="text-center text-muted py-4">Aucune donnée disponible.</td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>
{% endblock %}
