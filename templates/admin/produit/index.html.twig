
{% extends 'back/base.html.twig' %}

{% block title %}Gestion des Produits - Back{% endblock %}

{% block content %}
<div class="d-flex justify-content-between align-items-center mb-4 flex-column flex-md-row gap-3">
    <div>
        <h1 class="h3 m-0 text-dark">Gestion des Produits</h1>
        <p class="text-muted small mb-0">Consultez et gérez le catalogue de produits.</p>
    </div>
    <div class="d-flex gap-2 flex-wrap">
        <a href="{{ path('admin_produit_stats') }}" class="btn btn-outline-info">
            <i class="bi bi-bar-chart-line"></i> Statistiques
        </a>
        <a href="{{ path('admin_produit_new') }}" class="btn btn-primary">
            <i class="bi bi-plus-lg"></i> Nouveau Produit
        </a>
    </div>
</div>

<div class="mb-4">
    <form method="get" action="{{ path('admin_produit_index') }}" class="d-flex w-50">
        <input type="text" name="search" class="form-control me-2" placeholder="Rechercher (Nom, Catégorie)..." value="{{ search|default('') }}">
        <button type="submit" class="btn btn-outline-primary"><i class="bi bi-search"></i></button>
        {% if search|default('') %}
            <a href="{{ path('admin_produit_index') }}" class="btn btn-outline-secondary ms-2"><i class="bi bi-x"></i></a>
        {% endif %}
    </form>
</div>

<div class="table-responsive">
    <table class="table table-striped table-hover border">
        <thead class="table-dark">
            <tr>
                <th>
                    <a href="{{ path('admin_produit_index', {'sort': 'id_produit', 'direction': sort == 'id_produit' and direction == 'ASC' ? 'DESC' : 'ASC', 'search': search|default('')}) }}" class="text-white text-decoration-none">
                        ID {% if sort == 'id_produit' %}<i class="bi bi-arrow-{{ direction == 'ASC' ? 'up' : 'down' }}"></i>{% endif %}
                    </a>
                </th>
                <th>
                    <a href="{{ path('admin_produit_index', {'sort': 'nom_produit', 'direction': sort == 'nom_produit' and direction == 'ASC' ? 'DESC' : 'ASC', 'search': search|default('')}) }}" class="text-white text-decoration-none">
                        Nom {% if sort == 'nom_produit' %}<i class="bi bi-arrow-{{ direction == 'ASC' ? 'up' : 'down' }}"></i>{% endif %}
                    </a>
                </th>
                <th>
                    <a href="{{ path('admin_produit_index', {'sort': 'categorie', 'direction': sort == 'categorie' and direction == 'ASC' ? 'DESC' : 'ASC', 'search': search|default('')}) }}" class="text-white text-decoration-none">
                        Catégorie {% if sort == 'categorie' %}<i class="bi bi-arrow-{{ direction == 'ASC' ? 'up' : 'down' }}"></i>{% endif %}
                    </a>
                </th>
                <th>
                    <a href="{{ path('admin_produit_index', {'sort': 'quantite_disponible', 'direction': sort == 'quantite_disponible' and direction == 'ASC' ? 'DESC' : 'ASC', 'search': search|default('')}) }}" class="text-white text-decoration-none">
                        Quantité {% if sort == 'quantite_disponible' %}<i class="bi bi-arrow-{{ direction == 'ASC' ? 'up' : 'down' }}"></i>{% endif %}
                    </a>
                </th>
                <th>Unité</th>
                <th>Commentaire</th>
                <th>
                    <a href="{{ path('admin_produit_index', {'sort': 'prix_unitaire', 'direction': sort == 'prix_unitaire' and direction == 'ASC' ? 'DESC' : 'ASC', 'search': search|default('')}) }}" class="text-white text-decoration-none">
                        Prix unitaire {% if sort == 'prix_unitaire' %}<i class="bi bi-arrow-{{ direction == 'ASC' ? 'up' : 'down' }}"></i>{% endif %}
                    </a>
                </th>
                <th class="text-center">Actions</th>
            </tr>
        </thead>
        <tbody>
            {% for produit in produits %}
            <tr>
                <td class="fw-bold">#{{ produit.idProduit }}</td>
                <td>{{ produit.nomProduit }}</td>
                <td>{{ produit.categorie }}</td>
                <td>
                    <span class="badge {% if produit.quantiteDisponible <= produit.seuilAlerte %}bg-danger{% else %}bg-success{% endif %}">
                        {{ produit.quantiteDisponible }}
                    </span>
                </td>
                <td>{{ produit.unite }}</td>
                <td>{{ produit.commentaire ?: '-' }}</td>
                <td>{{ produit.prixUnitaire }} €</td>
                <td class="text-center">
                    <div class="btn-group">
                        <a href="{{ path('admin_produit_show', {'id_produit': produit.idProduit}) }}" class="btn btn-sm btn-info text-white" title="Voir">
                            <i class="bi bi-eye"></i>
                        </a>
                        <a href="{{ path('app_produit_show', {'id_produit': produit.idProduit}) }}" class="btn btn-sm btn-secondary" title="Commenter">
                            <i class="bi bi-chat-left-text"></i>
                        </a>
                        <a href="{{ path('admin_produit_edit', {'id_produit': produit.idProduit}) }}" class="btn btn-sm btn-warning" title="Modifier">
                            <i class="bi bi-pencil"></i>
                        </a>
                        <form method="post" action="{{ path('admin_produit_delete', {'id_produit': produit.idProduit}) }}" onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer ce produit ?');" class="d-inline">
                            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ produit.idProduit) }}">
                            <button type="submit" class="btn btn-sm btn-danger" title="Supprimer">
                                <i class="bi bi-trash"></i>
                            </button>
                        </form>
                    </div>
                </td>
            </tr>
            {% else %}
            <tr>
                <td colspan="8" class="text-center py-4 text-muted">
                    Aucun produit enregistré
                </td>
            </tr>
            {% endfor %}
        </tbody>
    </table>
</div>
{% endblock %}
