{% extends 'back/base.html.twig' %}

{% block title %}Statistiques Produits - Back{% endblock %}

{% block content %}
<div class="d-flex justify-content-between align-items-center flex-wrap gap-3 mb-4">
    <div>
        <h1 class="h3 m-0 text-dark">Statistiques Produits</h1>
        <p class="text-muted small mb-0">Résumé récoltes, ventes et marges.</p>
    </div>
    <a href="{{ path('admin_produit_index') }}" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left"></i> Retour aux produits
    </a>
</div>

<div class="row g-3 mb-4">
    <div class="col-md-3">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body">
                <div class="text-muted small text-uppercase fw-semibold">Produits</div>
                <div class="display-6 fw-bold">{{ statistics.totalProducts|default(0) }}</div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body">
                <div class="text-muted small text-uppercase fw-semibold">Quantité totale</div>
                <div class="display-6 fw-bold text-primary">{{ statistics.totalQuantity|default(0) }}</div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body">
                <div class="text-muted small text-uppercase fw-semibold">Prix moyen</div>
                <div class="display-6 fw-bold text-success">{{ statistics.averagePrice|default(0)|number_format(2, ',', ' ') }} TND</div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body">
                <div class="text-muted small text-uppercase fw-semibold">Stock faible</div>
                <div class="display-6 fw-bold text-danger">{{ statistics.lowStockCount|default(0) }}</div>
            </div>
        </div>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-lg-5">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-header bg-white border-0 pt-4 px-4">
                <h2 class="h5 m-0">Cercle stock faible</h2>
            </div>
            <div class="card-body">
                <div class="mx-auto" style="max-width: 320px;">
                    <canvas id="lowStockDonut"></canvas>
                </div>
            </div>
        </div>
    </div>
    <div class="col-lg-7">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-header bg-white border-0 pt-4 px-4">
                <h2 class="h5 m-0">Produits par catégorie</h2>
            </div>
            <div class="card-body">
                <div style="height: 320px;">
                    <canvas id="categoryBar"></canvas>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-header bg-white border-0 pt-4 px-4">
        <h2 class="h5 m-0">Répartition par catégorie</h2>
    </div>
    <div class="card-body table-responsive pt-0">
        <table class="table align-middle mb-0">
            <thead>
                <tr>
                    <th>Catégorie</th>
                    <th>Nombre de produits</th>
                </tr>
            </thead>
            <tbody>
                {% for row in categoryCounts %}
                    <tr>
                        <td>{{ row.categorie|default('Non définie') }}</td>
                        <td>{{ row.productCount|default(0) }}</td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="2" class="text-center text-muted py-4">Aucune donnée disponible.</td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.3/dist/chart.umd.min.js"></script>
    <script>
        const totalProducts = {{ statistics.totalProducts|default(0)|json_encode|raw }};
        const lowStockCount = {{ statistics.lowStockCount|default(0)|json_encode|raw }};
        const safeStockCount = Math.max(0, totalProducts - lowStockCount);

        const categoryLabels = [
            {% for row in categoryCounts %}
                {{ row.categorie|default('Non définie')|json_encode|raw }}{% if not loop.last %},{% endif %}
            {% endfor %}
        ];

        const categoryValues = [
            {% for row in categoryCounts %}
                {{ row.productCount|default(0)|json_encode|raw }}{% if not loop.last %},{% endif %}
            {% endfor %}
        ];

        const donutCtx = document.getElementById('lowStockDonut');
        if (donutCtx) {
            new Chart(donutCtx, {
                type: 'doughnut',
                data: {
                    labels: ['Stock faible', 'Stock normal'],
                    datasets: [{
                        data: [lowStockCount, safeStockCount],
                        backgroundColor: ['#e74a3b', '#1cc88a'],
                        borderWidth: 0,
                    }],
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: true,
                    plugins: {
                        legend: {
                            position: 'bottom',
                        },
                    },
                    cutout: '64%',
                },
            });
        }

        const barCtx = document.getElementById('categoryBar');
        if (barCtx) {
            new Chart(barCtx, {
                type: 'bar',
                data: {
                    labels: categoryLabels,
                    datasets: [{
                        label: 'Nombre de produits',
                        data: categoryValues,
                        backgroundColor: '#0d6efd',
                        borderRadius: 8,
                    }],
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    scales: {
                        y: {
                            beginAtZero: true,
                            ticks: {
                                precision: 0,
                            },
                        },
                    },
                    plugins: {
                        legend: {
                            display: false,
                        },
                    },
                },
            });
        }
    </script>
{% endblock %}
