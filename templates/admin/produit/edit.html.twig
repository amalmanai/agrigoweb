{% extends 'back/base.html.twig' %}

{% block title %}Modifier Produit{% endblock %}

{% block content %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="h3 m-0 text-dark">Modifier Produit #{{ produit.idProduit }}</h1>
    </div>
    <a href="{{ path('admin_produit_index') }}" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left"></i> Retour à la liste
    </a>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body p-4">
        {{ form_start(form) }}
            {{ form_widget(form) }}
            <div class="mt-4">
                <button type="submit" class="btn btn-warning text-dark">Mettre à jour</button>
            </div>
        {{ form_end(form) }}
    </div>
</div>
{% endblock %}
