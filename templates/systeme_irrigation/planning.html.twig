{% extends layout %}
{% block title %}Planning d'irrigation suggéré{% endblock %}

{% block content %}
<div class="d-flex flex-wrap justify-content-between align-items-start gap-2 mb-4">
    <div>
        <h1 class="h3 mb-1">Planning d'irrigation suggéré</h1>
        <p class="text-muted mb-0">Créneaux priorisés entre 6h et 8h, sans chevauchement sur la même parcelle.</p>
    </div>
    <a href="{{ path('front_systeme_irrigation_index') }}" class="btn btn-outline-secondary btn-sm">Retour aux systèmes</a>
</div>

<form method="get" class="row g-2 align-items-end mb-4">
    <div class="col-md-5 col-lg-4">
        <label class="form-label small text-muted mb-0">Parcelle</label>
        <select name="parcelle" class="form-select form-select-sm">
            {% for parcelle in parcelles %}
                <option value="{{ parcelle.id }}" {{ parcelle_id_courant == parcelle.id ? 'selected' }}>{{ parcelle.nomParcelle }}</option>
            {% endfor %}
        </select>
    </div>
    <div class="col-md-auto">
        <button type="submit" class="btn btn-sm btn-primary">Afficher</button>
    </div>
</form>

{% if parcelle_selectionnee %}
    <div class="mb-3">
        <span class="badge bg-info text-dark">Parcelle: {{ parcelle_selectionnee.nomParcelle }}</span>
    </div>
{% endif %}

<div class="table-responsive">
    <table class="table table-striped table-hover align-middle">
        <thead>
            <tr>
                <th>ID système</th>
                <th>Nom système</th>
                <th>Créneau suggéré</th>
                <th>Volume estimé</th>
            </tr>
        </thead>
        <tbody>
        {% for planning in plannings %}
            <tr>
                <td>{{ planning.id_systeme }}</td>
                <td>{{ planning.nom_systeme }}</td>
                <td>{{ planning.creneau_suggere }}</td>
                <td>{{ planning.volume_estime }}</td>
            </tr>
        {% else %}
            <tr><td colspan="4" class="text-muted text-center py-4">Aucun système actif à planifier pour cette parcelle.</td></tr>
        {% endfor %}
        </tbody>
    </table>
</div>
{% endblock %}