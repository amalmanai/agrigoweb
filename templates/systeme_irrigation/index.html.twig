{% extends layout %}
{% block title %}Systèmes d'irrigation{% endblock %}

{% block content %}
{% set pfx = app.request.attributes.get('_route') starts with 'admin_' ? 'admin_' : 'front_' %}
<h1 class="h3 mb-4">Systèmes d'irrigation</h1>

<form method="get" class="row g-2 align-items-end mb-4">
    <div class="col-md-4">
        <label class="form-label small text-muted mb-0">Recherche</label>
        <input type="search" name="q" value="{{ search_q }}" class="form-control form-control-sm" placeholder="Nom ou parcelle…">
    </div>
    <div class="col-md-3">
        <label class="form-label small text-muted mb-0">Tri</label>
        <select name="tri" class="form-select form-select-sm">
            <option value="nom_asc" {{ tri_courant == 'nom_asc' ? 'selected' }}>Nom (A→Z)</option>
            <option value="nom_desc" {{ tri_courant == 'nom_desc' ? 'selected' }}>Nom (Z→A)</option>
            <option value="date_asc" {{ tri_courant == 'date_asc' ? 'selected' }}>Création (ancien)</option>
            <option value="date_desc" {{ tri_courant == 'date_desc' ? 'selected' }}>Création (récent)</option>
            <option value="parcelle_asc" {{ tri_courant == 'parcelle_asc' ? 'selected' }}>Parcelle (A→Z)</option>
            <option value="parcelle_desc" {{ tri_courant == 'parcelle_desc' ? 'selected' }}>Parcelle (Z→A)</option>
        </select>
    </div>
    <div class="col-md-auto">
        <button type="submit" class="btn btn-sm btn-outline-primary">Filtrer</button>
        <a href="{{ path(pfx ~ 'systeme_irrigation_index') }}" class="btn btn-sm btn-outline-secondary">Réinitialiser</a>
    </div>
    <div class="col-md-auto ms-md-auto">
        <a href="{{ path(pfx ~ 'systeme_irrigation_new') }}" class="btn btn-sm btn-primary">Nouveau système</a>
    </div>
</form>

<div class="table-responsive">
    <table class="table table-striped table-hover align-middle">
        <thead>
            <tr>
                <th>Nom</th>
                <th>Parcelle</th>
                <th>Mode</th>
                <th>Statut</th>
                <th class="text-end">Actions</th>
            </tr>
        </thead>
        <tbody>
        {% for s in systemes %}
            {% set p = parcellesParId[s.idParcelle] ?? null %}
            <tr>
                <td>{{ s.nomSysteme }}</td>
                <td>{{ p ? p.nomParcelle : '—' }}</td>
                <td>{{ s.mode ?? '—' }}</td>
                <td>{{ s.statut ?? '—' }}</td>
                <td class="text-end">
                    <a href="{{ path(pfx ~ 'systeme_irrigation_show', {idSysteme: s.idSysteme}) }}" class="btn btn-sm btn-outline-primary">Voir</a>
                    <a href="{{ path(pfx ~ 'systeme_irrigation_edit', {idSysteme: s.idSysteme}) }}" class="btn btn-sm btn-outline-secondary">Modifier</a>
                </td>
            </tr>
        {% else %}
            <tr><td colspan="5" class="text-muted text-center py-4">Aucun système trouvé.</td></tr>
        {% endfor %}
        </tbody>
    </table>
</div>
{% endblock %}
