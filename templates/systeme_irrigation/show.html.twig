{% extends layout %}
{% block title %}{{ systeme.nomSysteme }}{% endblock %}

{% block content %}
{% set pfx = app.request.attributes.get('_route') starts with 'admin_' ? 'admin_' : 'front_' %}
<div class="d-flex flex-wrap justify-content-between align-items-start gap-2 mb-4">
    <h1 class="h3 mb-0">{{ systeme.nomSysteme }}</h1>
    <div class="d-flex flex-wrap gap-2">
        <a href="{{ path(pfx ~ 'systeme_irrigation_edit', {idSysteme: systeme.idSysteme}) }}" class="btn btn-primary btn-sm">Modifier</a>
        <a href="{{ path(pfx ~ 'systeme_irrigation_index') }}" class="btn btn-outline-secondary btn-sm">Liste</a>
        {{ include('systeme_irrigation/_delete_form.html.twig') }}
    </div>
</div>

<dl class="row">
    <dt class="col-sm-3">Parcelle</dt>
    <dd class="col-sm-9">{{ parcelle ? parcelle.nomParcelle : '—' }}</dd>
    <dt class="col-sm-3">Seuil humidité</dt>
    <dd class="col-sm-9">{{ systeme.seuilHumidite ?? '—' }}</dd>
    <dt class="col-sm-3">Mode</dt>
    <dd class="col-sm-9">{{ systeme.mode ?? '—' }}</dd>
    <dt class="col-sm-3">Statut</dt>
    <dd class="col-sm-9">{{ systeme.statut ?? '—' }}</dd>
    <dt class="col-sm-3">Création</dt>
    <dd class="col-sm-9">{{ systeme.dateCreation ? systeme.dateCreation|date('d/m/Y H:i') : '—' }}</dd>
</dl>
{% endblock %}
