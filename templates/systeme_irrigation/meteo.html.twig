{% extends layout %}
{% block title %}Météo des parcelles{% endblock %}

{% block content %}
<style>
    .weather-hero {
        background: linear-gradient(135deg, #0f172a 0%, #1d4ed8 55%, #38bdf8 100%);
        color: #fff;
        border-radius: 1.5rem;
        padding: 1.5rem;
        box-shadow: 0 18px 40px rgba(15, 23, 42, 0.18);
    }
    .weather-card {
        border: 0;
        border-radius: 1.25rem;
        overflow: hidden;
        box-shadow: 0 10px 24px rgba(15, 23, 42, 0.08);
    }
    .weather-card .card-header {
        background: linear-gradient(135deg, rgba(15, 23, 42, 0.96), rgba(30, 64, 175, 0.96));
        color: #fff;
        border: 0;
    }
    .weather-metric {
        background: #f8fafc;
        border-radius: 1rem;
        padding: 0.9rem 1rem;
        height: 100%;
    }
</style>

<div class="weather-hero mb-4">
    <div class="d-flex flex-wrap justify-content-between align-items-start gap-3">
        <div>
            <h1 class="h3 mb-2">Météo des parcelles</h1>
            <p class="mb-0 opacity-75">Prévisions OpenWeatherMap par parcelle, avec alerte automatique si l'irrigation AUTO est déconseillée.</p>
        </div>
        <a href="{{ path('front_systeme_irrigation_index') }}" class="btn btn-light btn-sm">Retour aux systèmes</a>
    </div>
</div>

<div class="row g-4">
    {% for card in cards %}
        {% set meteo = card.meteo %}
        <div class="col-12 col-lg-6">
            <div class="card weather-card h-100">
                <div class="card-header d-flex flex-wrap justify-content-between align-items-center gap-2">
                    <div>
                        <h2 class="h5 mb-1">{{ card.parcelle.nomParcelle }}</h2>
                        <div class="small opacity-75">{{ card.parcelle.coordonneesGps ?? 'Coordonnées indisponibles' }}</div>
                    </div>
                    <div class="text-end small">
                        <div>{{ card.systemes|length }} système(s) actif(s)</div>
                        <div>{{ card.has_auto ? 'Mode AUTO présent' : 'Pas de système AUTO' }}</div>
                    </div>
                </div>
                <div class="card-body">
                    {% if meteo and meteo.disponible %}
                        <div class="row g-3 mb-3">
                            <div class="col-6 col-xl-3">
                                <div class="weather-metric">
                                    <div class="text-muted small">Température</div>
                                    <div class="fs-4 fw-semibold">{{ meteo.temperature is not null ? meteo.temperature ~ '°C' : '—' }}</div>
                                </div>
                            </div>
                            <div class="col-6 col-xl-3">
                                <div class="weather-metric">
                                    <div class="text-muted small">Humidité</div>
                                    <div class="fs-4 fw-semibold">{{ meteo.humidite is not null ? meteo.humidite ~ '%' : '—' }}</div>
                                </div>
                            </div>
                            <div class="col-6 col-xl-3">
                                <div class="weather-metric">
                                    <div class="text-muted small">Pluie 6h</div>
                                    <div class="fs-4 fw-semibold">{{ meteo.pluie_prevue_prochaines_6h ? 'Oui' : 'Non' }}</div>
                                </div>
                            </div>
                            <div class="col-6 col-xl-3">
                                <div class="weather-metric">
                                    <div class="text-muted small">Alerte</div>
                                    <div class="fs-6 fw-semibold {{ meteo.avertissement ? 'text-danger' : 'text-success' }}">
                                        {{ meteo.avertissement ?? 'Aucune' }}
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="d-flex flex-wrap align-items-center gap-2">
                            <span class="badge bg-primary text-uppercase">{{ meteo.description_meteo }}</span>
                            {% if meteo.pluie_prevue_prochaines_6h %}
                                <span class="badge bg-warning text-dark">Pluie prévue sous 6h</span>
                            {% else %}
                                <span class="badge bg-success">Pas de pluie imminente</span>
                            {% endif %}
                        </div>

                        {% if meteo.avertissement %}
                            <div class="alert alert-warning mt-3 mb-0">
                                {{ meteo.avertissement }}
                            </div>
                        {% endif %}
                    {% elseif meteo %}
                        <div class="alert alert-secondary mb-0">
                            {{ meteo.description_meteo }}
                        </div>
                    {% else %}
                        <div class="alert alert-secondary mb-0">Coordonnées GPS manquantes pour cette parcelle.</div>
                    {% endif %}
                </div>
            </div>
        </div>
    {% else %}
        <div class="col-12">
            <div class="alert alert-info">Aucune parcelle disponible.</div>
        </div>
    {% endfor %}
</div>
{% endblock %}