{% extends 'base.html.twig' %}

{% block title %}Tâches{% endblock %}

{% block content %}
<div class="py-12 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <!-- Header -->
        <div class="mb-8 flex justify-between items-center">
            <div>
                <h1 class="text-3xl font-bold text-gray-900">Tâches</h1>
                <p class="mt-2 text-gray-600">Gérez vos tâches agricoles</p>
            </div>
            <a href="{{ path('app_tache_new') }}" class="bg-green-600 hover:bg-green-700 text-white font-semibold py-2 px-6 rounded-lg transition duration-200">
                + Créer une Tâche
            </a>
        </div>

        <!-- Flash Messages -->
        {% for message in app.flashes('success') %}
            <div class="mb-4 p-4 bg-green-100 border border-green-400 text-green-700 rounded-lg">
                {{ message }}
            </div>
        {% endfor %}

        <!-- Tâches Grid -->
        {% if taches|length > 0 %}
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                {% for tache in taches %}
                    <div class="bg-white rounded-lg shadow-md hover:shadow-lg transition duration-200 overflow-hidden">
                        <div class="p-6">
                            <div class="flex justify-between items-start mb-3">
                                <h3 class="text-lg font-semibold text-gray-900">{{ tache.tittre_tache }}</h3>
                                <span class="inline-block
                                    {% if tache.status_tache == 'Terminée' %}
                                        bg-green-100 text-green-800
                                    {% elseif tache.status_tache == 'En cours' %}
                                        bg-blue-100 text-blue-800
                                    {% elseif tache.status_tache == 'En attente' %}
                                        bg-yellow-100 text-yellow-800
                                    {% elseif tache.status_tache == 'Annulée' %}
                                        bg-red-100 text-red-800
                                    {% else %}
                                        bg-gray-100 text-gray-800
                                    {% endif %}
                                    px-3 py-1 rounded-full text-sm font-medium">
                                    {{ tache.status_tache }}
                                </span>
                            </div>

                            <p class="text-gray-600 text-sm mb-4">{{ tache.description_tache }}</p>

                            <div class="space-y-2 text-sm text-gray-600 mb-4">
                                <p><strong>Type:</strong> {{ tache.type_tache }}</p>
                                <p><strong>Date:</strong> {{ tache.date_tache|date('d/m/Y') }}</p>
                                <p><strong>Horaires:</strong> {{ tache.heure_debut_tache }} - {{ tache.heure_fin_tache }}</p>
                            </div>

                            <div class="pt-4 border-t border-gray-200 flex gap-2">
                                <a href="{{ path('app_tache_show', {id: tache.id}) }}" class="flex-1 bg-blue-600 hover:bg-blue-700 text-white font-semibold py-2 px-4 rounded-lg text-center transition duration-200">
                                    Voir
                                </a>
                                <a href="{{ path('app_tache_edit', {id: tache.id}) }}" class="flex-1 bg-yellow-600 hover:bg-yellow-700 text-white font-semibold py-2 px-4 rounded-lg text-center transition duration-200">
                                    Modifier
                                </a>
                                <form method="POST" action="{{ path('app_tache_delete', {id: tache.id}) }}" class="flex-1" onsubmit="return confirm('Êtes-vous sûr?');">
                                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ tache.id) }}">
                                    <button type="submit" class="w-full bg-red-600 hover:bg-red-700 text-white font-semibold py-2 px-4 rounded-lg transition duration-200">
                                        Supprimer
                                    </button>
                                </form>
                            </div>
                        </div>
                    </div>
                {% endfor %}
            </div>
        {% else %}
            <div class="text-center py-12 bg-white rounded-lg">
                <p class="text-gray-500 text-lg">Aucune tâche trouvée</p>
                <a href="{{ path('app_tache_new') }}" class="mt-4 inline-block bg-green-600 hover:bg-green-700 text-white font-semibold py-2 px-6 rounded-lg transition duration-200">
                    Créer la première tâche
                </a>
            </div>
        {% endif %}
    </div>
</div>
{% endblock %}
